{
  "stryker-config": {
    "project": "Humans.Application.csproj",
    "test-runner": "mtp",
    "coverage-analysis": "off",
    "mutation-level": "Standard",
    "mutate": [
      "**/Authorization/UserEmail/*.cs",
      "**/FullProfile.cs",
      "**/Helpers/ProfileCompletion.cs",
      "**/Services/Profile/*.cs",
      "**/Services/Profiles/*.cs"
    ],
    "concurrency": 16,
    "reporters": [
      "ClearText",
      "Json",
      "Html"
    ],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    }
  }
}
