@model Humans.Web.Models.Events.ModerationQueueViewModel
@{
    ViewData["Title"] = "Moderate Events";
}

<h2 class="mb-3">Moderate Events</h2>

<vc:temp-data-alerts />

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link @(Model.ActiveTab == EventStatus.Pending ? "active" : "")"
           asp-action="Index" asp-route-tab="@EventStatus.Pending">
            Pending <span class="badge bg-warning text-dark">@Model.PendingCount</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.ActiveTab == EventStatus.Approved ? "active" : "")"
           asp-action="Index" asp-route-tab="@EventStatus.Approved">
            Approved <span class="badge bg-success">@Model.ApprovedCount</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.ActiveTab == EventStatus.Rejected ? "active" : "")"
           asp-action="Index" asp-route-tab="@EventStatus.Rejected">
            Rejected <span class="badge bg-danger">@Model.RejectedCount</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.ActiveTab == EventStatus.ResubmitRequested ? "active" : "")"
           asp-action="Index" asp-route-tab="@EventStatus.ResubmitRequested">
            Resubmit <span class="badge bg-info">@Model.ResubmitRequestedCount</span>
        </a>
    </li>
</ul>

@if (Model.Events.Count == 0)
{
    <div class="alert alert-secondary">
        No events in this category.
    </div>
}
else
{
    <div class="accordion" id="moderationAccordion">
        @foreach (var evt in Model.Events)
        {
            var collapseId = $"collapse-{evt.Id:N}";
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                        <div class="d-flex w-100 justify-content-between align-items-center me-3">
                            <div>
                                <strong>@evt.Title</strong>
                                <span class="text-muted ms-2">
                                    @if (evt.CampName != null)
                                    {
                                        <i class="fa-solid fa-campground me-1"></i>@evt.CampName
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-user me-1"></i>@evt.SubmitterName
                                        @if (evt.VenueName != null)
                                        {
                                            <text> &#64; @evt.VenueName</text>
                                        }
                                    }
                                </span>
                            </div>
                            <div class="d-flex gap-2 align-items-center">
                                <span class="badge bg-secondary">@evt.CategoryName</span>
                                <small class="text-muted">@evt.StartAt.ToString("d MMM HH:mm") &middot; @evt.DurationMinutes min</small>
                                @if (evt.DuplicateCandidates.Count > 0)
                                {
                                    <span class="badge bg-warning text-dark" title="Potential duplicate"><i class="fa-solid fa-triangle-exclamation"></i></span>
                                }
                                <span class="badge @evt.StatusBadgeClass">@evt.Status</span>
                            </div>
                        </div>
                    </button>
                </h2>
                <div id="@collapseId" class="accordion-collapse collapse" data-bs-parent="#moderationAccordion">
                    <div class="accordion-body">
                        <div class="row">
                            <div class="col-md-8">
                                <dl class="row mb-0">
                                    <dt class="col-sm-3">Description</dt>
                                    <dd class="col-sm-9">@evt.Description</dd>

                                    <dt class="col-sm-3">Submitter</dt>
                                    <dd class="col-sm-9">
                                        <vc:human user-id="@evt.SubmitterUserId" link="Admin" />
                                    </dd>

                                    @if (evt.CampName != null)
                                    {
                                        <dt class="col-sm-3">Camp</dt>
                                        <dd class="col-sm-9">
                                            <a asp-controller="Camp" asp-action="Details" asp-route-slug="@evt.CampSlug">@evt.CampName</a>
                                        </dd>
                                    }

                                    @if (evt.VenueName != null)
                                    {
                                        <dt class="col-sm-3">Venue</dt>
                                        <dd class="col-sm-9">@evt.VenueName</dd>
                                    }

                                    <dt class="col-sm-3">Date / Time</dt>
                                    <dd class="col-sm-9">@evt.StartAt.ToString("ddd d MMM yyyy, HH:mm") (@evt.DurationMinutes min)</dd>

                                    @if (!string.IsNullOrEmpty(evt.LocationNote))
                                    {
                                        <dt class="col-sm-3">Location Note</dt>
                                        <dd class="col-sm-9">@evt.LocationNote</dd>
                                    }

                                    @if (evt.IsRecurring)
                                    {
                                        <dt class="col-sm-3">Recurrence</dt>
                                        <dd class="col-sm-9">Day offsets: @evt.RecurrenceDays</dd>
                                    }

                                    @if (evt.PriorityRank > 0)
                                    {
                                        <dt class="col-sm-3">Priority Rank</dt>
                                        <dd class="col-sm-9">@evt.PriorityRank</dd>
                                    }

                                    <dt class="col-sm-3">Submitted</dt>
                                    <dd class="col-sm-9">@evt.SubmittedAt.ToString("d MMM yyyy HH:mm")</dd>
                                </dl>

                                @if (evt.DuplicateCandidates.Count > 0)
                                {
                                    <hr />
                                    <h6><i class="fa-solid fa-triangle-exclamation text-warning me-1"></i>Potential Duplicates</h6>
                                    <ul class="list-unstyled">
                                        @foreach (var dup in evt.DuplicateCandidates)
                                        {
                                            <li class="mb-1">
                                                <strong>@dup.Title</strong>
                                                — @dup.StartAt.ToString("d MMM HH:mm") (@dup.DurationMinutes min)
                                                <span class="badge bg-secondary">@dup.Status</span>
                                            </li>
                                        }
                                    </ul>
                                }

                                @if (evt.History.Count > 0)
                                {
                                    <hr />
                                    <h6>Moderation History</h6>
                                    <ul class="list-unstyled">
                                        @foreach (var h in evt.History)
                                        {
                                            <li class="mb-2">
                                                <span class="badge @h.ActionBadgeClass">@h.Action</span>
                                                by <strong>@h.ActorName</strong>
                                                <small class="text-muted">@h.CreatedAt.ToString("d MMM yyyy HH:mm")</small>
                                                @if (!string.IsNullOrEmpty(h.Reason))
                                                {
                                                    <br /><small class="text-muted fst-italic">@h.Reason</small>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>

                            @if (evt.Status == EventStatus.Pending)
                            {
                                <div class="col-md-4">
                                    <div class="card">
                                        <div class="card-body">
                                            <h6 class="card-title">Actions</h6>

                                            <form method="post" asp-action="Approve" class="mb-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="EventId" value="@evt.Id" />
                                                <button type="submit" class="btn btn-success w-100">
                                                    <i class="fa-solid fa-check me-1"></i>Approve
                                                </button>
                                            </form>

                                            <form method="post" asp-action="Reject" class="mb-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="EventId" value="@evt.Id" />
                                                <div class="mb-2">
                                                    <textarea name="Reason" class="form-control form-control-sm" rows="2" maxlength="500" placeholder="Reason for rejection (required)"></textarea>
                                                </div>
                                                <button type="submit" class="btn btn-danger w-100">
                                                    <i class="fa-solid fa-xmark me-1"></i>Reject
                                                </button>
                                            </form>

                                            <form method="post" asp-action="RequestEdit">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="EventId" value="@evt.Id" />
                                                <div class="mb-2">
                                                    <textarea name="Reason" class="form-control form-control-sm" rows="2" maxlength="500" placeholder="What needs changing? (required)"></textarea>
                                                </div>
                                                <button type="submit" class="btn btn-info w-100">
                                                    <i class="fa-solid fa-pen-to-square me-1"></i>Request Edit
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
