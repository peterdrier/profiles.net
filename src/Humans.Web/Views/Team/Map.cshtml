@model Humans.Web.Models.MapViewModel
@{
    ViewData["Title"] = Localizer["Map_Title"].Value;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">@Localizer["Teams_Title"]</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Localizer["Map_Title"]</li>
    </ol>
</nav>

<h1 class="mb-4">@Localizer["Map_Title"]</h1>

@if (Model.Markers.Count > 0)
{
    <div class="card">
        <div class="card-header">
            @string.Format(Localizer["Map_Count"].Value, Model.Markers.Count)
        </div>
        <div class="card-body p-0">
            <div id="map" style="height: 600px; width: 100%;"></div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            @Localizer["Map_None"]
        </div>
    </div>
}

<div class="mt-3">
    <p class="text-muted small">@Localizer["Map_Privacy"]</p>
</div>

@section Scripts {
    @if (Model.Markers.Count > 0 && !string.IsNullOrEmpty(ViewData["GoogleMapsApiKey"]?.ToString()))
    {
        <script>
            (g=>{var h,a,k,p="The Google Maps JavaScript API",c="google",l="importLibrary",q="__ib__",m=document,b=window;b=b[c]||(b[c]={});var d=b.maps||(b.maps={}),r=new Set,e=new URLSearchParams,u=()=>h||(h=new Promise(async(f,n)=>{await (a=m.createElement("script"));e.set("libraries",[...r]+"");for(k in g)e.set(k.replace(/[A-Z]/g,t=>"_"+t[0].toLowerCase()),g[k]);e.set("callback",c+".maps."+q);a.src=`https://maps.${c}apis.com/maps/api/js?`+e;d[q]=f;a.onerror=()=>h=n(Error(p+" could not load."));a.nonce=m.querySelector("script[nonce]")?.nonce||"";m.head.append(a)}));d[l]?console.warn(p+" only loads once. Ignoring:",g):d[l]=(f,...n)=>r.add(f)&&u().then(()=>d[l](f,...n))})({
                key: "@ViewData["GoogleMapsApiKey"]",
                v: "weekly"
            });
        </script>
        <script src="https://unpkg.com/&#64;googlemaps/markerclusterer/dist/index.min.js"></script>
        <script>
            const markers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Markers, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

            @await Html.PartialAsync("~/Views/Shared/_EscapeHtmlScript.cshtml")

            // Read CSS variables for JS-generated markup
            const _cs = getComputedStyle(document.documentElement);
            const cssVar = (name) => _cs.getPropertyValue(name).trim();
            const clrMutedText = cssVar('--h-muted-text');
            const clrTextOnDark = cssVar('--h-text-on-dark');
            const clrTextSecondary = cssVar('--h-text-secondary');
            const clrMapPin = cssVar('--h-map-pin');
            const clrMapPinBorder = cssVar('--h-map-pin-border');
            const clrMapClusterLarge = cssVar('--h-map-cluster-large');
            const clrMapClusterLargeBorder = cssVar('--h-map-cluster-large-border');
            const clrMapClusterMedium = cssVar('--h-map-cluster-medium');
            const clrMapClusterMediumBorder = cssVar('--h-map-cluster-medium-border');

            function avatarHtml(m, size) {
                const s = size || 40;
                if (m.profilePictureUrl) {
                    return '<img src="' + escapeHtml(m.profilePictureUrl) + '" alt="" style="width:' + s + 'px;height:' + s + 'px;border-radius:50%;object-fit:cover;">';
                }
                const initials = (m.displayName || '?').split(' ').map(function(w){return w[0];}).join('').substring(0, 2).toUpperCase();
                return '<div style="width:' + s + 'px;height:' + s + 'px;border-radius:50%;background:' + clrMutedText + ';color:' + clrTextOnDark + ';display:flex;align-items:center;justify-content:center;font-size:' + Math.round(s * 0.4) + 'px;font-weight:600;">' + escapeHtml(initials) + '</div>';
            }

            function personHtml(m) {
                const location = [m.city, m.countryCode].filter(Boolean).join(', ');
                return '<div style="display:flex;align-items:center;gap:8px;padding:4px 0;">' +
                    avatarHtml(m, 36) +
                    '<div>' +
                    '<a href="/Profile/' + m.userId + '" style="font-weight:600;text-decoration:none;">' + escapeHtml(m.displayName) + '</a>' +
                    (location ? '<br><span style="color:' + clrTextSecondary + ';font-size:0.85em;">' + escapeHtml(location) + '</span>' : '') +
                    '</div></div>';
            }

            // Group markers by exact lat/lng
            function groupByLocation(data) {
                const groups = {};
                for (const m of data) {
                    const key = m.latitude.toFixed(6) + ',' + m.longitude.toFixed(6);
                    if (!groups[key]) groups[key] = [];
                    groups[key].push(m);
                }
                return Object.values(groups);
            }

            async function initMap() {
                const { Map, InfoWindow } = await google.maps.importLibrary("maps");
                const { AdvancedMarkerElement, PinElement } = await google.maps.importLibrary("marker");

                const map = new Map(document.getElementById("map"), {
                    zoom: 3,
                    center: { lat: 40, lng: -3 },
                    mapId: "volunteer-map"
                });

                const infoWindow = new InfoWindow();
                const mapMarkers = [];
                const groups = groupByLocation(markers);

                for (const group of groups) {
                    const first = group[0];
                    let pinContent;

                    if (group.length > 1) {
                        // Multi-person pin with count
                        const pin = new PinElement({
                            glyph: '' + group.length,
                            glyphColor: clrTextOnDark,
                            background: clrMapPin,
                            borderColor: clrMapPinBorder,
                            scale: 1.1
                        });
                        pinContent = pin.element;
                    } else {
                        pinContent = undefined; // default pin
                    }

                    const marker = new AdvancedMarkerElement({
                        position: { lat: first.latitude, lng: first.longitude },
                        map: map,
                        title: group.length > 1 ? group.length + ' humans' : first.displayName,
                        gmpClickable: true,
                        content: pinContent
                    });

                    marker._people = group;

                    marker.addEventListener("gmp-click", function () {
                        const people = marker._people;
                        let html = '<div style="max-height:300px;overflow-y:auto;">';
                        for (const p of people) {
                            html += personHtml(p);
                        }
                        html += '</div>';
                        infoWindow.setContent(html);
                        infoWindow.open({ anchor: marker, map: map });
                    });

                    mapMarkers.push(marker);
                }

                // Cluster with count rendering
                if (typeof markerClusterer !== 'undefined') {
                    var renderer = {
                        render: function(ref) {
                            var count = ref.count;
                            var position = ref.position;
                            // Sum actual people counts from grouped markers
                            var totalPeople = 0;
                            for (var gm of ref.markers) {
                                totalPeople += (gm._people ? gm._people.length : 1);
                            }
                            var pin = new PinElement({
                                glyph: '' + totalPeople,
                                glyphColor: clrTextOnDark,
                                background: totalPeople > 10 ? clrMapClusterLarge : totalPeople > 5 ? clrMapClusterMedium : clrMapPin,
                                borderColor: totalPeople > 10 ? clrMapClusterLargeBorder : totalPeople > 5 ? clrMapClusterMediumBorder : clrMapPinBorder,
                                scale: 1.2 + Math.min(totalPeople / 50, 0.6)
                            });
                            return new AdvancedMarkerElement({
                                position: position,
                                content: pin.element
                            });
                        }
                    };
                    new markerClusterer.MarkerClusterer({ markers: mapMarkers, map: map, renderer: renderer });
                }

                // Fit bounds with European focus fallback
                if (markers.length > 1) {
                    const bounds = new google.maps.LatLngBounds();
                    for (const m of markers) {
                        bounds.extend({ lat: m.latitude, lng: m.longitude });
                    }
                    map.fitBounds(bounds, 50);
                    // If outliers cause extreme zoom-out, default to Europe-centered view
                    google.maps.event.addListenerOnce(map, 'idle', function() {
                        if (map.getZoom() < 4) {
                            map.setCenter({ lat: 43, lng: 5 });
                            map.setZoom(4);
                        }
                    });
                } else if (markers.length === 1) {
                    map.setCenter({ lat: markers[0].latitude, lng: markers[0].longitude });
                    map.setZoom(10);
                }
            }

            initMap();
        </script>
    }
}
