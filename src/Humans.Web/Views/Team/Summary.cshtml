@model Humans.Web.Models.AdminTeamListViewModel
@{
    ViewData["Title"] = "Teams Summary";

    var groups = new (string Heading, List<AdminTeamViewModel> Teams)[]
    {
        ("Departments", Model.Departments),
        ("System", Model.System),
        ("Hidden", Model.Hidden),
    };
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">@Localizer["Teams_Title"]</a></li>
        <li class="breadcrumb-item active" aria-current="page">Teams Summary</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Teams Summary</h1>
    <a asp-action="CreateTeam" class="btn btn-primary" authorize-policy="BoardOrAdmin">@Localizer["Teams_CreateTeam"]</a>
</div>

<vc:temp-data-alerts />

@foreach (var group in groups)
{
    <h2 class="h5 mt-4 mb-2">@group.Heading</h2>
    @if (group.Teams.Count == 0)
    {
        <p class="text-muted small mb-0">No teams in this group.</p>
    }
    else
    {
        <div class="card mb-3">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@Localizer["AdminTeams_Name"]</th>
                            <th>@Localizer["AdminTeams_Type"]</th>
                            <th>@Localizer["AdminTeams_Members"]</th>
                            <th>@Localizer["AdminTeams_PendingJoins"]</th>
                            <th>@Localizer["AdminTeams_PendingShifts"]</th>
                            <th>@Localizer["AdminTeams_MailGroup"]</th>
                            <th>Slots</th>
                            <th>@Localizer["AdminTeams_DriveResources"]</th>
                            <th>@Localizer["Common_Status"]</th>
                            <th>@Localizer["AdminTeams_Created"]</th>
                            <th authorize-policy="BoardOrAdmin">@Localizer["MyTeams_Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var team in group.Teams)
                        {
                            <partial name="_AdminTeamRow" model="team" />
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@if (!Model.HasAnyTeams)
{
    <div class="alert alert-info mt-3">
        @Localizer["Teams_NoTeams"]
    </div>
}
