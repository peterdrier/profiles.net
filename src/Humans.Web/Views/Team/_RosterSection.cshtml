@model List<Humans.Web.Models.TeamRoleDefinitionViewModel>

@{
    var canManage = (bool)(ViewData["CanManage"] ?? false);
    var visibleRoles = canManage ? Model : Model.Where(r => r.IsPublic).ToList();
}

@if (visibleRoles.Any())
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Roles</h5>
            @if (canManage)
            {
                <a href="@Url.Action("Roles", "TeamAdmin", new { slug = ViewData["Slug"] })"
                   class="btn btn-sm btn-outline-primary">Edit Roles</a>
            }
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Role</th>
                        <th>Slot</th>
                        <th>Priority</th>
                        <th>Assigned To</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in visibleRoles)
                    {
                        var collapseId = $"role-desc-{role.Id:N}";
                        @foreach (var slot in role.Slots)
                        {
                            <tr>
                                @if (slot.SlotIndex == 0)
                                {
                                    <td rowspan="@role.Slots.Count">
                                        <strong>@role.Name</strong>
                                        @if (role.Period != RolePeriod.YearRound)
                                        {
                                            var rpBadge = role.Period switch
                                            {
                                                RolePeriod.Build => "bg-info",
                                                RolePeriod.Event => "bg-success",
                                                RolePeriod.Strike => "bg-secondary",
                                                _ => "bg-light text-dark"
                                            };
                                            <span class="badge @rpBadge ms-1">@role.Period</span>
                                        }
                                        @if (!string.IsNullOrEmpty(role.Description))
                                        {
                                            <br />
                                            <a class="text-muted small text-decoration-none" data-bs-toggle="collapse"
                                               href="#@collapseId" role="button" aria-expanded="false" aria-controls="@collapseId">
                                                <i class="fa-solid fa-chevron-down role-desc-chevron"></i> Details
                                            </a>
                                        }
                                    </td>
                                }
                                <td>@(slot.SlotIndex + 1)</td>
                                <td><span class="badge @slot.PriorityBadgeClass">@(slot.Priority == SlotPriority.NiceToHave ? "Nice to Have" : slot.Priority.ToString())</span></td>
                                <td>
                                    @if (slot.IsFilled && slot.AssignedUserId.HasValue)
                                    {
                                        <vc:human user-id="@slot.AssignedUserId.Value" />
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Open</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!string.IsNullOrEmpty(role.Description))
                        {
                            <tr class="collapse" id="@collapseId">
                                <td colspan="4">
                                    <div class="role-description small text-muted">
                                        @Html.SanitizedMarkdown(role.Description)
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}
