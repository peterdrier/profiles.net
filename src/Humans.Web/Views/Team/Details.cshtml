@model Humans.Web.Models.TeamDetailViewModel
@{
    ViewData["Title"] = Model.Name;
}


<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">@Localizer["Teams_Title"]</a></li>
        @if (Model.ParentTeam != null)
        {
            <li class="breadcrumb-item"><a asp-action="Details" asp-route-slug="@Model.ParentTeam.Slug">@Model.ParentTeam.Name</a></li>
        }
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
    </ol>
</nav>

<vc:temp-data-alerts />

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">@Model.Name</h4>
                <div>
                    @if (Model.IsAuthenticated)
                    {
                        @if (Model.IsSystemTeam)
                        {
                            <span class="badge bg-secondary">@Model.SystemTeamType @Localizer["Teams_Member"]</span>
                        }
                        @if (Model.IsCurrentUserMember)
                        {
                            @await Html.PartialAsync("_RoleBadge", TeamMemberRole.Member)
                        }
                        @if (Model.IsCurrentUserCoordinator)
                        {
                            @await Html.PartialAsync("_RoleBadge", TeamMemberRole.Coordinator)
                        }
                    }
                </div>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="card-text">@Html.SanitizedMarkdown(Model.Description)</div>
                }
                else
                {
                    <p class="text-muted">@Localizer["TeamDetail_NoDescription"]</p>
                }

                @if (Model.IsAuthenticated && Model.IsSystemTeam)
                {
                    <div class="alert alert-info mb-0">
                        @string.Format(Localizer["TeamDetail_SystemTeamInfo"].Value, Model.SystemTeamType)
                    </div>
                }
            </div>
            <div class="card-footer">
                <small class="text-muted">@Localizer["TeamDetail_Created"] @Model.CreatedAt.ToDisplayLongDate()</small>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.PageContentHtml))
        {
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>@Localizer["TeamDetail_AboutTeam"]</span>
                    @if (Model.CanEditPageContent)
                    {
                        <a asp-controller="TeamAdmin" asp-action="EditPage" asp-route-slug="@Model.Slug" class="btn btn-sm btn-outline-secondary">
                            <i class="fa-solid fa-pen-to-square me-1"></i>@Localizer["TeamDetail_EditPage"]
                        </a>
                    }
                </div>
                <div class="card-body">
                    <div class="markdown-content">
                        @Html.Raw(Model.PageContentHtml)
                    </div>
                    @if (Model.PageContentUpdatedAt.HasValue)
                    {
                        <hr />
                        <small class="text-muted">
                            @Localizer["TeamDetail_LastUpdated"] @Model.PageContentUpdatedAt.Value.ToString("MMMM d, yyyy")
                            @if (!string.IsNullOrEmpty(Model.PageContentUpdatedByDisplayName))
                            {
                                @: &mdash; @Model.PageContentUpdatedByDisplayName
                            }
                        </small>
                    }
                </div>
            </div>
        }
        else if (Model.CanEditPageContent)
        {
            <div class="card mb-4">
                <div class="card-body text-center py-4">
                    <p class="text-muted mb-3">@Localizer["TeamDetail_NoPageContent"]</p>
                    <a asp-controller="TeamAdmin" asp-action="EditPage" asp-route-slug="@Model.Slug" class="btn btn-outline-primary">
                        <i class="fa-solid fa-pen-to-square me-1"></i>@Localizer["TeamDetail_AddPageContent"]
                    </a>
                </div>
            </div>
        }

        @if (Model.CallsToAction?.Any() == true)
        {
            <div class="d-flex flex-wrap gap-2 mb-4">
                @foreach (var cta in Model.CallsToAction)
                {
                    var btnClass = cta.Style == CallToActionStyle.Primary ? "btn-primary btn-lg" : "btn-outline-secondary";
                    <a href="@cta.Url" target="_blank" rel="noopener noreferrer" class="btn @btnClass">
                        @cta.Text <i class="fa-solid fa-arrow-up-right-from-square ms-1"></i>
                    </a>
                }
            </div>
        }

        @if (Model.IsAuthenticated)
        {
            @await Html.PartialAsync("_RosterSection", Model.RoleDefinitions,
                new ViewDataDictionary(ViewData) {
                    { "CanManage", Model.CanCurrentUserManage },
                    { "Slug", Model.Slug }
                })
        }

        @if (Model.IsAuthenticated || Model.ShowCoordinatorsOnPublicPage)
        {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                @if (Model.IsAuthenticated)
                {
                    <span>@string.Format(Localizer["TeamDetail_Members"].Value, Model.Members.Count)</span>
                    @if (Model.CanCurrentUserManage)
                    {
                        <a asp-controller="TeamAdmin" asp-action="Members" asp-route-slug="@Model.Slug" class="btn btn-sm btn-outline-primary">
                            @Localizer["TeamDetail_ManageMembers"]
                        </a>
                    }
                }
                else
                {
                    <span>@Localizer["TeamDetail_TeamCoordinators"]</span>
                }
            </div>
            <div class="card-body">
                @if (Model.Members.Any())
                {
                    var coordinators = Model.Members.Where(m => m.IsCoordinator).ToList();
                    var regularMembers = Model.Members.Where(m => !m.IsCoordinator).ToList();

                    @if (coordinators.Any())
                    {
                        @if (Model.IsAuthenticated)
                        {
                            <h6 class="text-muted mb-3">@Localizer["TeamDetail_TeamCoordinators"]</h6>
                        }
                        <div class="row g-3 mb-4">
                            @foreach (var member in coordinators)
                            {
                                <div class="col-6 col-sm-4 col-md-3">
                                    @if (Model.IsAuthenticated)
                                    {
                                        <vc:human user-id="@member.UserId"
                                                  layout="Card" size="128"
                                                  css-class="border border-primary border-3"
                                                  bg-color="bg-primary" />
                                    }
                                    else
                                    {
                                        <vc:human user-id="@member.UserId"
                                                  layout="Card" size="128"
                                                  link="None"
                                                  popover-public="true"
                                                  css-class="border border-primary border-3"
                                                  bg-color="bg-primary" />
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (Model.IsAuthenticated && regularMembers.Any())
                    {
                        @if (coordinators.Any())
                        {
                            <h6 class="text-muted mb-3">@Localizer["Teams_Member"]</h6>
                        }
                        <div class="row g-3">
                            @foreach (var member in regularMembers)
                            {
                                <div class="col-6 col-sm-4 col-md-3">
                                    <vc:human user-id="@member.UserId" layout="Card" size="102" />
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <p class="text-center text-muted mb-0">@Localizer["TeamDetail_NoMembers"]</p>
                }
            </div>
        </div>
        }

        @if (Model.IsAuthenticated && Model.SubteamLeads.Any())
        {
        <div class="card mb-4">
            <div class="card-header">
                <span>Subteam Leads (@Model.SubteamLeads.Count)</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var lead in Model.SubteamLeads)
                    {
                        <div class="col-6 col-sm-4 col-md-3">
                            <vc:human user-id="@lead.UserId"
                                      layout="Card" size="128"
                                      css-class="border border-primary border-3"
                                      bg-color="bg-primary" />
                            <div class="text-center small mt-1">
                                <span class="badge bg-primary">@(lead.RoleTitle ?? "Coordinator")</span>
                                <span class="badge bg-secondary bg-opacity-50">@lead.ChildTeamName</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        }

        @if (Model.IsAuthenticated && Model.ChildTeamMembers.Any())
        {
        <div class="card mb-4">
            <div class="card-header">
                <span>@Localizer["TeamDetail_ChildTeamMembers", Model.ChildTeamMembers.Count]</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var member in Model.ChildTeamMembers)
                    {
                        <div class="col-6 col-sm-4 col-md-3">
                            <vc:human user-id="@member.UserId" layout="Card" size="102" />
                            <div class="text-center small mt-1">
                                <span class="badge bg-secondary bg-opacity-50">@member.ChildTeamName</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        }
    </div>

    <div class="col-md-4">
        @if (Model.IsAuthenticated)
        {
            <div class="card mb-4">
                <div class="card-header">@Localizer["TeamDetail_Actions"]</div>
                <div class="card-body">
                    @if (Model.CanCurrentUserJoin)
                    {
                        <a asp-action="Join" asp-route-slug="@Model.Slug" class="btn btn-primary w-100 mb-2">
                            @if (Model.RequiresApproval)
                            {
                                <span>@Localizer["TeamDetail_RequestToJoin"]</span>
                            }
                            else
                            {
                                <span>@Localizer["TeamDetail_JoinTeam"]</span>
                            }
                        </a>
                    }
                    else if (Model.CurrentUserPendingRequestId.HasValue)
                    {
                        <div class="alert alert-info mb-2">
                            @Localizer["TeamDetail_PendingApproval"]
                        </div>
                        <form asp-action="WithdrawRequest" asp-route-id="@Model.CurrentUserPendingRequestId" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger w-100" data-confirm="@Localizer["TeamDetail_WithdrawConfirm"].Value">
                                @Localizer["TeamDetail_WithdrawRequest"]
                            </button>
                        </form>
                    }
                    else if (Model.CanCurrentUserLeave)
                    {
                        <form asp-action="Leave" asp-route-slug="@Model.Slug" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger w-100" data-confirm="@Localizer["TeamDetail_LeaveConfirm"].Value">
                                @Localizer["TeamDetail_LeaveTeam"]
                            </button>
                        </form>
                    }
                    else if (Model.IsCurrentUserMember && Model.IsSystemTeam)
                    {
                        <div class="alert alert-secondary mb-0">
                            @Localizer["TeamDetail_SystemMembership"]
                        </div>
                    }

                    <a asp-controller="Calendar" asp-action="Team" asp-route-teamId="@Model.Id" class="btn btn-outline-secondary w-100 mt-2">
                        Team calendar
                    </a>

                    @if (Model.CanOpenStore)
                    {
                        <a asp-controller="Store" asp-action="Index" class="btn btn-outline-primary w-100 mt-2">
                            <i class="fa-solid fa-cart-shopping me-1"></i> Open store
                        </a>
                    }
                </div>
            </div>
        }

        @if (Model.IsAuthenticated && Model.Resources.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <span>@Localizer["TeamDetail_Resources"]</span>
                </div>
                <div class="list-group list-group-flush">
                    @foreach (var resource in Model.Resources)
                    {
                        @if (!string.IsNullOrEmpty(resource.Url))
                        {
                            <a href="@resource.Url" target="_blank" rel="noopener noreferrer" class="list-group-item list-group-item-action">
                                <i class="@resource.IconClass me-1"></i> @resource.Name
                            </a>
                        }
                        else
                        {
                            <span class="list-group-item text-muted">
                                <i class="@resource.IconClass me-1"></i> @resource.Name
                            </span>
                        }
                    }
                </div>
            </div>
        }

        @if (Model.IsAuthenticated && Model.ShiftsSummary != null)
        {
            @await Html.PartialAsync("_ShiftsSummaryCard", Model.ShiftsSummary)
        }

        @if (Model.CanCurrentUserManage)
        {
            <div class="card mb-4">
                <div class="card-header">@Localizer["TeamDetail_TeamManagement"]</div>
                <div class="list-group list-group-flush">
                    @if (Model.CanCurrentUserEditTeam)
                    {
                        <a asp-controller="Team" asp-action="EditTeam" asp-route-id="@Model.Id" class="list-group-item list-group-item-action">
                            @Localizer["TeamDetail_EditTeam"]
                        </a>
                    }
                    <a asp-controller="TeamAdmin" asp-action="EditPage" asp-route-slug="@Model.Slug" class="list-group-item list-group-item-action">
                        @Localizer["TeamDetail_EditPage"]
                    </a>
                    <a asp-controller="TeamAdmin" asp-action="Members" asp-route-slug="@Model.Slug" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        @Localizer["TeamDetail_ManageMembers"]
                        @if (Model.PendingRequestCount > 0)
                        {
                            <span class="badge bg-warning">@Model.PendingRequestCount</span>
                        }
                    </a>
                    <a asp-controller="TeamAdmin" asp-action="Roles" asp-route-slug="@Model.Slug" class="list-group-item list-group-item-action">
                        @Localizer["TeamDetail_ManageRoles"]
                    </a>
                    @if (Model.CanCurrentUserEditTeam)
                    {
                        <a asp-controller="TeamAdmin" asp-action="Resources" asp-route-slug="@Model.Slug" class="list-group-item list-group-item-action">
                            @Localizer["TeamDetail_ManageResources"]
                        </a>
                        <a asp-controller="AdminLegalDocuments" asp-action="LegalDocuments" asp-route-teamId="@Model.Id" class="list-group-item list-group-item-action">
                            @Localizer["TeamDetail_ManageConsents"]
                        </a>
                    }
                </div>
            </div>
        }

        @if (Model.ChildTeams.Any())
        {
            <div class="card mb-4">
                <div class="card-header">@Localizer["TeamDetail_SubTeams"]</div>
                <div class="list-group list-group-flush">
                    @foreach (var child in Model.ChildTeams)
                    {
                        <a asp-action="Details" asp-route-slug="@child.Slug" class="list-group-item list-group-item-action">
                            @child.Name
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>
