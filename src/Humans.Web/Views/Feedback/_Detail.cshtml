@model Humans.Web.Models.FeedbackDetailViewModel

<!-- Report header -->
<div class="border-bottom pb-3 mb-3">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h5 class="mb-1">@Model.Category on @(Model.PageUrl.Length > 40 ? Model.PageUrl[..40] + "..." : Model.PageUrl)</h5>
            <div class="text-muted small">
                @if (Model.IsAdmin)
                {
                    <vc:human user-id="@Model.ReporterUserId" link="Admin" />
                }
                else
                {
                    @Model.ReporterName
                }
                · @Model.CreatedAt.ToString("MMM dd, HH:mm") ·
                <span class="text-muted">@Model.PageUrl</span>
            </div>
        </div>

        @if (Model.IsAdmin)
        {
            <div class="d-flex gap-2 align-items-center">
                <i class="fa-solid fa-lock auth-lock-icon" title="Admin only"></i>
                <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <select name="Status" class="form-select form-select-sm detail-auto-submit" style="width: auto;">
                        @foreach (var s in Enum.GetValues<FeedbackStatus>())
                        {
                            if (Model.Status == s)
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                </form>
                <form asp-action="SetGitHubIssue" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <div class="input-group input-group-sm" style="width: 120px;">
                        <span class="input-group-text">GH #</span>
                        <input type="number" name="IssueNumber" value="@Model.GitHubIssueNumber"
                               class="form-control form-control-sm detail-auto-submit" placeholder="#">
                    </div>
                </form>
            </div>
        }
    </div>

    @if (Model.IsAdmin)
    {
        <div class="mt-2 d-flex gap-2 align-items-center flex-wrap">
            <form asp-action="UpdateAssignment" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="AssignedToTeamId" value="@Model.AssignedToTeamId" />
                <div class="input-group input-group-sm" style="width: auto;">
                    <span class="input-group-text"><i class="fa-solid fa-user fa-xs"></i></span>
                    <select name="AssignedToUserId" class="form-select form-select-sm detail-auto-submit" style="width: auto; min-width: 160px;">
                        <option value="">@Localizer["Feedback_Unassigned"]</option>
                        @foreach (var a in Model.AssigneeOptions)
                        {
                            if (Model.AssignedToUserId == a.Id)
                            {
                                <option value="@a.Id" selected>@a.DisplayName</option>
                            }
                            else
                            {
                                <option value="@a.Id">@a.DisplayName</option>
                            }
                        }
                    </select>
                </div>
            </form>
            <form asp-action="UpdateAssignment" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="AssignedToUserId" value="@Model.AssignedToUserId" />
                <div class="input-group input-group-sm" style="width: auto;">
                    <span class="input-group-text"><i class="fa-solid fa-users fa-xs"></i></span>
                    <select name="AssignedToTeamId" class="form-select form-select-sm detail-auto-submit" style="width: auto; min-width: 160px;">
                        <option value="">@Localizer["Feedback_NoTeam"]</option>
                        @foreach (var t in Model.TeamOptions)
                        {
                            var label = t.IsActive ? t.Name : $"{t.Name} (inactive)";
                            if (Model.AssignedToTeamId == t.Id)
                            {
                                <option value="@t.Id" selected>@label</option>
                            }
                            else
                            {
                                <option value="@t.Id">@label</option>
                            }
                        }
                    </select>
                </div>
            </form>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.UserAgent) || !string.IsNullOrEmpty(Model.AdditionalContext))
    {
        <div class="text-muted mt-2" style="font-size: 0.75rem;">
            @if (!string.IsNullOrEmpty(Model.UserAgent))
            {
                <span>@Model.UserAgent</span>
            }
            @if (!string.IsNullOrEmpty(Model.AdditionalContext))
            {
                <span> · <em>@Model.AdditionalContext</em></span>
            }
        </div>
    }
</div>

<!-- Description -->
<div class="card mb-3">
    <div class="card-body">
        <p class="mb-0" style="white-space: pre-wrap;">@Model.Description</p>
    </div>
</div>

@if (Model.ScreenshotUrl is not null)
{
    <div class="mb-3">
        <a href="@Model.ScreenshotUrl" target="_blank" class="text-muted small">
            <i class="fa-solid fa-paperclip"></i> @Localizer["Feedback_ScreenshotLink"]
        </a>
    </div>
}

<!-- Conversation -->
<h6 class="text-muted text-uppercase mb-3" style="font-size: 0.75rem; letter-spacing: 0.05em;">@Localizer["Feedback_Conversation"]</h6>

@if (Model.Messages.Count == 0)
{
    <p class="text-muted small">@Localizer["Feedback_NoMessages"]</p>
}

@foreach (var msg in Model.Messages)
{
    var borderClass = msg.IsReporter ? "border-primary" : "border-success";
    <div class="mb-3">
        <div class="text-muted mb-1" style="font-size: 0.75rem;">
            <strong>@msg.SenderName</strong> · @msg.CreatedAt.ToString("MMM dd, HH:mm")
        </div>
        <div class="p-2 rounded border-start border-3 @borderClass bg-body-tertiary" style="white-space: pre-wrap;">@msg.Content</div>
    </div>
}

<!-- Reply form -->
<form asp-action="PostMessage" asp-route-id="@Model.Id" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <div class="d-flex gap-2">
        <textarea name="Content" class="form-control form-control-sm" rows="2"
                  placeholder="@Localizer["Feedback_MessagePlaceholder"].Value" required maxlength="5000"></textarea>
        <button type="submit" class="btn btn-primary btn-sm align-self-end">@Localizer["Feedback_Send"]</button>
    </div>
</form>

@if (Model.ResolvedAt.HasValue)
{
    <div class="text-muted small mt-3">
        @Html.Raw(string.Format(Localizer["Feedback_ResolvedAt"].Value, Html.Encode(Model.ResolvedAt.Value.ToString("MMM dd, HH:mm"))))
        @if (!string.IsNullOrEmpty(Model.ResolvedByName))
        {
            <text> @Html.Raw(string.Format(Localizer["Feedback_ResolvedBy"].Value, Html.Encode(Model.ResolvedByName)))</text>
        }
    </div>
}
