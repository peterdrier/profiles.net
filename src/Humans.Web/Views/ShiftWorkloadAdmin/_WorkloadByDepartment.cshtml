@using Humans.Application.DTOs.Shifts.Workload
@model IReadOnlyList<WorkloadByDepartmentRow>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No departments own rotas or roles in this event.</div>
    return;
}

<div class="table-responsive">
    <table class="table table-sm table-striped table-hover workload-table">
        <thead>
            <tr>
                <th data-sort>Department</th>
                <th data-sort class="text-end">Rotas</th>
                <th data-sort class="text-end">Shifts</th>
                <th data-sort class="text-end">Planned slots</th>
                <th data-sort class="text-end">Filled slots</th>
                <th data-sort class="text-end">Coverage</th>
                <th data-sort class="text-end">Planned hours</th>
                <th data-sort class="text-end">Filled hours</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model)
            {
                var pct = row.PlannedSlots > 0
                    ? (decimal)row.FilledSlots * 100m / row.PlannedSlots
                    : 0m;
                <tr>
                    <td data-value="@row.TeamName">
                        @if (!string.IsNullOrEmpty(row.TeamSlug))
                        {
                            <a asp-controller="ShiftAdmin" asp-action="Index" asp-route-slug="@row.TeamSlug">@row.TeamName</a>
                        }
                        else
                        {
                            @row.TeamName
                        }
                    </td>
                    <td class="text-end" data-value="@row.RotaCount">@row.RotaCount</td>
                    <td class="text-end" data-value="@row.ShiftCount">@row.ShiftCount</td>
                    <td class="text-end" data-value="@row.PlannedSlots">@row.PlannedSlots</td>
                    <td class="text-end" data-value="@row.FilledSlots">@row.FilledSlots</td>
                    <td class="text-end" data-value="@pct.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)">@pct.ToString("0.0")%</td>
                    <td class="text-end" data-value="@row.PlannedHours.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)">@row.PlannedHours.ToString("0.##")</td>
                    <td class="text-end" data-value="@row.FilledHours.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)">@row.FilledHours.ToString("0.##")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
