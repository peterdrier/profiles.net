<script>
    document.getElementById('checkForm').addEventListener('submit', function (e) {
        if (!confirm('This will check Drive Activity API for anomalous permission changes. Continue?')) {
            e.preventDefault();
            return;
        }
        var btn = document.getElementById('checkBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Checking\u2026';
    });
</script>
