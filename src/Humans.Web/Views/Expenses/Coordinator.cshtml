@model Humans.Web.Models.ExpenseCoordinatorViewModel
@using Humans.Domain.Enums
@{
    ViewData["Title"] = "Expense Reports — Coordinator Queue";
    var badgeClass = (ExpenseReportStatus s) => s switch
    {
        ExpenseReportStatus.Submitted => "bg-primary",
        _ => "bg-secondary"
    };
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item active" aria-current="page">Coordinator Queue</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Coordinator Queue</h1>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Reports.Any())
{
    <div class="alert alert-info">
        <i class="fa-solid fa-inbox me-2"></i>No reports awaiting your endorsement.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Report</th>
                    <th>Submitted by</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Submitted</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Reports)
                {
                    <tr>
                        <td>
                            <a asp-action="Detail" asp-route-id="@r.Id">
                                @r.Id.ToString()[..8]…
                            </a>
                        </td>
                        <td>@(Model.SubmitterNames.TryGetValue(r.SubmitterUserId, out var name) ? name : "(unknown)")</td>
                        <td>€@r.Total.ToString("N2")</td>
                        <td>
                            <span class="badge @badgeClass(r.Status)">@r.Status</span>
                        </td>
                        <td>
                            @if (r.SubmittedAt.HasValue)
                            {
                                @r.SubmittedAt.Value.ToDisplayDate()
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-end">
                                <a asp-action="Detail" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="fa-solid fa-eye me-1"></i>View
                                </a>
                                @if (r.Status == ExpenseReportStatus.Submitted)
                                {
                                    <form asp-action="Endorse" asp-route-id="@r.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success"
                                                data-confirm="Endorse this expense report?">
                                            <i class="fa-solid fa-check me-1"></i>Endorse
                                        </button>
                                    </form>

                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#rejectModal-@r.Id">
                                        <i class="fa-solid fa-xmark me-1"></i>Reject
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Coordinator rejection modals *@
    @foreach (var r in Model.Reports.Where(x => x.Status == ExpenseReportStatus.Submitted))
    {
        <div class="modal fade" id="rejectModal-@r.Id" tabindex="-1"
             aria-labelledby="rejectModalLabel-@r.Id" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form asp-action="CoordinatorReject" asp-route-id="@r.Id" method="post">
                        @Html.AntiForgeryToken()
                        <div class="modal-header">
                            <h5 class="modal-title" id="rejectModalLabel-@r.Id">Reject Report</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p class="text-muted">
                                The submitter will see this reason. Explain clearly why the report cannot be endorsed.
                            </p>
                            <div class="mb-3">
                                <label for="reason-@r.Id" class="form-label fw-semibold">Rejection reason <span class="text-danger">*</span></label>
                                <textarea class="form-control" id="reason-@r.Id" name="Reason"
                                          rows="3" maxlength="1000" required
                                          placeholder="e.g. Missing receipts for line 2"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-danger">Reject</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}
