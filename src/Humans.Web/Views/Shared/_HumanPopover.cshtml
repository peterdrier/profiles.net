@model Humans.Web.Models.ProfileSummaryViewModel
@using Humans.Web.Authorization
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthService
@{
    var canSeeHiddenTeams =
        (await AuthService.AuthorizeAsync(User, PolicyNames.TeamsAdminBoardOrAdmin)).Succeeded;
    IReadOnlyList<string> visibleHiddenTeams =
        canSeeHiddenTeams ? Model.HiddenTeams : [];
}

<div class="d-flex align-items-center" style="min-width: 200px;">
    <vc:human user-id="@Model.UserId" layout="Avatar" size="72" css-class="me-2" link="None" />
    <div>
        <div class="fw-semibold">
            @Model.DisplayName
            @if ((await AuthService.AuthorizeAsync(User, PolicyNames.HumanAdminBoardOrAdmin)).Succeeded
                && !string.IsNullOrEmpty(Model.PreferredLanguage?.ToFlagClass()))
            {
                <span class="@Model.PreferredLanguage.ToFlagClass() ms-1" title="@Model.PreferredLanguage.ToDisplayLanguageName()"></span>
            }
        </div>
        @if (!Model.HasProfile)
        {
            <span class="badge bg-secondary" style="font-size: 0.7rem;" title="This human exists in the system but has not completed a profile (e.g. imported from a mailing list or ticketing).">Imported · no profile yet</span>
        }
        else if (Model.IsSuspended)
        {
            <span class="badge bg-danger" style="font-size: 0.7rem;">Suspended</span>
        }
        else if (!string.IsNullOrEmpty(Model.MembershipTier)
            && !string.Equals(Model.MembershipTier, "Volunteer", StringComparison.OrdinalIgnoreCase))
        {
            <span class="badge bg-success" style="font-size: 0.7rem;">@Model.MembershipTier</span>
        }
        @if (!Model.HasProfile && !string.IsNullOrEmpty(Model.Email))
        {
            <div class="text-muted small text-break">
                <i class="fa-solid fa-envelope me-1"></i>@Model.Email
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.City) || !string.IsNullOrEmpty(Model.CountryCode))
        {
            <div class="text-muted small">
                <i class="fa-solid fa-location-dot me-1"></i>@(string.Join(", ",
                    new[] { Model.City, Model.CountryCode }.Where(s => !string.IsNullOrEmpty(s))))
            </div>
        }
    </div>
</div>
@if (Model.Teams.Count > 0 || visibleHiddenTeams.Count > 0 || Model.Languages.Count > 0)
{
    <div class="mt-2 pt-2 border-top">
        @foreach (var team in Model.Teams)
        {
            <span class="badge bg-light text-dark border me-1 mb-1" style="font-size: 0.7rem;">@team</span>
        }
        @if (visibleHiddenTeams.Count > 0 && Model.Teams.Count > 0)
        {
            <hr class="my-2" />
        }
        @foreach (var team in visibleHiddenTeams)
        {
            <span class="badge bg-light text-dark border border-warning me-1 mb-1" style="font-size: 0.7rem;"
                  title="Hidden team — admin-only visibility">
                <i class="fa-solid fa-eye-slash me-1 opacity-75"></i>@team
            </span>
        }
        @foreach (var lang in Model.Languages)
        {
            <span class="badge bg-light text-dark border me-1 mb-1" style="font-size: 0.7rem;">
                @lang.LanguageName
                <small class="opacity-75">(@lang.Proficiency)</small>
            </span>
        }
    </div>
}
