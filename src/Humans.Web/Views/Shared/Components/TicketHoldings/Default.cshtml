@model Humans.Web.ViewComponents.TicketHoldingsViewModel
@{
    var voidCount = Model.Tickets.Count(t => t.Status == TicketAttendeeStatus.Void);
    var activeCount = Model.Tickets.Count - voidCount;
}

<div class="card mb-3">
    <div class="card-header py-2">
        <h3 class="h6 mb-0">Tickets</h3>
    </div>
    <div class="card-body py-2 small">
        <div class="d-flex align-items-center mb-2">
            <i class="fa-solid fa-receipt me-2 text-muted"></i>
            <span>@Model.OrderCount @(Model.OrderCount == 1 ? "order" : "orders")</span>
        </div>
        <div class="d-flex align-items-start">
            <i class="fa-solid fa-ticket me-2 mt-1 text-muted"></i>
            <div class="flex-grow-1">
                <div class="mb-1">
                    @activeCount @(activeCount == 1 ? "ticket" : "tickets")
                    @if (voidCount > 0)
                    {
                        <span class="text-muted">(+ @voidCount voided)</span>
                    }
                </div>
                @if (Model.Tickets.Count > 0)
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var t in Model.Tickets)
                        {
                            var isVoid = t.Status == TicketAttendeeStatus.Void;
                            var statusClass = t.Status switch
                            {
                                TicketAttendeeStatus.Valid => "bg-success",
                                TicketAttendeeStatus.CheckedIn => "bg-info",
                                TicketAttendeeStatus.Void => "bg-danger",
                                _ => "bg-secondary"
                            };
                            <li class="@(isVoid ? "text-muted" : null)">
                                <span class="badge @statusClass me-1">@t.Status</span>
                                <span class="@(isVoid ? "text-decoration-line-through" : null)">@t.AttendeeName</span>
                                @if (!string.IsNullOrWhiteSpace(t.TicketTypeName))
                                {
                                    <span class="text-muted">— @t.TicketTypeName</span>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
