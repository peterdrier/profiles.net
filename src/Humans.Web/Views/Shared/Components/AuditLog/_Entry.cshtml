@model Humans.Application.Services.AuditLog.AuditEvent

@{
    var render = Model.RenderStructured();
    var actorIsSubject = Model.ActorUserId.HasValue && Model.SubjectUserId.HasValue
        && Model.ActorUserId.Value == Model.SubjectUserId.Value;
}

<div class="d-flex align-items-baseline gap-1 small flex-wrap">
    <span class="text-muted text-nowrap">@Model.OccurredAt.ToAuditTimestamp()</span>
    <span class="text-muted">—</span>
    @if (render.Verb != null)
    {
        @* Actor *@
        @if (Model.ActorUserId.HasValue)
        {
            <human-link user-id="@Model.ActorUserId.Value" display-name="@(Model.ActorDisplayName ?? "Unknown")" mode="Text" />
        }
        else
        {
            <span class="text-muted">System</span>
        }

        @* When the view will not render a subject (actor==subject or subject unknown),
           use selfVerb if defined, else trim a trailing preposition from the transitive verb. *@
        var noVisibleSubject = actorIsSubject || !Model.SubjectUserId.HasValue;
        var displayVerb = noVisibleSubject && render.SelfVerb != null ? render.SelfVerb
                        : noVisibleSubject ? render.TrimmedVerb
                        : render.Verb;
        <span>@displayVerb</span>

        @* Subject (skip if same as actor) *@
        @if (Model.SubjectUserId.HasValue && !actorIsSubject)
        {
            <human-link user-id="@Model.SubjectUserId.Value" display-name="@(Model.SubjectDisplayName ?? "Unknown")" mode="Text" />
        }

        @* Target team *@
        @if (Model.TargetTeamId.HasValue && !string.IsNullOrEmpty(Model.TargetTeamName))
        {
            <span class="text-muted">in</span>
            <a asp-controller="Team" asp-action="Details" asp-route-slug="@Model.TargetTeamSlug" class="text-decoration-none">@Model.TargetTeamName</a>
        }

        @* Description tail — only for actions whose descriptions are written as tails (e.g. ShiftSignup*).
           Sentence-style descriptions (Team*, Role*, Member*) would render redundantly here. *@
        @if (render.ShouldRenderDescriptionTail)
        {
            <span class="text-muted">— @Model.Description</span>
        }
    }
    else
    {
        @* Unmapped action — render rough but fully attributed: actor · ActionName · subject · in team · "description" *@
        @if (Model.ActorUserId.HasValue)
        {
            <human-link user-id="@Model.ActorUserId.Value" display-name="@(Model.ActorDisplayName ?? "Unknown")" mode="Text" />
        }
        else
        {
            <span class="text-muted">System</span>
        }
        <span class="text-muted">·</span>
        <span>@Model.Action.ToString()</span>
        @if (Model.SubjectUserId.HasValue && !actorIsSubject)
        {
            <span class="text-muted">·</span>
            <human-link user-id="@Model.SubjectUserId.Value" display-name="@(Model.SubjectDisplayName ?? "Unknown")" mode="Text" />
        }
        @if (Model.TargetTeamId.HasValue && !string.IsNullOrEmpty(Model.TargetTeamName))
        {
            <span class="text-muted">in</span>
            <a asp-controller="Team" asp-action="Details" asp-route-slug="@Model.TargetTeamSlug" class="text-decoration-none">@Model.TargetTeamName</a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <span class="text-muted">— @Model.Description</span>
        }
    }
</div>
