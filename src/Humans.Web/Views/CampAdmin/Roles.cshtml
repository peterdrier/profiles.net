@using Humans.Web.Models.CampAdmin
@model CampRoleDefinitionListViewModel
@{
    ViewData["Title"] = "Camp roles";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Camp" asp-action="Index">@Localizer["Camp_Plural"]</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">@Localizer["Camp_AdminTitle"]</a></li>
        <li class="breadcrumb-item active" aria-current="page">Roles</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Camp roles</h1>
        <p class="text-muted mb-0">Global role definitions applied to every barrio.</p>
    </div>
    <a asp-controller="CampAdmin" asp-action="CreateRole" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Add role
    </a>
</div>

<vc:temp-data-alerts />

<div class="card mb-4">
    <div class="card-header">
        <i class="fa-solid fa-circle-check me-2"></i>Active (@Model.Active.Count)
    </div>
    @if (Model.Active.Count == 0)
    {
        <div class="card-body">
            <p class="text-muted mb-0">No active camp roles defined yet. Use <strong>Add role</strong> to create the first one.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Sort</th>
                        <th>Name</th>
                        <th class="text-end">Slots</th>
                        <th class="text-end">Min required</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Active)
                    {
                        <tr>
                            <td>@row.SortOrder</td>
                            <td>
                                <a asp-controller="CampAdmin" asp-action="RolesDrillDown" asp-route-slug="@(string.IsNullOrWhiteSpace(row.Slug) ? row.Id.ToString() : row.Slug)"><strong>@row.Name</strong></a>
                                @if (!string.IsNullOrWhiteSpace(row.GroupEmail))
                                {
                                    <small class="text-muted ms-2"><code>@row.GroupEmail</code></small>
                                }
                                @if (!string.IsNullOrWhiteSpace(row.Description))
                                {
                                    <br />
                                    <small class="text-muted">@Html.SanitizedMarkdown(row.Description)</small>
                                }
                            </td>
                            <td class="text-end">@row.SlotCount</td>
                            <td class="text-end">@row.MinimumRequired</td>
                            <td class="text-end">
                                <a asp-controller="CampAdmin" asp-action="RolesDrillDown" asp-route-slug="@(string.IsNullOrWhiteSpace(row.Slug) ? row.Id.ToString() : row.Slug)" class="btn btn-outline-secondary btn-sm">
                                    <i class="fa-solid fa-table-list me-1"></i>Roster
                                </a>
                                <a asp-controller="CampAdmin" asp-action="EditRole" asp-route-id="@row.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="fa-solid fa-pen-to-square me-1"></i>Edit
                                </a>
                                <form asp-controller="CampAdmin" asp-action="DeactivateRole" asp-route-id="@row.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-warning btn-sm" data-confirm="Deactivate this role? Existing assignments will remain but it will no longer be assignable.">
                                        <i class="fa-solid fa-eye-slash me-1"></i>Deactivate
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.Deactivated.Count > 0)
{
    <div class="card">
        <div class="card-header">
            <i class="fa-solid fa-circle-pause me-2"></i>Deactivated (@Model.Deactivated.Count)
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Sort</th>
                        <th>Name</th>
                        <th class="text-end">Slots</th>
                        <th class="text-end">Min required</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Deactivated)
                    {
                        <tr class="text-muted">
                            <td>@row.SortOrder</td>
                            <td>
                                <strong>@row.Name</strong>
                                @if (!string.IsNullOrWhiteSpace(row.Description))
                                {
                                    <br />
                                    <small class="text-muted">@Html.SanitizedMarkdown(row.Description)</small>
                                }
                            </td>
                            <td class="text-end">@row.SlotCount</td>
                            <td class="text-end">@row.MinimumRequired</td>
                            <td class="text-end">
                                <form asp-controller="CampAdmin" asp-action="ReactivateRole" asp-route-id="@row.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-success btn-sm">
                                        <i class="fa-solid fa-rotate-left me-1"></i>Reactivate
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
