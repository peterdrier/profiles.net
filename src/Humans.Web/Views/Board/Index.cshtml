@model Humans.Web.Models.BoardDashboardViewModel
@{
    ViewData["Title"] = "Board Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Board Dashboard</h1>
    <vc:access-matrix section="Board" />
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-3 mb-4">
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h2 class="card-title mb-0">@Model.TotalMembers</h2>
                <p class="card-text text-muted">Total Humans</p>
            </div>
        </div>
    </div>
    <div class="col">
        <a asp-controller="Profile" asp-action="AdminList" asp-route-filter="active" class="text-decoration-none">
            <div class="card text-center h-100 bg-success text-white">
                <div class="card-body">
                    <h2 class="card-title mb-0">@Model.ActiveMembers</h2>
                    <p class="card-text">Active</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col">
        <a asp-controller="Profile" asp-action="AdminList" asp-route-filter="pending" class="text-decoration-none">
            <div class="card text-center h-100 @(Model.PendingApproval > 0 ? "bg-warning" : "") ">
                <div class="card-body">
                    <h2 class="card-title mb-0 @(Model.PendingApproval > 0 ? "" : "text-warning")">@Model.PendingApproval</h2>
                    <p class="card-text @(Model.PendingApproval > 0 ? "" : "text-muted")">Pending Approval</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col">
        <a asp-controller="Profile" asp-action="AdminList" asp-route-filter="missingconsents" class="text-decoration-none">
            <div class="card text-center h-100 @(Model.MissingConsents > 0 ? "border-warning" : "")">
                <div class="card-body">
                    <h2 class="card-title mb-0" style="color: @(Model.MissingConsents > 0 ? "darkorange" : "inherit")">@Model.MissingConsents</h2>
                    <p class="card-text text-muted">Missing Consents</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col">
        <a asp-controller="Profile" asp-action="AdminList" asp-route-filter="incomplete" class="text-decoration-none">
            <div class="card text-center h-100 bg-secondary text-white">
                <div class="card-body">
                    <h2 class="card-title mb-0">@Model.IncompleteSignup</h2>
                    <p class="card-text">Incomplete Signup</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col">
        <a asp-controller="Profile" asp-action="AdminList" asp-route-filter="suspended" class="text-decoration-none">
            <div class="card text-center h-100 @(Model.Suspended > 0 ? "bg-danger text-white" : "")">
                <div class="card-body">
                    <h2 class="card-title mb-0 @(Model.Suspended > 0 ? "" : "text-danger")">@Model.Suspended</h2>
                    <p class="card-text @(Model.Suspended > 0 ? "" : "text-muted")">Suspended</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col">
        <a asp-controller="Profile" asp-action="AdminList" asp-route-filter="deleting" class="text-decoration-none">
            <div class="card text-center h-100 @(Model.PendingDeletion > 0 ? "bg-dark text-white" : "")">
                <div class="card-body">
                    <h2 class="card-title mb-0 @(Model.PendingDeletion > 0 ? "" : "text-dark")">@Model.PendingDeletion</h2>
                    <p class="card-text @(Model.PendingDeletion > 0 ? "" : "text-muted")">Pending Deletion</p>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>@Localizer["Admin_QuickActions"]</span>
            </div>
            <div class="list-group list-group-flush">
                <a asp-controller="Profile" asp-action="AdminList" asp-route-filter="pending" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    @Localizer["Admin_ReviewPendingVolunteers"]
                    @if (Model.PendingApproval > 0)
                    {
                        <span class="badge bg-warning">@Model.PendingApproval</span>
                    }
                </a>
                <a asp-controller="GovernanceApplications" asp-action="Admin" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    @Localizer["Admin_ReviewApplications"]
                    @if (Model.PendingApplications > 0)
                    {
                        <span class="badge bg-warning">@Model.PendingApplications</span>
                    }
                </a>
                <a asp-controller="Profile" asp-action="AdminList" class="list-group-item list-group-item-action">
                    @Localizer["Admin_ManageMembers"]
                </a>
                <a asp-controller="Governance" asp-action="Roles" class="list-group-item list-group-item-action">
                    @Localizer["Admin_ManageRoles"]
                </a>
                <a asp-controller="AdminLegalDocuments" asp-action="LegalDocuments" class="list-group-item list-group-item-action">
                    Legal Documents
                </a>
                <a asp-action="AuditLog" class="list-group-item list-group-item-action">
                    Audit Log
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        @if (Model.TotalApplications > 0)
        {
            <div class="card mt-3">
                <div class="card-header">@Localizer["Admin_ApplicationStats"]</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-7">@Localizer["Admin_StatsTotal"]</dt>
                        <dd class="col-5 text-end mb-2">@Model.TotalApplications</dd>
                        <dt class="col-7">@Localizer["Admin_StatsApproved"]</dt>
                        <dd class="col-5 text-end mb-2">@Model.ApprovedApplications</dd>
                        <dt class="col-7">@Localizer["Admin_StatsRejected"]</dt>
                        <dd class="col-5 text-end mb-2">@Model.RejectedApplications</dd>
                        <dt class="col-7">@Localizer["Admin_StatsPending"]</dt>
                        <dd class="col-5 text-end mb-2">@(Model.TotalApplications - Model.ApprovedApplications - Model.RejectedApplications)</dd>
                    </dl>
                    <hr class="my-2" />
                    <dl class="row mb-0">
                        <dt class="col-7">Colaborador</dt>
                        <dd class="col-5 text-end mb-2">@Model.ColaboradorApplied</dd>
                        <dt class="col-7">Asociado</dt>
                        <dd class="col-5 text-end mb-2">@Model.AsociadoApplied</dd>
                    </dl>
                </div>
            </div>
        }

        @if (Model.LanguageDistribution.Count > 0)
        {
            var totalActive = Model.LanguageDistribution.Sum(l => l.Count);
            var barColors = new[] { "bg-primary", "bg-success", "bg-info", "bg-warning", "bg-secondary" };
            <div class="card mt-3">
                <div class="card-header"><h6 class="mb-0">Preferred Language</h6></div>
                <div class="card-body">
                    @for (var i = 0; i < Model.LanguageDistribution.Count; i++)
                    {
                        var lang = Model.LanguageDistribution[i];
                        var percentage = totalActive > 0 ? (int)(100.0 * lang.Count / totalActive) : 0;
                        var label = lang.Language.ToDisplayLanguageName();
                        var color = barColors[i % barColors.Length];
                        <div class="d-flex align-items-center mb-2">
                            <span class="me-2" style="min-width: 70px;">@label</span>
                            <div class="flex-grow-1">
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar @color" style="width: @percentage%;">@lang.Count</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">@Localizer["Admin_RecentActivity"]</div>
            <div class="card-body">
                @if (Model.RecentActivity.Count == 0)
                {
                    <p class="text-muted mb-0">@Localizer["Admin_NoRecentActivity"]</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var activity in Model.RecentActivity)
                        {
                            <li class="mb-2 d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="badge bg-secondary me-2">@activity.Type</span>
                                    @activity.Description
                                </div>
                                <small class="text-muted text-nowrap ms-3">@activity.Timestamp.ToDisplayGeneralDateTime()</small>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
