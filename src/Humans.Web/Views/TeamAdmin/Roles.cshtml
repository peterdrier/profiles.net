@model Humans.Web.Models.RoleManagementViewModel
@{
    ViewData["Title"] = $"Manage Roles - {Model.TeamName}";
    var priorityOptions = new[] { "None", "Critical", "Important", "NiceToHave" };
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Team" asp-action="Index">@Localizer["Teams_Title"]</a></li>
        <li class="breadcrumb-item"><a asp-controller="Team" asp-action="Details" asp-route-slug="@Model.Slug">@Model.TeamName</a></li>
        <li class="breadcrumb-item active" aria-current="page">Roles</li>
    </ol>
</nav>

<h1>Manage Roles</h1>
<p class="text-muted">@Localizer["MyTeams_Team"]: @Model.TeamName</p>

<vc:temp-data-alerts />

@if (Model.RoleDefinitions.Any())
{
    @foreach (var role in Model.RoleDefinitions)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0 d-inline">@role.Name</h5>
                    @if (role.Period != RolePeriod.YearRound)
                    {
                        var rpBadge = role.Period switch
                        {
                            RolePeriod.Build => "bg-info",
                            RolePeriod.Event => "bg-success",
                            RolePeriod.Strike => "bg-secondary",
                            _ => "bg-light text-dark"
                        };
                        <span class="badge @rpBadge ms-2">@role.Period</span>
                    }
                    @if (!role.IsPublic)
                    {
                        <span class="badge bg-secondary ms-1"><i class="fa-solid fa-eye-slash me-1"></i>Hidden</span>
                    }
                    @if (role.IsManagement)
                    {
                        <span class="badge bg-warning text-dark ms-1">Management</span>
                    }
                </div>
                @if (!role.IsManagement)
                {
                    <form asp-controller="TeamAdmin" asp-action="DeleteRole" asp-route-slug="@Model.Slug" asp-route-roleId="@role.Id" method="post"
                          class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                data-confirm="Are you sure you want to delete this role? All assignments will be removed.">Delete</button>
                    </form>
                }
            </div>
            <div class="card-body">
                <form asp-controller="TeamAdmin" asp-action="EditRole" asp-route-slug="@Model.Slug" asp-route-roleId="@role.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" name="Name" value="@role.Name" required />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Slot Count</label>
                            <input type="number" class="form-control slot-count-input" name="SlotCount" value="@role.SlotCount" min="1" required
                                   data-role-id="@role.Id" />
                        </div>
                        <div class="col-md-1">
                            <label class="form-label">Sort</label>
                            <input type="number" class="form-control" name="SortOrder" value="@role.SortOrder" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Period</label>
                            <select name="Period" class="form-select">
                                <option value="YearRound" selected="@(role.Period == RolePeriod.YearRound ? "selected" : null)">Year-round</option>
                                <option value="Build" selected="@(role.Period == RolePeriod.Build ? "selected" : null)">Set-up</option>
                                <option value="Event" selected="@(role.Period == RolePeriod.Event ? "selected" : null)">Event</option>
                                <option value="Strike" selected="@(role.Period == RolePeriod.Strike ? "selected" : null)">Strike</option>
                            </select>
                        </div>
                        <div class="col-md-1 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Slot Priorities</label>
                        <div class="d-flex flex-wrap gap-2 priorities-container" data-role-id="@role.Id">
                            @for (var i = 0; i < role.SlotCount; i++)
                            {
                                var currentPriority = i < role.Slots.Count ? role.Slots[i].Priority.ToString() : "None";
                                <div class="input-group input-group-sm" style="max-width: 200px;">
                                    <span class="input-group-text">@(i + 1)</span>
                                    <select name="Priorities" class="form-select form-select-sm">
                                        @foreach (var opt in priorityOptions)
                                        {
                                            <option value="@opt" selected="@(string.Equals(opt, currentPriority, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                                                @(opt == "NiceToHave" ? "Nice to Have" : opt)
                                            </option>
                                        }
                                    </select>
                                </div>
                            }
                        </div>
                    </div>
                    @{
                        var hasAssignments = role.Slots.Any(s => s.IsFilled);
                    }
                    <div class="mb-3 form-check">
                        @if (!Model.CanToggleManagement || (role.IsManagement && hasAssignments))
                        {
                            <input type="hidden" name="IsManagement" value="@(role.IsManagement ? "true" : "false")" />
                            @if (role.IsManagement)
                            {
                                <input type="checkbox" class="form-check-input" id="isManagement-@role.Id" checked disabled />
                            }
                            else
                            {
                                <input type="checkbox" class="form-check-input" id="isManagement-@role.Id" disabled />
                            }
                        }
                        else
                        {
                            <input type="checkbox" class="form-check-input" id="isManagement-@role.Id"
                                   name="IsManagement" value="true" @(role.IsManagement ? "checked" : null) />
                        }
                        <label class="form-check-label" for="isManagement-@role.Id">
                            @(Model.IsChildTeam ? "Manager role" : "Coordinator role")
                        </label>
                        @if (!Model.CanToggleManagement)
                        {
                            <div class="form-text text-muted">Only TeamsAdmin or Admin can change this setting.</div>
                        }
                        else if (role.IsManagement && hasAssignments)
                        {
                            <div class="form-text text-warning">Unassign all humans before unchecking.</div>
                        }
                        else if (Model.IsChildTeam)
                        {
                            <div class="form-text">Humans assigned to this role can manage this sub-team's members, roles, and shifts.</div>
                        }
                        else
                        {
                            <div class="form-text">Humans assigned to this role automatically become Coordinators.</div>
                        }
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="isPublic-@role.Id"
                               name="IsPublic" value="true" @(role.IsPublic ? "checked" : null) />
                        <input type="hidden" name="IsPublic" value="false" />
                        <label class="form-check-label" for="isPublic-@role.Id">Visible to volunteers</label>
                        <div class="form-text">When unchecked, this role is hidden from volunteer-facing views.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="Description" rows="3" maxlength="2000">@role.Description</textarea>
                        <div class="form-text">
                            <a href="#" data-bs-toggle="modal" data-bs-target="#markdownHelpModal">
                                <i class="fa-solid fa-circle-info me-1"></i>Markdown formatting is supported
                            </a>
                        </div>
                    </div>
                </form>

                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Slot</th>
                            <th>Priority</th>
                            <th>Assigned To</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var slot in role.Slots)
                        {
                            <tr>
                                <td>@(slot.SlotIndex + 1)</td>
                                <td><span class="badge @slot.PriorityBadgeClass">@(slot.Priority == SlotPriority.NiceToHave ? "Nice to Have" : slot.Priority.ToString())</span></td>
                                <td>
                                    @if (slot.IsFilled && slot.AssignedUserId.HasValue)
                                    {
                                        <vc:human user-id="@slot.AssignedUserId.Value" />
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Open</span>
                                    }
                                </td>
                                <td>
                                    @if (slot.IsFilled)
                                    {
                                        <form asp-controller="TeamAdmin" asp-action="UnassignRole" asp-route-slug="@Model.Slug"
                                              asp-route-roleId="@role.Id" asp-route-memberId="@slot.TeamMemberId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-warning">Unassign</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-controller="TeamAdmin" asp-action="AssignRole" asp-route-slug="@Model.Slug"
                                              asp-route-roleId="@role.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <div class="input-group input-group-sm" style="max-width: 300px; display: inline-flex !important;">
                                                <select name="UserId" class="form-select form-select-sm" required>
                                                    <option value="">Select human...</option>
                                                    @foreach (var member in Model.MemberOptions.Where(m => !role.AssignedUserIds.Contains(m.UserId)))
                                                    {
                                                        <option value="@member.UserId">@member.BurnerName</option>
                                                    }
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Assign</button>
                                            </div>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-info">No roles defined for this team yet.</div>
}

<div class="card mb-4">
    <div class="card-header">Add New Role</div>
    <div class="card-body">
        <form asp-controller="TeamAdmin" asp-action="CreateRole" asp-route-slug="@Model.Slug" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" name="Name" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Slot Count</label>
                    <input type="number" class="form-control slot-count-input" name="SlotCount" value="1" min="1" required
                           data-role-id="new" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">Sort</label>
                    <input type="number" class="form-control" name="SortOrder" value="0" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Period</label>
                    <select name="Period" class="form-select">
                        <option value="YearRound" selected>Year-round</option>
                        <option value="Build">Set-up</option>
                        <option value="Event">Event</option>
                        <option value="Strike">Strike</option>
                    </select>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-success">Add</button>
                </div>
            </div>
            <div class="mt-2">
                <label class="form-label">Slot Priorities</label>
                <div class="d-flex flex-wrap gap-2 priorities-container" data-role-id="new">
                    <div class="input-group input-group-sm" style="max-width: 200px;">
                        <span class="input-group-text">1</span>
                        <select name="Priorities" class="form-select form-select-sm">
                            @foreach (var opt in priorityOptions)
                            {
                                <option value="@opt">@(opt == "NiceToHave" ? "Nice to Have" : opt)</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="mt-2 form-check">
                <input type="checkbox" class="form-check-input" id="isPublic-new"
                       name="IsPublic" value="true" checked />
                <input type="hidden" name="IsPublic" value="false" />
                <label class="form-check-label" for="isPublic-new">Visible to volunteers</label>
                <div class="form-text">When unchecked, this role is hidden from volunteer-facing views.</div>
            </div>
            <div class="mt-2">
                <label class="form-label">Description</label>
                <textarea class="form-control" name="Description" rows="3" maxlength="2000"></textarea>
                <div class="form-text">
                    <a href="#" data-bs-toggle="modal" data-bs-target="#markdownHelpModal">
                        <i class="fa-solid fa-circle-info me-1"></i>Markdown formatting is supported
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Team" asp-action="Details" asp-route-slug="@Model.Slug" class="btn btn-outline-secondary">@Localizer["TeamAdmin_BackToTeam"]</a>
    <a asp-controller="TeamAdmin" asp-action="Members" asp-route-slug="@Model.Slug" class="btn btn-outline-primary">@Localizer["TeamAdmin_ManageMembers"]</a>
</div>

<partial name="_MarkdownHelp" />

@section Scripts {
<script>
document.querySelectorAll('.slot-count-input').forEach(function(input) {
    input.addEventListener('change', function() {
        var roleId = this.dataset.roleId;
        var count = parseInt(this.value) || 1;
        var container = document.querySelector('.priorities-container[data-role-id="' + roleId + '"]');
        if (!container) return;
        var current = container.children.length;
        var options = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(priorityOptions));
        while (container.children.length < count) {
            var idx = container.children.length + 1;
            var div = document.createElement('div');
            div.className = 'input-group input-group-sm';
            div.style.maxWidth = '200px';
            var span = document.createElement('span');
            span.className = 'input-group-text';
            span.textContent = idx;
            var sel = document.createElement('select');
            sel.name = 'Priorities';
            sel.className = 'form-select form-select-sm';
            options.forEach(function(o) {
                var opt = document.createElement('option');
                opt.value = o;
                opt.textContent = o === 'NiceToHave' ? 'Nice to Have' : o;
                sel.appendChild(opt);
            });
            div.appendChild(span);
            div.appendChild(sel);
            container.appendChild(div);
        }
        while (container.children.length > count) {
            container.removeChild(container.lastChild);
        }
    });
});

// Dirty-state tracking for role edit forms
document.querySelectorAll('form[action*="/Edit"]').forEach(function(form) {
    var card = form.closest('.card');
    var saveBtn = form.querySelector('button[type="submit"]');
    var unsavedBadge = null;

    function markDirty() {
        if (unsavedBadge) return;
        if (!card) return;
        card.classList.add('border-warning');
        unsavedBadge = document.createElement('span');
        unsavedBadge.className = 'badge bg-warning text-dark ms-2 unsaved-badge';
        unsavedBadge.textContent = 'Unsaved';
        var header = card.querySelector('.card-header h5');
        if (header) header.appendChild(unsavedBadge);
    }

    function clearDirty() {
        if (card) card.classList.remove('border-warning');
        if (unsavedBadge) { unsavedBadge.remove(); unsavedBadge = null; }
    }

    form.addEventListener('input', markDirty);
    form.addEventListener('change', markDirty);

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (saveBtn) saveBtn.disabled = true;
        var formData = new FormData(form);
        fetch(form.action, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: formData
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                clearDirty();
                showToast(data.message, 'success');
            } else {
                showToast(data.message || 'Save failed.', 'danger');
            }
        })
        .catch(function() {
            showToast('Save failed. Please try again.', 'danger');
        })
        .finally(function() {
            if (saveBtn) saveBtn.disabled = false;
        });
    });
});
</script>
}
