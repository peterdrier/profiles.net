@model Humans.Web.Models.GovernanceIndexViewModel
@{
    ViewData["Title"] = Localizer["Governance_Title"].Value;

    var orderedLanguages = Model.StatutesContent
        .OrderByDisplayLanguage(canonicalFirst: true)
        .ToList();
    var statutesTabs = new TabbedMarkdownDocumentsViewModel
    {
        Documents = orderedLanguages,
        TabsId = "statutesTabs",
        ContentId = "statutesTabsContent",
        DefaultLanguage = Model.StatutesContent.GetDefaultDocumentLanguage(),
        TabsCssClass = "nav nav-tabs px-3 pt-3",
        EmptyMessage = Localizer["ConsentReview_ContentNotAvailable"].Value
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">@Localizer["Governance_Title"]</h1>
    <vc:access-matrix section="Governance" />
</div>

<div class="row mb-4">
    <div class="col-md-8">
        @if (!Model.HasApplication)
        {
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@Localizer["Governance_NotYetApplied"]</h5>
                    <p class="card-text text-muted">
                        @Localizer["Governance_AsociadoDescription"]
                    </p>
                    <p class="card-text text-muted">
                        @Localizer["Governance_Optional"]
                    </p>
                    <a asp-controller="GovernanceApplications" asp-action="Create" class="btn btn-outline-primary">@Localizer["Governance_ApplyButton"]</a>
                </div>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <span>@Localizer["Governance_YourApplication"]</span>
                        @if (Model.ApplicationTier.HasValue)
                        {
                            <span class="badge bg-primary ms-2">@Model.ApplicationTier.Value</span>
                        }
                    </div>
                    <span class="badge @Model.ApplicationStatusBadgeClass">@Localizer["ApplicationStatus_" + Model.ApplicationStatus.ToString()]</span>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        @if (Model.ApplicationTier.HasValue)
                        {
                            <dt class="col-sm-4">@Localizer["Governance_Tier"]</dt>
                            <dd class="col-sm-8">@Model.ApplicationTier.Value</dd>
                        }

                        <dt class="col-sm-4">@Localizer["Governance_Submitted"]</dt>
                        <dd class="col-sm-8">@Model.ApplicationSubmittedAt.ToDisplayLongDate()</dd>

                        @if (Model.ApplicationResolvedAt.HasValue)
                        {
                            <dt class="col-sm-4">@Localizer["Governance_Resolved"]</dt>
                            <dd class="col-sm-8">@Model.ApplicationResolvedAt.ToDisplayLongDate()</dd>
                        }

                        @if (Model.ApplicationStatus == ApplicationStatus.Approved && Model.ApplicationResolvedAt.HasValue)
                        {
                            var resolvedYear = Model.ApplicationResolvedAt.Value.Year;
                            var expiryYear = resolvedYear % 2 == 0 ? resolvedYear + 1 : resolvedYear + 2;
                            <dt class="col-sm-4">@Localizer["Governance_TermExpiry"]</dt>
                            <dd class="col-sm-8">31 December @expiryYear</dd>
                        }
                    </dl>

                    @if (Model.ApplicationStatus == ApplicationStatus.Submitted)
                    {
                        <hr />
                        <p class="text-muted mb-0">@Localizer["Governance_UnderReviewMessage"]</p>
                    }
                    else if (Model.ApplicationStatus == ApplicationStatus.Approved)
                    {
                        <hr />
                        <p class="text-success mb-0">
                            @(Model.ApplicationTier == MembershipTier.Asociado
                                ? Localizer["Governance_ApprovedMessageAsociado"]
                                : Localizer["Governance_ApprovedMessageColaborador"])
                        </p>
                    }
                    else if (Model.ApplicationStatus == ApplicationStatus.Rejected)
                    {
                        <hr />
                        <p class="text-muted mb-0">@Localizer["Governance_RejectedMessage"]</p>
                        @if (Model.CanApply)
                        {
                            <a asp-controller="GovernanceApplications" asp-action="Create" class="btn btn-outline-primary mt-3">@Localizer["Governance_ApplyButton"]</a>
                        }
                    }
                </div>
            </div>
        }

        @if (orderedLanguages.Count > 0)
        {
            <div class="card mt-4">
                <div class="card-header">@Localizer["Governance_Statutes"]</div>
                <div class="card-body p-0">
                    @await Html.PartialAsync("~/Views/Shared/_TabbedMarkdownDocuments.cshtml", statutesTabs)
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        @if (Model.ApplicationStatus != ApplicationStatus.Approved)
        {
            <div class="card mb-3">
                <div class="card-header">@Localizer["Governance_WhatIsAsociado"]</div>
                <div class="card-body">
                    <p class="mb-2">@Localizer["Governance_AsociadoLawDescription"]</p>
                    <p class="mb-2"><strong>@Localizer["Governance_AsociadoCanDo"]</strong></p>
                    <ul class="mb-0">
                        <li>@Localizer["Governance_AttendAssemblies"]</li>
                        <li>@Localizer["Governance_VoteOnDecisions"]</li>
                        <li>@Localizer["Governance_ParticipateElections"]</li>
                    </ul>
                </div>
            </div>
            <div class="card mb-3">
                <div class="card-header">@Localizer["Governance_WhoShouldApply"]</div>
                <div class="card-body">
                    <p class="mb-2">@Localizer["Governance_WhoShouldApplyDescription"]</p>
                    <ul class="mb-2">
                        <li>@Localizer["Governance_CampLeads"]</li>
                        <li>@Localizer["Governance_MetaVolunteers"]</li>
                        <li>@Localizer["Governance_LongTermMembers"]</li>
                    </ul>
                    <p class="mb-2 text-muted"><small>@Localizer["Governance_BoardReviews"]</small></p>
                    <p class="mb-0 text-muted"><small>@Localizer["Governance_NoteNotRequired"]</small></p>
                </div>
            </div>
        }
        <div class="card mt-3">
            <div class="card-header">@Localizer["Governance_MemberCounts"]</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-8">@Localizer["Governance_Colaboradores"]</dt>
                    <dd class="col-4 text-end mb-2">@Model.ColaboradorCount</dd>
                    <dt class="col-8">@Localizer["Governance_Asociados"]</dt>
                    <dd class="col-4 text-end mb-0">@Model.AsociadoCount</dd>
                </dl>
            </div>
        </div>
        @if (Model.IsApprovedColaborador && Model.CanApply)
        {
            <div class="card mt-3 border-info">
                <div class="card-body text-info-emphasis bg-info-subtle">
                    <p class="mb-2">@Localizer["Governance_ColaboradorCanApply"]</p>
                    <a asp-controller="GovernanceApplications" asp-action="Create" class="btn btn-sm btn-outline-info">@Localizer["Governance_ApplyForAsociado"]</a>
                </div>
            </div>
        }
    </div>
</div>
