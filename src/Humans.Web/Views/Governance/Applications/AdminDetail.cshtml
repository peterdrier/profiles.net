@model Humans.Web.Models.AdminApplicationDetailViewModel
@{
    ViewData["Title"] = Localizer["AdminApplicationDetail_Title"].Value;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">@Localizer["Nav_Admin"]</a></li>
        <li class="breadcrumb-item"><a asp-action="Admin">@Localizer["AdminApplications_Title"]</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Localizer["AdminApp_Review"]</li>
    </ol>
</nav>

<vc:temp-data-alerts />

<div class="row">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1>@Localizer["AdminAppDetail_ApplicationReview"]</h1>
            <span class="badge fs-5 @Model.Status.GetBadgeClass()">@Localizer["ApplicationStatus_" + Model.Status.ToString()]</span>
        </div>

        <div class="card mb-4">
            <div class="card-header">@Localizer["AdminApp_Applicant"]</div>
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <vc:human user-id="@Model.UserId"
                              layout="Avatar"
                              size="48"
                              css-class="me-3"
                              link="Admin" />
                    <div>
                        <h5 class="mb-0">@Model.UserDisplayName</h5>
                        <small class="text-muted">@Model.UserEmail</small>
                    </div>
                </div>
            </div>
        </div>

        <partial name="~/Views/Shared/_ApplicationResponseSections.cshtml"
                 model="Model"
                 view-data='new ViewDataDictionary(ViewData) { ["MotivationTitle"] = Localizer["AdminAppDetail_Motivation"].Value }' />
    </div>

    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header">@Localizer["ApplicationDetail_ApplicationInfo"]</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">@Localizer["Governance_Submitted"]</dt>
                    <dd class="col-7">@Model.SubmittedAt.ToDisplayDate()</dd>

                    @if (!string.IsNullOrEmpty(Model.Language))
                    {
                        <dt class="col-5">@Localizer["AdminAppDetail_Language"]</dt>
                        <dd class="col-7">@Model.Language.ToDisplayLanguageName()</dd>
                    }

                    @if (Model.ReviewStartedAt.HasValue)
                    {
                        <dt class="col-5">@Localizer["ApplicationDetail_ReviewStarted"]</dt>
                        <dd class="col-7">@Model.ReviewStartedAt.ToDisplayDate()</dd>
                    }

                    @if (!string.IsNullOrEmpty(Model.ReviewerName))
                    {
                        <dt class="col-5">@Localizer["AdminAppDetail_Reviewer"]</dt>
                        <dd class="col-7">@Model.ReviewerName</dd>
                    }
                </dl>
            </div>
        </div>

        @if (Model.CanApproveReject)
        {
            <div class="card mb-4">
                <div class="card-body text-center">
                    <a asp-controller="GovernanceBoardVoting" asp-action="BoardVotingDetail" asp-route-applicationId="@Model.Id"
                       class="btn btn-primary w-100">
                        <i class="fa-solid fa-gavel me-1"></i> @Localizer["BoardVoting_Title"] <i class="fa-solid fa-lock auth-lock-icon"></i>
                    </a>
                </div>
            </div>
        }

        <div class="card">
            @await Html.PartialAsync("_ApplicationHistory", Model.History)
        </div>
    </div>
</div>
