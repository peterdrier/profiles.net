@model Humans.Application.Interfaces.Budget.BudgetCategorySnapshot
@{
    ViewData["Title"] = $"Finance - {Model.Name}";
    var teams = ViewBag.Teams as IEnumerable<dynamic> ?? [];
    var lineItemTotal = Model.LineItems.Where(li => !li.IsCashflowOnly).Sum(li => li.Amount);
    var unallocated = Model.AllocatedAmount - lineItemTotal;
    var group = Model.BudgetGroup;
    var year = group?.BudgetYear;

    // Compute VAT projections
    var vatProjections = Model.LineItems
        .Where(li => li.VatRate > 0 && li.ExpectedDate.HasValue)
        .Select(li => new VatProjection
        {
            SourceDescription = li.Description,
            VatAmount = Math.Abs(li.Amount) * li.VatRate / (100m + li.VatRate),
            SettlementDate = ComputeVatSettlementDate(li.ExpectedDate!.Value),
            VatRate = li.VatRate,
            IsExpense = li.Amount > 0
        })
        .OrderBy(v => v.SettlementDate)
        .ToList();
}

@functions {
    private static NodaTime.LocalDate ComputeVatSettlementDate(NodaTime.LocalDate expectedDate)
    {
        var quarterEnd = expectedDate.Month switch
        {
            >= 1 and <= 3 => new NodaTime.LocalDate(expectedDate.Year, 3, 31),
            >= 4 and <= 6 => new NodaTime.LocalDate(expectedDate.Year, 6, 30),
            >= 7 and <= 9 => new NodaTime.LocalDate(expectedDate.Year, 9, 30),
            _ => new NodaTime.LocalDate(expectedDate.Year, 12, 31)
        };
        return quarterEnd.PlusDays(45);
    }
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Finance</a></li>
        @if (year is not null)
        {
            <li class="breadcrumb-item"><a asp-action="YearDetail" asp-route-id="@year.Id">@year.Name</a></li>
        }
        @if (group is not null)
        {
            <li class="breadcrumb-item">@group.Name</li>
        }
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<h1 class="mb-4">@Model.Name</h1>

<vc:temp-data-alerts />

<div class="alert alert-warning d-flex align-items-center" role="alert">
    <i class="fa-solid fa-triangle-exclamation fa-lg me-2"></i>
    <div>
        <strong>All amounts on this page include VAT / IVA.</strong>
        Enter the gross figure you will actually pay or receive — the full amount including IVA. <strong>Do not subtract VAT.</strong>
        The "VAT %" field only records the rate so the IVA portion can be broken out for projections; it does <em>not</em> add VAT on top of the amount you enter.
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Allocated <span class="text-muted">(incl. VAT/IVA)</span></h6>
                <h3 class="card-title mb-0">&euro;@Model.AllocatedAmount.ToString("N2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Total in Line Items</h6>
                <h3 class="card-title mb-0">&euro;@lineItemTotal.ToString("N2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Unallocated</h6>
                <h3 class="card-title mb-0 @(unallocated < 0 ? "text-danger" : "")">
                    &euro;@unallocated.ToString("N2")
                </h3>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header" role="button" data-bs-toggle="collapse" data-bs-target="#editCategory">
        <i class="fa-solid fa-pen me-1"></i>Edit Category
    </div>
    <div id="editCategory" class="collapse">
        <div class="card-body">
            <form asp-action="UpdateCategory" asp-route-id="@Model.Id" method="post" class="row g-3 align-items-end">
                @Html.AntiForgeryToken()
                <div class="col-md-4">
                    <label class="form-label">Name</label>
                    <input type="text" name="name" class="form-control" value="@Model.Name" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Allocated Amount (&euro;, incl. VAT/IVA)</label>
                    <input type="number" name="allocatedAmount" class="form-control" step="0.01" value="@Model.AllocatedAmount" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Expenditure Type</label>
                    <select name="expenditureType" class="form-select">
                        @if (Model.ExpenditureType == ExpenditureType.OpEx)
                        {
                            <option value="@ExpenditureType.OpEx" selected>OpEx</option>
                            <option value="@ExpenditureType.CapEx">CapEx</option>
                        }
                        else
                        {
                            <option value="@ExpenditureType.OpEx">OpEx</option>
                            <option value="@ExpenditureType.CapEx" selected>CapEx</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Save</button>
                </div>
            </form>
            @if (year is not null)
            {
                <hr />
                <form asp-action="DeleteCategory" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="budgetYearId" value="@year.Id" />
                    <button type="submit" class="btn btn-outline-danger btn-sm" data-confirm="Delete this category and all its line items?">
                        <i class="fa-solid fa-trash me-1"></i>Delete Category
                    </button>
                </form>
            }
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Line Items</span>
        <span class="badge bg-secondary">@Model.LineItems.Count items</span>
    </div>
    @if (Model.LineItems.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th class="text-end">Amount <small class="text-muted fw-normal">(incl. VAT/IVA)</small></th>
                        <th>VAT</th>
                        <th>Responsible Team</th>
                        <th>Notes</th>
                        <th>Expected Date</th>
                        <th class="text-end" style="min-width: 120px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.LineItems.OrderBy(li => li.SortOrder))
                    {
                        var editId = $"edit-{item.Id.ToString("N")}";
                        var amountClass = item.Amount >= 0 ? "text-success" : "text-danger";
                        <tr class="@(item.IsAutoGenerated ? (item.Description.StartsWith("Projected:") ? "table-light fst-italic" : "table-light") : "")">
                            <td>
                                @item.Description
                                @if (item.IsAutoGenerated)
                                {
                                    <span class="badge bg-secondary ms-1" title="Auto-generated from ticket sales data">Auto</span>
                                }
                                @if (item.IsCashflowOnly)
                                {
                                    <span class="badge bg-info ms-1" title="Cashflow only — excluded from budget totals">Cashflow</span>
                                }
                            </td>
                            <td class="text-end @amountClass">&euro;@item.Amount.ToString("N2")</td>
                            <td>
                                @if (item.VatRate > 0)
                                {
                                    <span class="badge bg-warning text-dark">@item.VatRate%</span>
                                }
                                else
                                {
                                    <span class="text-muted">0%</span>
                                }
                            </td>
            <td>@(item.ResponsibleTeamName ?? "\u2014")</td>
                            <td class="text-muted">@(item.Notes ?? "")</td>
                            <td>@item.ExpectedDate?.ToDisplayDate()</td>
                            <td class="text-end">
                                <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#@editId">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <form asp-action="DeleteLineItem" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="budgetCategoryId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm" data-confirm="Delete this line item?">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <tr class="collapse" id="@editId">
                            <td colspan="7" class="bg-light">
                                <form asp-action="UpdateLineItem" asp-route-id="@item.Id" method="post" class="row g-2 p-2 align-items-end">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="budgetCategoryId" value="@Model.Id" />
                                    <div class="col-md-2">
                                        <label class="form-label form-label-sm">Description</label>
                                        <input type="text" name="description" class="form-control form-control-sm" value="@item.Description" required />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label form-label-sm">Amount (&euro;, incl. VAT/IVA)</label>
                                        <input type="number" name="amount" class="form-control form-control-sm" step="0.01" value="@item.Amount" required />
                                    </div>
                                    <div class="col-md-1">
                                        <label class="form-label form-label-sm">VAT %</label>
                                        <select name="vatRate" class="form-select form-select-sm">
                                            @foreach (var rate in new[] { 0, 10, 21 })
                                            {
                                                if (item.VatRate == rate)
                                                {
                                                    <option value="@rate" selected>@rate%</option>
                                                }
                                                else
                                                {
                                                    <option value="@rate">@rate%</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label form-label-sm">Responsible Team</label>
                                        <select name="responsibleTeamId" class="form-select form-select-sm">
                                            <option value="">None</option>
                                            @foreach (var team in teams)
                                            {
                                                var teamId = (Guid)team.Id;
                                                var teamName = (string)team.Name;
                                                if (item.ResponsibleTeamId == teamId)
                                                {
                                                    <option value="@teamId" selected>@teamName</option>
                                                }
                                                else
                                                {
                                                    <option value="@teamId">@teamName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label form-label-sm">Notes</label>
                                        <input type="text" name="notes" class="form-control form-control-sm" value="@item.Notes" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label form-label-sm">Expected Date</label>
                                        <input type="date" name="expectedDate" class="form-control form-control-sm" value="@item.ExpectedDate?.ToDateTimeUnspecified().ToString("yyyy-MM-dd")" />
                                    </div>
                                    <div class="col-md-1">
                                        <button type="submit" class="btn btn-primary btn-sm w-100">Save</button>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="card-body text-center text-muted py-4">
            No line items yet. Add one below.
        </div>
    }
    <div class="card-footer bg-light">
        <h6 class="mb-2">Add Line Item</h6>
        <form asp-action="CreateLineItem" method="post" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <input type="hidden" name="budgetCategoryId" value="@Model.Id" />
            <div class="col-md-2">
                <label class="form-label form-label-sm">Description</label>
                <input type="text" name="description" class="form-control form-control-sm" required />
            </div>
            <div class="col-md-2">
                <label class="form-label form-label-sm">Amount (&euro;, incl. VAT/IVA)</label>
                <input type="number" name="amount" class="form-control form-control-sm" step="0.01" value="0" required />
            </div>
            <div class="col-md-1">
                <label class="form-label form-label-sm">VAT %</label>
                <select name="vatRate" class="form-select form-select-sm">
                    <option value="0" selected>0%</option>
                    <option value="10">10%</option>
                    <option value="21">21%</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label form-label-sm">Responsible Team</label>
                <select name="responsibleTeamId" class="form-select form-select-sm">
                    <option value="">None</option>
                    @foreach (var team in teams)
                    {
                        var teamId = (Guid)team.Id;
                        var teamName = (string)team.Name;
                        if (Model.TeamId == teamId)
                        {
                            <option value="@teamId" selected>@teamName</option>
                        }
                        else
                        {
                            <option value="@teamId">@teamName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label form-label-sm">Notes</label>
                <input type="text" name="notes" class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <label class="form-label form-label-sm">Expected Date</label>
                <input type="date" name="expectedDate" class="form-control form-control-sm" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="fa-solid fa-plus me-1"></i>Add
                </button>
            </div>
        </form>
    </div>
</div>

@if (vatProjections.Any())
{
    <div class="card mt-4">
        <div class="card-header">
            <i class="fa-solid fa-receipt me-1"></i>VAT Projections
        </div>
        <div class="table-responsive">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Source</th>
                        <th class="text-end">VAT Amount</th>
                        <th>Rate</th>
                        <th>Direction</th>
                        <th>Settlement Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vat in vatProjections)
                    {
                        <tr class="fst-italic text-muted">
                            <td>
                                <i class="fa-solid fa-receipt me-1"></i>
                                VAT on @vat.SourceDescription
                            </td>
                            <td class="text-end @(vat.IsExpense ? "text-danger" : "text-success")">
                                @(vat.IsExpense ? "-" : "+")&euro;@vat.VatAmount.ToString("N2")
                            </td>
                            <td><span class="badge bg-warning text-dark">@vat.VatRate%</span></td>
                            <td>
                                @if (vat.IsExpense)
                                {
                                    <span class="badge bg-danger">VAT Liability</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">VAT Credit</span>
                                }
                            </td>
                            <td>@vat.SettlementDate.ToDisplayDate()</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="mt-3">
    @if (year is not null)
    {
        <a asp-action="YearDetail" asp-route-id="@year.Id" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to @year.Name
        </a>
    }
    else
    {
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to Finance
        </a>
    }
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-confirm]').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            if (!confirm(this.getAttribute('data-confirm'))) {
                e.preventDefault();
            }
        });
    });
});
</script>
