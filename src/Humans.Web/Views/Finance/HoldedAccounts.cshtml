@model Humans.Application.Services.Finance.Dtos.HoldedProvisioningPlan
@{
    ViewData["Title"] = "Holded Account Provisioning";
    var blockStart = (int)(ViewBag.BlockStart ?? 62900100);
    var toAddRows = Model.Rows.Where(r => r.State == "ToAdd").ToList();
    var hasToAdd = toAddRows.Count > 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Holded Account Provisioning</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to Finance
    </a>
</div>

<vc:temp-data-alerts />

<div class="alert alert-info mb-4">
    <i class="fa-solid fa-circle-info me-1"></i>
    Each budget category gets a dedicated Holded account for accurate expense tracking. Provisioning is additive — existing accounts are never modified or removed.
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="fa-solid fa-sliders me-1"></i>Account Number Block
    </div>
    <div class="card-body">
        <form method="get" asp-action="HoldedAccounts" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label" for="blockStart">Reserved block start</label>
                <input type="number" id="blockStart" name="blockStart" class="form-control" value="@blockStart" min="0" style="width: 160px;" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrows-rotate me-1"></i>Refresh Preview
                </button>
            </div>
            <div class="col-auto align-self-end">
                <span class="text-muted small">Next number: <strong>@Model.NextNumber</strong></span>
            </div>
        </form>
    </div>
</div>

@if (hasToAdd)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fa-solid fa-plus me-1"></i>Provision New Accounts</span>
            <span class="badge bg-primary">@toAddRows.Count to add</span>
        </div>
        <div class="card-body d-flex gap-2">
            <form asp-action="ProvisionHoldedAccounts" method="post" class="d-inline js-provision-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="blockStart" value="@blockStart" />
                <input type="hidden" name="addAll" value="false" />
                <button type="submit" class="btn btn-outline-primary">
                    <i class="fa-solid fa-flask me-1"></i>Add One (test)
                </button>
            </form>
            <form asp-action="ProvisionHoldedAccounts" method="post" class="d-inline js-provision-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="blockStart" value="@blockStart" />
                <input type="hidden" name="addAll" value="true" />
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-cloud-upload-alt me-1"></i>Add All (@toAddRows.Count)
                </button>
            </form>
        </div>
    </div>
}

<div class="card">
    <div class="card-header">
        <i class="fa-solid fa-table me-1"></i>Provisioning Plan
        <span class="badge bg-secondary ms-2">@Model.Rows.Count rows</span>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Group</th>
                    <th>Category</th>
                    <th>State</th>
                    <th class="text-end">Existing #</th>
                    <th class="text-end">Proposed #</th>
                    <th>Tag</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows.OrderBy(r => r.GroupName, StringComparer.Ordinal).ThenBy(r => r.CategoryName, StringComparer.Ordinal))
                {
                    var badgeClass = row.State switch
                    {
                        "Mapped"  => "bg-success",
                        "ToAdd"   => "bg-primary",
                        "Orphan"  => "bg-warning text-dark",
                        _         => "bg-secondary"
                    };
                    <tr>
                        <td>@row.GroupName</td>
                        <td>@row.CategoryName</td>
                        <td><span class="badge @badgeClass">@row.State</span></td>
                        <td class="text-end text-muted">@(row.ExistingAccountNum?.ToString() ?? "—")</td>
                        <td class="text-end">@(row.ProposedAccountNum?.ToString() ?? "—")</td>
                        <td><code class="small">@row.Tag</code></td>
                        <td class="text-muted small">
                            @if (row.State == "Orphan")
                            {
                                <span>Account exists in Holded but has no matching category — archived locally, not deleted from Holded.</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    // Idempotency guard: provisioning calls the external Holded API to create accounts,
    // so a double-submit could create duplicate accounts (and orphan a Holded account when
    // the second local write hits the unique BudgetCategoryId constraint). Disable both
    // provision buttons on first submit; show a spinner on the one that was clicked.
    document.querySelectorAll('.js-provision-form').forEach(function (form) {
        form.addEventListener('submit', function () {
            var clicked = form.querySelector('button[type="submit"]');
            document.querySelectorAll('.js-provision-form button[type="submit"]').forEach(function (b) {
                b.disabled = true;
            });
            if (clicked) {
                clicked.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Working…';
            }
        });
    });
</script>
