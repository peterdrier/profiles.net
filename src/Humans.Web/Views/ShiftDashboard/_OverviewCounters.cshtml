@using Humans.Application.DTOs
@model (DashboardOverview Overview, ShiftPeriod? SelectedPeriod)

@{
    static string PctClass(double pct) =>
        pct >= 80 ? "bg-success" : pct >= 60 ? "bg-warning text-dark" : "bg-danger";

    string PctStatusLabel(double pct) =>
        pct >= 80 ? Localizer["ShiftDash_Status_OnTrack"].Value
        : pct >= 60 ? Localizer["ShiftDash_Status_AtRisk"].Value
        : Localizer["ShiftDash_Status_BelowTarget"].Value;

    var o = Model.Overview;
    var shiftsPct = o.TotalShifts == 0 ? 0 : 100.0 * o.FilledShifts / o.TotalShifts;
    var slotsPct = o.TotalSlots == 0 ? 0 : 100.0 * o.FilledSlots / o.TotalSlots;
    var engagedPct = o.TicketHolderCount == 0 ? 0 : 100.0 * o.TicketHoldersEngaged / o.TicketHolderCount;
    var unreached = Math.Max(0, o.TicketHolderCount - o.TicketHoldersEngaged);

    // TEMP: ticket figures are not shareable yet. Flip to true once ticket data is publishable.
    // The underlying DashboardOverview still computes them (see ShiftManagementService).
    var showTicketData = false;
}

<div class="row g-3 mb-4">
    <div class="col-md-4 col-lg">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">@Localizer["ShiftDash_Overview_ShiftsFilled"]</div>
                <div class="fs-3 fw-bold">@o.FilledSlots <span class="text-muted fs-6">/ @o.TotalSlots (@slotsPct.ToString("0")%)</span></div>
                @if (!Model.SelectedPeriod.HasValue)
                {
                    <div class="mt-2">
                        <span class="badge @PctClass(o.PeriodFillRates.BuildPct) me-1">@Localizer["Shifts_SetUp"] @o.PeriodFillRates.BuildPct.ToString("0")% <span class="visually-hidden">@PctStatusLabel(o.PeriodFillRates.BuildPct)</span></span>
                        <span class="badge @PctClass(o.PeriodFillRates.EventPct) me-1">@Localizer["Shifts_Event"] @o.PeriodFillRates.EventPct.ToString("0")% <span class="visually-hidden">@PctStatusLabel(o.PeriodFillRates.EventPct)</span></span>
                        <span class="badge @PctClass(o.PeriodFillRates.StrikePct)">@Localizer["Shifts_Strike"] @o.PeriodFillRates.StrikePct.ToString("0")% <span class="visually-hidden">@PctStatusLabel(o.PeriodFillRates.StrikePct)</span></span>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">@Localizer["ShiftDash_Overview_TicketHolders"]</div>
                @if (showTicketData)
                {
                    <div class="fs-3 fw-bold">@o.TicketHolderCount</div>
                    <div class="text-muted small">@Localizer["ShiftDash_Overview_TicketHoldersSubline"]</div>
                }
                else
                {
                    <div class="fs-3 fw-bold text-muted">@Localizer["Common_NotAvailable"]</div>
                    <div class="text-muted small">@Localizer["ShiftDash_Overview_TicketData_Hidden"]</div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="card h-100 @(showTicketData ? "border-primary" : "")">
            <div class="card-body">
                <div class="text-muted small text-uppercase">@Localizer["ShiftDash_Overview_TicketHoldersEngaged"]</div>
                @if (showTicketData)
                {
                    <div class="fs-3 fw-bold">@o.TicketHoldersEngaged <span class="text-muted fs-6">/ @o.TicketHolderCount (@engagedPct.ToString("0")%)</span></div>
                    <div class="text-muted small">@string.Format(Localizer["ShiftDash_Overview_EngagedSubline"].Value, unreached)</div>
                }
                else
                {
                    <div class="fs-3 fw-bold text-muted">@Localizer["Common_NotAvailable"]</div>
                    <div class="text-muted small">@Localizer["ShiftDash_Overview_TicketData_Hidden"]</div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">@Localizer["ShiftDash_Overview_NonTicketSignups"]</div>
                @if (showTicketData)
                {
                    <div class="fs-3 fw-bold">@o.NonTicketSignups</div>
                    <div class="text-muted small">@Localizer["ShiftDash_Overview_NonTicketSubline"]</div>
                }
                else
                {
                    <div class="fs-3 fw-bold text-muted">@Localizer["Common_NotAvailable"]</div>
                    <div class="text-muted small">@Localizer["ShiftDash_Overview_TicketData_Hidden"]</div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="card h-100 @(o.StalePendingCount > 0 ? "border-warning" : "")">
            <div class="card-body">
                <div class="text-muted small text-uppercase">@Localizer["ShiftDash_Overview_StalePending"]</div>
                <div class="fs-3 fw-bold">@o.StalePendingCount</div>
                <div class="text-muted small">@Localizer["ShiftDash_Overview_StaleSubline"]</div>
            </div>
        </div>
    </div>
</div>
