@using Humans.Application.DTOs
@model (IReadOnlyList<DepartmentStaffingRow> Rows, ShiftPeriod? SelectedPeriod)

@{
    static string PctClass(double pct) =>
        pct >= 80 ? "bg-success" : pct >= 60 ? "bg-warning text-dark" : "bg-danger";

    static double SlotPct(int filled, int total) => total == 0 ? 0 : 100.0 * filled / total;

    string PctStatusLabel(double pct) =>
        pct >= 80 ? Localizer["ShiftDash_Status_OnTrack"].Value
        : pct >= 60 ? Localizer["ShiftDash_Status_AtRisk"].Value
        : Localizer["ShiftDash_Status_BelowTarget"].Value;

    var periodSelected = Model.SelectedPeriod.HasValue;
}

@if (Model.Rows.Count == 0)
{
    return;
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>@Localizer["ShiftDash_Departments_Title"]</strong>
        <span class="text-muted small">@Localizer["ShiftDash_Departments_SortNote"]</span>
    </div>
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th></th>
                    <th>@Localizer["ShiftDash_Departments_Col_Department"]</th>
                    <th class="text-end">@Localizer["ShiftDash_Departments_Col_Filled"]</th>
                    <th class="text-end">@Localizer["ShiftDash_Departments_Col_Pct"]</th>
                    <th class="text-end">@Localizer["ShiftDash_Departments_Col_SlotsRemaining"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    var rowId = "dept-" + row.DepartmentId.ToString("N");
                    var pct = SlotPct(row.FilledSlots, row.TotalSlots);
                    // Drill-down is shown when there are subgroups (always worth seeing)
                    // or when no period is selected (so the per-period breakdown has something to say).
                    // Otherwise we render a plain non-interactive row — no chevron, no collapse target.
                    var hasDrilldown = row.Subgroups.Count > 0 || !periodSelected;
                    if (hasDrilldown)
                    {
                    <tr role="button" data-bs-toggle="collapse" data-bs-target="#@rowId" aria-expanded="false" aria-controls="@rowId">
                        <td class="text-muted"><i class="fa-solid fa-chevron-right"></i></td>
                        <td>
                            @if (!string.IsNullOrEmpty(row.DepartmentSlug))
                            {
                                <a asp-controller="Team" asp-action="Details" asp-route-slug="@row.DepartmentSlug"
                                   data-dashboard-team-link="true">@row.DepartmentName</a>
                            }
                            else
                            {
                                @row.DepartmentName
                            }
                        </td>
                        <td class="text-end">@row.FilledSlots / @row.TotalSlots</td>
                        <td class="text-end"><span class="badge @PctClass(pct)">@pct.ToString("0")% <span class="visually-hidden">@PctStatusLabel(pct)</span></span></td>
                        <td class="text-end">@row.SlotsRemaining</td>
                    </tr>
                    <tr class="collapse" id="@rowId">
                        <td colspan="5" class="bg-light">
                            @if (row.Subgroups.Count > 0)
                            {
                                <table class="table table-sm mb-0">
                                    <thead>
                                        <tr>
                                            <th></th>
                                            <th class="text-end">@Localizer["ShiftDash_Departments_Col_Filled"]</th>
                                            <th class="text-end">@Localizer["ShiftDash_Departments_Col_Pct"]</th>
                                            <th class="text-end">@Localizer["ShiftDash_Departments_Col_SlotsRemaining"]</th>
                                            @if (!periodSelected)
                                            {
                                                <th class="text-end">@Localizer["Shifts_SetUp"]</th>
                                                <th class="text-end">@Localizer["Shifts_Event"]</th>
                                                <th class="text-end">@Localizer["Shifts_Strike"]</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var sub in row.Subgroups)
                                        {
                                            var sPct = SlotPct(sub.FilledSlots, sub.TotalSlots);
                                            <tr>
                                                <td>
                                                    @if (sub.IsDirect)
                                                    {
                                                        <span class="badge bg-secondary me-1">@Localizer["ShiftDash_Departments_Direct"]</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(sub.Slug))
                                                    {
                                                        <a asp-controller="Team" asp-action="Details" asp-route-slug="@sub.Slug">@sub.Name</a>
                                                    }
                                                    else
                                                    {
                                                        @sub.Name
                                                    }
                                                </td>
                                                <td class="text-end">@sub.FilledSlots / @sub.TotalSlots</td>
                                                <td class="text-end"><span class="badge @PctClass(sPct)">@sPct.ToString("0")% <span class="visually-hidden">@PctStatusLabel(sPct)</span></span></td>
                                                <td class="text-end">@sub.SlotsRemaining</td>
                                                @if (!periodSelected)
                                                {
                                                    var bPct = SlotPct(sub.Build.FilledSlots, sub.Build.TotalSlots);
                                                    var ePct = SlotPct(sub.Event.FilledSlots, sub.Event.TotalSlots);
                                                    var stPct = SlotPct(sub.Strike.FilledSlots, sub.Strike.TotalSlots);
                                                    <td class="text-end"><span class="badge @PctClass(bPct)">@bPct.ToString("0")% <span class="visually-hidden">@PctStatusLabel(bPct)</span></span></td>
                                                    <td class="text-end"><span class="badge @PctClass(ePct)">@ePct.ToString("0")% <span class="visually-hidden">@PctStatusLabel(ePct)</span></span></td>
                                                    <td class="text-end"><span class="badge @PctClass(stPct)">@stPct.ToString("0")% <span class="visually-hidden">@PctStatusLabel(stPct)</span></span></td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else if (!periodSelected)
                            {
                                <table class="table table-sm mb-0">
                                    <thead>
                                        <tr>
                                            <th>@Localizer["ShiftDash_Departments_Col_Period"]</th>
                                            <th class="text-end">@Localizer["ShiftDash_Departments_Col_Filled"]</th>
                                            <th class="text-end">@Localizer["ShiftDash_Departments_Col_Pct"]</th>
                                            <th class="text-end">@Localizer["ShiftDash_Departments_Col_SlotsRemaining"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var (label, p) in new[] {
                                            (Localizer["Shifts_SetUp"].Value, row.Build),
                                            (Localizer["Shifts_Event"].Value, row.Event),
                                            (Localizer["Shifts_Strike"].Value, row.Strike) })
                                        {
                                            var pPct = SlotPct(p.FilledSlots, p.TotalSlots);
                                            <tr>
                                                <td>@label</td>
                                                <td class="text-end">@p.FilledSlots / @p.TotalSlots</td>
                                                <td class="text-end"><span class="badge @PctClass(pPct)">@pPct.ToString("0")% <span class="visually-hidden">@PctStatusLabel(pPct)</span></span></td>
                                                <td class="text-end">@p.SlotsRemaining</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </td>
                    </tr>
                    }
                    else
                    {
                    <tr>
                        <td></td>
                        <td>
                            @if (!string.IsNullOrEmpty(row.DepartmentSlug))
                            {
                                <a asp-controller="Team" asp-action="Details" asp-route-slug="@row.DepartmentSlug">@row.DepartmentName</a>
                            }
                            else
                            {
                                @row.DepartmentName
                            }
                        </td>
                        <td class="text-end">@row.FilledSlots / @row.TotalSlots</td>
                        <td class="text-end"><span class="badge @PctClass(pct)">@pct.ToString("0")% <span class="visually-hidden">@PctStatusLabel(pct)</span></span></td>
                        <td class="text-end">@row.SlotsRemaining</td>
                    </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    // Team-page links inside a clickable-collapse row must not trigger the row's
    // data-bs-toggle="collapse" behaviour — stop propagation so the link navigates
    // cleanly without also opening/closing the drill-down.
    (function () {
        document.querySelectorAll('[data-dashboard-team-link="true"]').forEach(function (el) {
            el.addEventListener('click', function (e) { e.stopPropagation(); });
        });
    })();
</script>
