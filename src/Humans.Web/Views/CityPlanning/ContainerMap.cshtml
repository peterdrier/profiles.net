@model Humans.Web.Models.ContainerMapViewModel
@{
    ViewData["Title"] = $"Container Placement {Model.Year}";
    Layout = "_Layout";
    var clearMeasurementsLabel = Localizer["CityPlanning_ClearMeasurementsButton"];
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@5.20.1/dist/maplibre-gl.css" />
    <style>
        :root {
            --container-fill:          var(--h-sepia);
            --container-fill-selected: var(--h-gold);
        }
        /* Override the main layout to occupy the whole screen space */
        body { height: 100vh; overflow: hidden; }
        .main-content { display: flex; max-width: 100vw; padding: 0; min-height: 0; }
        main { display: flex; flex: 1; padding: 0; min-height: 0; }
        #map-page, #container-sidebar { min-height: 0; }
        #container-sidebar { width: 280px; }
        #rotation-handle {
            position: absolute;
            width: 28px;
            height: 28px;
            background: var(--container-fill-selected);
            border: 2px solid white;
            border-radius: 50%;
            cursor: grab;
            transform: translate(-50%, -50%);
            display: none;
            z-index: 10;
            pointer-events: auto;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 13px;
        }
        #rotation-handle:active { cursor: grabbing; }
        #map-toast {
            position: absolute;
            bottom: 16px;
            left: 50%;
            transform: translateX(-50%);
            display: none;
            z-index: 20;
            white-space: nowrap;
        }
    </style>
}

@Html.AntiForgeryToken()

<div id="map-page" class="d-flex flex-fill overflow-hidden">
    <div id="container-sidebar" class="border-end d-flex flex-column overflow-hidden flex-shrink-0">
        <div class="px-3 py-2 border-bottom d-flex flex-column align-items-center gap-2">
            <div>
                <div class="fw-semibold">@Localizer["Container_Breadcrumb"] @Model.Year</div>
                @if (!string.IsNullOrEmpty(Model.CampName))
                {
                    <div class="small text-muted">@Model.CampName</div>
                }
            </div>
            @if (Model.IsMapAdmin)
            {
                <a asp-action="Containers" asp-route-year="@Model.Year" class="btn btn-sm btn-outline-secondary">
                    <i class="fa-solid fa-edit me-1"></i>@Localizer["CityPlanning_Admin_ManageContainers"]
                </a>
            }
            else if (!string.IsNullOrEmpty(Model.CampSlug))
            {
                <a asp-controller="Container" asp-action="Index" asp-route-slug="@Model.CampSlug" class="btn btn-sm btn-outline-secondary">
                    <i class="fa-solid fa-edit me-1"></i>@Localizer["CityPlanning_Admin_ManageContainers"]
                </a>
            }
        </div>
        <div class="overflow-auto">
            <div id="sidebar-unplaced" class="list-group list-group-flush">
                <div class="sidebar-section-label list-group-item py-1 text-uppercase text-muted small fw-semibold bg-body-tertiary">@Localizer["ContainerMap_Unplaced"]</div>
            </div>
            <div id="sidebar-placed" class="list-group list-group-flush border-top">
                <div class="sidebar-section-label list-group-item py-1 text-uppercase text-muted small fw-semibold bg-body-tertiary">@Localizer["ContainerMap_Placed"]</div>
            </div>
        </div>
    </div>
    <div id="map-container" class="flex-fill position-relative">
        <div id="map" class="h-100 w-100"
             data-year="@Model.Year"
             data-is-map-admin="@Model.IsMapAdmin.ToString().ToLower()"
             data-user-camp-id="@Model.UserCampId"></div>
        <div id="rotation-handle"><i class="fa-solid fa-rotate"></i></div>
        <div id="map-toast" class="alert alert-danger py-2 px-3 mb-0 shadow-sm" role="alert"></div>
        <div class="position-absolute top-0 end-0 m-3 d-grid gap-3" style="z-index:10;">
            <div class="card shadow-sm">
                <div class="card-body py-2 px-3 d-flex flex-column gap-1">
                    <vc:access-matrix section="ContainerMap" />
                    <div class="d-flex gap-1">
                        <button type="button" id="measure-btn" class="btn btn-outline-secondary btn-sm flex-grow-1" aria-pressed="false">
                            <i class="fa-solid fa-ruler me-1"></i> @Localizer["CityPlanning_MeasureButton"]
                        </button>
                        <button id="clear-measurements-btn" type="button" class="btn btn-sm btn-outline-danger d-none" title="@clearMeasurementsLabel" aria-label="@clearMeasurementsLabel">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-body py-2 px-3" style="font-size:11px; line-height:1.4;">
                    <div class="fw-semibold mb-1 text-muted text-uppercase" style="font-size:10px; letter-spacing:.05em;">@Localizer["ContainerMap_Legend_Title"]</div>
                    <div class="d-flex align-items-center gap-2 mb-1">
                      <svg width="36" height="18" viewBox="0 0 36 18" style="flex-shrink:0;">
                          <polygon points="0,0 0,18 24,18 24,13.5 30,9 24,4.5 24,0" style="fill: var(--container-fill); fill-opacity: 0.7"/>
                          <polygon points="24,4.5 30,9 24,13.5" style="fill: var(--container-fill)"/>
                      </svg>
                      <ul class="list-unstyled mb-0">
                        <li>@Localizer["ContainerMap_Legend_Body"]</li>
                        <li>@Localizer["ContainerMap_Legend_Door"]</li>
                      </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="placementNotesModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="placementNotesForm" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <span data-role="title-prefix">@Localizer["Container_PlacementNotes_Title"]</span> —
                        <span data-role="container-name"></span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger d-none" data-role="error"></div>
                    <fieldset data-role="fields">
                        <div class="mb-3">
                            <label class="form-label">@Localizer["Container_FieldPlacementNotes"]</label>
                            <textarea name="PlacementNotes" class="form-control" rows="5" maxlength="5000"
                                      placeholder="@Localizer["Container_PlacementNotesPlaceholder"]"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">@Localizer["Container_FieldPlacementImage"]</label>
                            <div class="mb-2 d-none" data-role="existing-image-wrap">
                                <img data-role="existing-image" alt="" style="height:96px;object-fit:cover;border-radius:4px;" />
                            </div>
                            <div class="form-check mb-2 d-none" data-role="remove-image-wrap">
                                <input type="checkbox" name="RemovePlacementImage" value="true" class="form-check-input" id="removePlacementImageMap" />
                                <label class="form-check-label" for="removePlacementImageMap">@Localizer["Container_RemovePlacementImage_Label"]</label>
                            </div>
                            <input type="file" name="PlacementImage" class="form-control" accept="image/jpeg,image/png,image/webp" />
                        </div>
                    </fieldset>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Common_Cancel"]</button>
                    <button type="submit" class="btn btn-primary" data-role="save-btn">@Localizer["Common_Save"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/maplibre-gl@5.20.1/dist/maplibre-gl.js"></script>
    <script src="https://unpkg.com/&#64;turf/turf@7.1.0/turf.min.js"></script>
    <script type="module" src="~/js/city-planning/container-map/main.js"></script>
}
