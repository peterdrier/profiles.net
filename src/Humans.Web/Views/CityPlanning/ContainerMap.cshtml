@model Humans.Web.Models.ContainerMapViewModel
@{
    ViewData["Title"] = $"Container Placement {Model.Year}";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@5.20.1/dist/maplibre-gl.css" />
    <style>
        /* Override the main layout to occupy the whole screen space */
        .main-content { display: flex; max-width: 100vw; padding: 0; }
        main { display: flex; flex: 1; padding: 0; }
        #map-page { display: flex; flex: 1; overflow: hidden; }
        #container-sidebar { width: 280px; flex-shrink: 0; display: flex; flex-direction: column; overflow: hidden; }
        #sidebar-unplaced, #sidebar-placed { overflow-y: auto; }
        #map-container { flex: 1; position: relative; }
        #map { height: 100%; width: 100%; }
        #rotation-handle {
            position: absolute;
            width: 28px;
            height: 28px;
            background: #4fc3f7;
            border: 2px solid white;
            border-radius: 50%;
            cursor: grab;
            transform: translate(-50%, -50%);
            display: none;
            z-index: 10;
            pointer-events: auto;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 13px;
        }
        #rotation-handle:active { cursor: grabbing; }
        #map-toast {
            position: absolute;
            bottom: 16px;
            left: 50%;
            transform: translateX(-50%);
            display: none;
            z-index: 20;
            white-space: nowrap;
        }
    </style>
}

@Html.AntiForgeryToken()

<div id="map-page">
    <div id="container-sidebar" class="border-end">
        <div class="px-3 py-2 border-bottom fw-semibold">@Localizer["Container_Breadcrumb"] @Model.Year</div>
        <div id="sidebar-unplaced" class="list-group list-group-flush">
            <div class="sidebar-section-label list-group-item py-1 text-uppercase text-muted small fw-semibold bg-body-tertiary">@Localizer["ContainerMap_Unplaced"]</div>
        </div>
        <div id="sidebar-placed" class="list-group list-group-flush">
            <div class="sidebar-section-label list-group-item py-1 text-uppercase text-muted small fw-semibold bg-body-tertiary">@Localizer["ContainerMap_Placed"]</div>
        </div>
    </div>
    <div id="map-container">
        <div id="map"
             data-year="@Model.Year"
             data-is-map-admin="@Model.IsMapAdmin.ToString().ToLower()"
             data-user-camp-season-id="@Model.UserCampSeasonId"></div>
        <div id="rotation-handle"><i class="fa-solid fa-rotate"></i></div>
        <div id="map-toast" class="alert alert-danger py-2 px-3 mb-0 shadow-sm" role="alert"></div>
        <div class="position-absolute top-0 end-0 m-3 d-grid gap-3" style="z-index:10;">
            <div class="card shadow-sm">
                <div class="card-body py-2 px-3 d-flex flex-column gap-1">
                    <vc:access-matrix section="ContainerMap" />
                    <button id="measure-btn" class="btn btn-outline-secondary btn-sm" aria-pressed="false">
                        <i class="fa-solid fa-ruler me-1"></i> @Localizer["CityPlanning_MeasureButton"]
                    </button>
                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-body py-2 px-3" style="font-size:11px; line-height:1.4;">
                    <div class="fw-semibold mb-1 text-muted text-uppercase" style="font-size:10px; letter-spacing:.05em;">@Localizer["ContainerMap_Legend_Title"]</div>
                    <div class="d-flex align-items-center gap-2 mb-1">
                      <svg width="36" height="18" viewBox="0 0 36 18" style="flex-shrink:0;">
                          <polygon points="0,0 0,18 24,18 24,13.5 30,9 24,4.5 24,0" fill="#e8a020" fill-opacity="0.7"/>
                          <polygon points="24,4.5 30,9 24,13.5" fill="#e8a020" fill-opacity="1"/>
                      </svg>
                      <ul class="list-unstyled mb-0">
                        <li>@Localizer["ContainerMap_Legend_Body"]</li>
                        <li>@Localizer["ContainerMap_Legend_Door"]</li>
                      </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/maplibre-gl@5.20.1/dist/maplibre-gl.js"></script>
    <script src="https://unpkg.com/@@turf/turf@7.1.0/turf.min.js"></script>
    <script type="module" src="~/js/container-map/main.js"></script>
}
