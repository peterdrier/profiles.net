@model Humans.Web.Models.OrgContainerIndexViewModel
@{
    ViewData["Title"] = $"{Localizer["Container_Breadcrumb"]} {Model.Year}";

    Humans.Web.Models.ContainerCardModel CardFor(Humans.Web.Models.ContainerViewModel c) => new()
    {
        Container = c,
        CanManage = true,
        FormController = "CityPlanning",
        EditAction = "EditOrgContainer",
        DeleteAction = "DeleteOrgContainer",
        ExtraRouteValues = new Dictionary<string, string>(StringComparer.Ordinal),
    };
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Admin">City Planning Admin</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Localizer["Container_Breadcrumb"] @Model.Year</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@Localizer["Container_Breadcrumb"] <small class="text-muted">@Model.Year</small></h1>
    <div class="d-flex gap-2">
        <a href="/api/city-planning/containers/@Model.Year/export.geojson" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-download me-1"></i> @Localizer["Common_ExportGeoJson"]
        </a>
        <a asp-action="ContainerMap" asp-route-year="@Model.Year" class="btn btn-outline-primary btn-sm">
            <i class="fa-solid fa-map-location-dot me-1"></i> @Localizer["ContainerMap_PlaceOnMap"]
        </a>
    </div>
</div>

<vc:temp-data-alerts />

<div class="d-flex align-items-center gap-3 mb-4 p-3 border rounded">
    <div>
        <span class="fw-semibold me-2">@Localizer["CityPlanning_Admin_ContainerPlacement"]:</span>
        @if (Model.IsContainerPlacementOpen)
        {
            <span class="badge bg-success">@Localizer["CityPlanning_StatusOpen"]</span>
        }
        else
        {
            <span class="badge bg-secondary">@Localizer["CityPlanning_StatusClosed"]</span>
        }
    </div>
    @if (Model.IsContainerPlacementOpen)
    {
        <form method="post" asp-action="CloseContainerPlacement">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning btn-sm">
                <i class="fa-solid fa-lock me-1"></i> @Localizer["CityPlanning_Admin_CloseContainerPlacement"]
            </button>
        </form>
    }
    else
    {
        <form method="post" asp-action="OpenContainerPlacement">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-sm">
                <i class="fa-solid fa-lock-open me-1"></i> @Localizer["CityPlanning_Admin_OpenContainerPlacement"]
            </button>
        </form>
    }
</div>

@* ── Org containers ──────────────────────────────────────────────────── *@
<div class="d-flex align-items-center gap-2 mb-3">
    <h2 class="h4 mb-0">@Localizer["CityPlanning_Admin_OrgContainersSection"]</h2>
    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addOrgModal">
        <i class="fa-solid fa-plus me-1"></i> @Localizer["Common_Add"]
    </button>
</div>

@if (Model.OrgContainers.Count == 0)
{
    <div class="alert alert-secondary mb-4">@string.Format(Localizer["CityPlanning_Admin_OrgContainersEmpty"], Model.Year)</div>
}
else
{
    <ul class="list-group mb-4">
        @foreach (var c in Model.OrgContainers)
        {
            <partial name="_ContainerCardRow" model="@CardFor(c)" />
        }
    </ul>
}

@* ── Barrio containers ───────────────────────────────────────────────── *@
<h2 class="h4 mb-3 mt-2">@Localizer["CityPlanning_Admin_BarrioContainersSection"]</h2>

@foreach (var group in Model.BarrioGroups)
{
    <div class="d-flex align-items-center gap-2 mt-4 mb-2">
        <h3 class="h5 mb-0">@group.CampName</h3>
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addBarrioModal-@group.SeasonId">
            <i class="fa-solid fa-plus me-1"></i> @Localizer["Common_Add"]
        </button>
    </div>

    @if (group.Containers.Count == 0)
    {
        <div class="alert alert-secondary mb-3">@string.Format(Localizer["CityPlanning_Admin_BarrioContainersEmpty"], group.CampName)</div>
    }
    else
    {
        <ul class="list-group mb-3">
            @foreach (var c in group.Containers)
            {
                <partial name="_ContainerCardRow" model="@CardFor(c)" />
            }
        </ul>
    }
}

@* ── Modals ──────────────────────────────────────────────────────────── *@

<div class="modal fade" id="addOrgModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Localizer["CityPlanning_Admin_AddOrgContainer"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateOrgContainer" asp-route-year="@Model.Year"
                  method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <partial name="_ContainerFormFields" model="@((Humans.Web.Models.ContainerViewModel?)null)" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Common_Cancel"]</button>
                    <button type="submit" class="btn btn-primary">@Localizer["Common_Add"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

@foreach (var group in Model.BarrioGroups)
{
    <div class="modal fade" id="addBarrioModal-@group.SeasonId" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@string.Format(Localizer["CityPlanning_Admin_AddBarrioContainer"], group.CampName)</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="CreateBarrioContainer" asp-route-year="@Model.Year" asp-route-seasonId="@group.SeasonId"
                      method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <partial name="_ContainerFormFields" model="@((Humans.Web.Models.ContainerViewModel?)null)" />
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Common_Cancel"]</button>
                        <button type="submit" class="btn btn-primary">@Localizer["Common_Add"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@foreach (var c in Model.OrgContainers.Concat(Model.BarrioGroups.SelectMany(g => g.Containers)))
{
    <partial name="_ContainerCardModals" model="@CardFor(c)" />
}
