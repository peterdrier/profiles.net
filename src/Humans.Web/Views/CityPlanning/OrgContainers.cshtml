@model Humans.Web.Models.OrgContainerIndexViewModel
@{
    ViewData["Title"] = $"Containers {Model.Year}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Admin">City Planning Admin</a></li>
        <li class="breadcrumb-item active" aria-current="page">Containers @Model.Year</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Containers <small class="text-muted">@Model.Year</small></h1>
</div>

<vc:temp-data-alerts />

<div class="d-flex align-items-center gap-3 mb-4 p-3 border rounded">
    <div>
        <span class="fw-semibold me-2">Container placement:</span>
        @if (Model.IsContainerPlacementOpen)
        {
            <span class="badge bg-success">Open</span>
        }
        else
        {
            <span class="badge bg-secondary">Closed</span>
        }
    </div>
    @if (Model.IsContainerPlacementOpen)
    {
        <form method="post" asp-action="CloseContainerPlacement">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning btn-sm">
                <i class="fa-solid fa-lock me-1"></i> Close
            </button>
        </form>
    }
    else
    {
        <form method="post" asp-action="OpenContainerPlacement">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-sm">
                <i class="fa-solid fa-lock-open me-1"></i> Open
            </button>
        </form>
    }
</div>

@* ── Org containers ──────────────────────────────────────────────────── *@
<div class="d-flex align-items-center gap-2 mb-3">
    <h2 class="h4 mb-0">Org Containers</h2>
    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addOrgModal">
        <i class="fa-solid fa-plus me-1"></i> Add
    </button>
</div>

@if (Model.OrgContainers.Count == 0)
{
    <div class="alert alert-secondary mb-4">No org-level containers for @Model.Year yet.</div>
}
else
{
    <ul class="list-group mb-4">
        @foreach (var c in Model.OrgContainers)
        {
            <li class="list-group-item d-flex align-items-center gap-3 py-2">
                <div style="width:48px;height:48px;flex-shrink:0;" class="d-flex align-items-center justify-content-center">
                    @if (c.ImageUrl is not null)
                    {
                        <img src="@c.ImageUrl" alt="@c.Name"
                             style="width:48px;height:48px;object-fit:cover;border-radius:4px;cursor:pointer;"
                             data-bs-toggle="modal" data-bs-target="#lightboxModal-@c.Id" />
                    }
                    else
                    {
                        <i class="fa-solid fa-box text-muted fa-lg"></i>
                    }
                </div>
                <div class="flex-grow-1 min-width-0">
                    <div class="fw-semibold">@c.Name</div>
                    @if (!string.IsNullOrEmpty(c.Description))
                    {
                        <div class="text-muted small">@c.Description</div>
                    }
                </div>
                <div class="d-flex gap-1 flex-shrink-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            data-bs-toggle="modal" data-bs-target="#editModal-@c.Id"
                            title="Edit">
                        <i class="fa-solid fa-pen"></i>
                    </button>
                    @if (c.ImageUrl is null)
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                data-bs-toggle="modal" data-bs-target="#imageModal-@c.Id"
                                title="Upload image">
                            <i class="fa-solid fa-image"></i>
                        </button>
                    }
                    else
                    {
                        <form asp-action="DeleteOrgContainerImage" asp-route-id="@c.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-warning btn-sm"
                                    data-confirm="Remove image from @c.Name?"
                                    title="Remove image">
                                <i class="fa-solid fa-image"></i>
                            </button>
                        </form>
                    }
                    <form asp-action="DeleteOrgContainer" asp-route-id="@c.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm"
                                data-confirm="Delete container @c.Name?"
                                title="Delete">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </form>
                </div>
            </li>
        }
    </ul>
}

@* ── Barrio containers ───────────────────────────────────────────────── *@
<h2 class="h4 mb-3 mt-2">Barrio Containers</h2>

@foreach (var group in Model.BarrioGroups)
{
    <div class="d-flex align-items-center gap-2 mt-4 mb-2">
        <h3 class="h5 mb-0">@group.CampName</h3>
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addBarrioModal-@group.SeasonId">
            <i class="fa-solid fa-plus me-1"></i> Add
        </button>
    </div>

    @if (group.Containers.Count == 0)
    {
        <div class="alert alert-secondary mb-3">No containers for @group.CampName yet.</div>
    }
    else
    {
        <ul class="list-group mb-3">
            @foreach (var c in group.Containers)
            {
                <li class="list-group-item d-flex align-items-center gap-3 py-2">
                    <div style="width:48px;height:48px;flex-shrink:0;" class="d-flex align-items-center justify-content-center">
                        @if (c.ImageUrl is not null)
                        {
                            <img src="@c.ImageUrl" alt="@c.Name"
                                 style="width:48px;height:48px;object-fit:cover;border-radius:4px;cursor:pointer;"
                                 data-bs-toggle="modal" data-bs-target="#lightboxModal-@c.Id" />
                        }
                        else
                        {
                            <i class="fa-solid fa-box text-muted fa-lg"></i>
                        }
                    </div>
                    <div class="flex-grow-1 min-width-0">
                        <div class="fw-semibold">@c.Name</div>
                        @if (!string.IsNullOrEmpty(c.Description))
                        {
                            <div class="text-muted small">@c.Description</div>
                        }
                    </div>
                    <div class="d-flex gap-1 flex-shrink-0">
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                data-bs-toggle="modal" data-bs-target="#editModal-@c.Id"
                                title="Edit">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        @if (c.ImageUrl is null)
                        {
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    data-bs-toggle="modal" data-bs-target="#imageModal-@c.Id"
                                    title="Upload image">
                                <i class="fa-solid fa-image"></i>
                            </button>
                        }
                        else
                        {
                            <form asp-action="DeleteOrgContainerImage" asp-route-id="@c.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-warning btn-sm"
                                        data-confirm="Remove image from @c.Name?"
                                        title="Remove image">
                                    <i class="fa-solid fa-image"></i>
                                </button>
                            </form>
                        }
                        <form asp-action="DeleteOrgContainer" asp-route-id="@c.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                    data-confirm="Delete container @c.Name?"
                                    title="Delete">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </li>
            }
        </ul>
    }
}

@* ── Modals ──────────────────────────────────────────────────────────── *@

<div class="modal fade" id="addOrgModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Org Container</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateOrgContainer" asp-route-year="@Model.Year" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input name="Name" class="form-control" maxlength="256" required placeholder="e.g. Storage Container A" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="Description" class="form-control" rows="3" maxlength="2000" placeholder="Size, type, location…"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add</button>
                </div>
            </form>
        </div>
    </div>
</div>

@foreach (var group in Model.BarrioGroups)
{
    <div class="modal fade" id="addBarrioModal-@group.SeasonId" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Container — @group.CampName</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="CreateBarrioContainer" asp-route-year="@Model.Year" asp-route-seasonId="@group.SeasonId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input name="Name" class="form-control" maxlength="256" required placeholder="e.g. Shipping Container #1" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="Description" class="form-control" rows="3" maxlength="2000" placeholder="Size, type, special requirements…"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@foreach (var c in Model.OrgContainers.Concat(Model.BarrioGroups.SelectMany(g => g.Containers)))
{
    @if (c.ImageUrl is not null)
    {
        <div class="modal fade" id="lightboxModal-@c.Id" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@c.Name</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-0 text-center">
                        <img src="@c.ImageUrl" alt="@c.Name" class="img-fluid" />
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="modal fade" id="editModal-@c.Id" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Container</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="EditOrgContainer" asp-route-id="@c.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input name="Name" class="form-control" value="@c.Name" maxlength="256" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="Description" class="form-control" rows="3" maxlength="2000">@c.Description</textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (c.ImageUrl is null)
    {
        <div class="modal fade" id="imageModal-@c.Id" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Upload Image — @c.Name</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="UploadOrgContainerImage" asp-route-id="@c.Id"
                          method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Image file (JPEG, PNG, or WebP — max 10 MB)</label>
                                <input type="file" name="file" class="form-control" accept="image/jpeg,image/png,image/webp" required />
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Upload</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}
