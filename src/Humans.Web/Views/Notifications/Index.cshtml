@model Humans.Web.Models.NotificationInboxViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Notification_PageTitle"];
}

<h1>@Localizer["Notification_PageTitle"]</h1>

<div class="notification-toolbar mb-3">
    <form method="get" asp-action="Index" class="notification-search-form">
        <input type="hidden" name="filter" value="@Model.ActiveFilter" />
        <input type="hidden" name="tab" value="@Model.ActiveTab" />
        <div class="input-group input-group-sm">
            <input type="text" name="search" class="form-control" value="@Model.SearchTerm"
                   placeholder="@Localizer["Notification_SearchPlaceholder"]" />
            <button type="submit" class="btn btn-outline-secondary">
                <i class="fa-solid fa-search"></i>
            </button>
        </div>
    </form>
    <div class="notification-filter-pills">
        @{
            var filters = new[] {
                ("all", Localizer["Notification_Filter_All"].Value),
                ("action", Localizer["Notification_Filter_NeedsAction"].Value),
                ("shifts", Localizer["Notification_Filter_Shifts"].Value),
                ("approvals", Localizer["Notification_Filter_Approvals"].Value),
                ("resolved", Localizer["Notification_Filter_Resolved"].Value)
            };
        }
        @foreach (var (value, label) in filters)
        {
            var active = string.Equals(Model.ActiveFilter, value, StringComparison.OrdinalIgnoreCase);
            <a href="@Url.Action("Index", new { filter = value, tab = Model.ActiveTab, search = Model.SearchTerm })"
               class="btn btn-sm @(active ? "btn-primary" : "btn-outline-secondary") notification-filter-pill">
                @label
            </a>
        }
    </div>
</div>

<!-- Bulk action toolbar (hidden until items selected) -->
<div class="notification-bulk-toolbar mb-2" id="bulkToolbar" style="display: none;">
    <span class="notification-bulk-count" id="bulkCount"
          data-template="@Localizer["Notification_Bulk_Selected"]">@string.Format(Localizer["Notification_Bulk_Selected"].Value, 0)</span>
    <button type="button" class="btn btn-sm btn-outline-primary" id="bulkResolveBtn">@Localizer["Notification_Bulk_Resolve"]</button>
    <button type="button" class="btn btn-sm btn-outline-secondary" id="bulkDismissBtn">@Localizer["Notification_Bulk_Dismiss"]</button>
</div>

<div class="card notification-inbox-card">
    <div class="notification-inbox-header">
        <div class="d-flex align-items-center gap-2">
            <i class="fa-solid fa-bell"></i>
            <span>@Localizer["Notification_Inbox_Title"]</span>
            @if (Model.UnreadCount > 0)
            {
                <span class="badge rounded-pill bg-danger">@Model.UnreadCount</span>
            }
        </div>
        <div class="notification-tab-toggle">
            @{
                var unreadActive = string.Equals(Model.ActiveTab, "unread", StringComparison.OrdinalIgnoreCase);
            }
            <a href="@Url.Action("Index", new { filter = Model.ActiveFilter, tab = "unread", search = Model.SearchTerm })"
               class="notification-tab @(unreadActive ? "active" : "")">@Localizer["Notification_Tab_Unread"]</a>
            <a href="@Url.Action("Index", new { filter = Model.ActiveFilter, tab = "all", search = Model.SearchTerm })"
               class="notification-tab @(!unreadActive ? "active" : "")">@Localizer["Notification_Tab_All"]</a>
        </div>
    </div>

    <div class="notification-inbox-body" id="notificationInboxBody">
        @if (Model.Meters.Count == 0 && Model.NeedsAttention.Count == 0 && Model.Informational.Count == 0 && Model.Resolved.Count == 0)
        {
            <div class="notification-empty-state">
                <i class="fa-solid fa-bell notification-empty-icon"></i>
                <p>@Localizer["Notification_Popup_CaughtUp"]</p>
            </div>
        }
        else
        {
            @if (Model.Meters.Count > 0)
            {
                <div class="notification-section-label">@Localizer["Notification_Section_WorkQueues"]</div>
                @foreach (var meter in Model.Meters)
                {
                    <div class="notification-meter-row">
                        <div class="notification-meter-info">
                            <span class="notification-meter-title">@meter.Title</span>
                            <span class="badge rounded-pill bg-warning text-dark notification-meter-badge">@meter.Count</span>
                        </div>
                        <a href="@meter.ActionUrl" class="btn btn-sm btn-outline-primary notification-meter-action">
                            @Localizer["Notification_DefaultActionLabel"]
                        </a>
                    </div>
                }
            }
            @if (Model.NeedsAttention.Count > 0)
            {
                <div class="notification-section-label">@Localizer["Notification_Section_NeedsAttention"]</div>
                @foreach (var item in Model.NeedsAttention)
                {
                    <div class="notification-row-wrapper d-flex align-items-start">
                        <div class="notification-checkbox-col">
                            <input type="checkbox" class="form-check-input notification-select"
                                   data-notification-id="@item.Id" data-notification-class="actionable"
                                   aria-label="Select notification" />
                        </div>
                        <div class="flex-grow-1">
                            <partial name="_NotificationRow" model="item" />
                        </div>
                    </div>
                }
            }
            @if (Model.Informational.Count > 0)
            {
                <div class="notification-section-label">@Localizer["Notification_Section_Informational"]</div>
                @foreach (var item in Model.Informational)
                {
                    <div class="notification-row-wrapper d-flex align-items-start">
                        <div class="notification-checkbox-col">
                            <input type="checkbox" class="form-check-input notification-select"
                                   data-notification-id="@item.Id" data-notification-class="informational"
                                   aria-label="Select notification" />
                        </div>
                        <div class="flex-grow-1">
                            <partial name="_NotificationRow" model="item" />
                        </div>
                    </div>
                }
            }
            @if (Model.Resolved.Count > 0)
            {
                <div class="notification-section-label">@Localizer["Notification_Section_Resolved"]</div>
                @foreach (var item in Model.Resolved)
                {
                    <partial name="_NotificationRow" model="item" />
                }
            }
        }
    </div>

    <div class="notification-inbox-footer">
        <form method="post" asp-controller="Notifications" asp-action="MarkAllRead">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-secondary">
                @Localizer["Notification_MarkAllRead"]
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script>
(function() {
    // Bulk selection
    var toolbar = document.getElementById('bulkToolbar');
    var countEl = document.getElementById('bulkCount');
    var resolveBtn = document.getElementById('bulkResolveBtn');
    var dismissBtn = document.getElementById('bulkDismissBtn');

    function getSelected() {
        return Array.from(document.querySelectorAll('.notification-select:checked'));
    }

    function updateBulkToolbar() {
        var selected = getSelected();
        if (selected.length === 0) {
            toolbar.style.display = 'none';
            return;
        }
        toolbar.style.display = 'flex';
        countEl.textContent = countEl.dataset.template.replace('{0}', selected.length);

        var hasActionable = selected.some(function(cb) { return cb.dataset.notificationClass === 'actionable'; });
        var hasInformational = selected.some(function(cb) { return cb.dataset.notificationClass === 'informational'; });
        resolveBtn.style.display = hasActionable ? '' : 'none';
        dismissBtn.style.display = hasInformational ? '' : 'none';
    }

    document.querySelectorAll('.notification-select').forEach(function(cb) {
        cb.addEventListener('change', updateBulkToolbar);
    });

    function getAntiForgeryToken() {
        var input = document.querySelector('input[name="__RequestVerificationToken"]');
        return input ? input.value : '';
    }

    function bulkAction(url, filterClass) {
        var selected = getSelected().filter(function(cb) {
            return cb.dataset.notificationClass === filterClass;
        });
        if (selected.length === 0) return;

        var formData = new FormData();
        formData.append('__RequestVerificationToken', getAntiForgeryToken());
        selected.forEach(function(cb) {
            formData.append('selectedIds', cb.dataset.notificationId);
        });

        fetch(url, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: formData
        }).then(function(r) {
            if (r.ok) {
                selected.forEach(function(cb) {
                    var wrapper = cb.closest('.notification-row-wrapper');
                    if (wrapper) wrapper.remove();
                });
                updateBulkToolbar();
            }
        });
    }

    if (resolveBtn) {
        resolveBtn.addEventListener('click', function() {
            bulkAction('@Url.Action("BulkResolve", "Notifications")', 'actionable');
        });
    }
    if (dismissBtn) {
        dismissBtn.addEventListener('click', function() {
            bulkAction('@Url.Action("BulkDismiss", "Notifications")', 'informational');
        });
    }

    // Keyboard navigation for inbox rows
    var body = document.getElementById('notificationInboxBody');
    if (body) {
        body.addEventListener('keydown', function(e) {
            if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
                var rows = Array.from(body.querySelectorAll('.notification-row'));
                var current = document.activeElement ? document.activeElement.closest('.notification-row') : null;
                var idx = current ? rows.indexOf(current) : -1;
                var next = e.key === 'ArrowDown' ? idx + 1 : idx - 1;
                if (next >= 0 && next < rows.length) {
                    var focusable = rows[next].querySelector('a, button, input[type="checkbox"]');
                    if (focusable) focusable.focus();
                    e.preventDefault();
                }
            } else if (e.key === 'Enter') {
                var row = document.activeElement ? document.activeElement.closest('.notification-row') : null;
                if (row) {
                    var actionBtn = row.querySelector('.notification-action-btn, .notification-text-link');
                    if (actionBtn) actionBtn.click();
                }
            }
        });
    }
})();
</script>
}
