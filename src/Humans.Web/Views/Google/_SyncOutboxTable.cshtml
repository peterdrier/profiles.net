@model IList<Humans.Application.Interfaces.GoogleIntegration.GoogleSyncOutboxEventSnapshot>
@{
    var googleEmailLookup = (Dictionary<Guid, string>)ViewData["GoogleEmailLookup"]!;
    var displayNameLookup = (Dictionary<Guid, string>)ViewData["DisplayNameLookup"]!;
    var teamLookup = (Dictionary<Guid, string>)ViewData["TeamLookup"]!;
    var resourceLookup = (Dictionary<Guid, List<string>>)ViewData["ResourceLookup"]!;
    var showError = (bool)ViewData["ShowError"]!;
}

@if (Model.Count == 0)
{
    <div class="text-muted text-center py-4">No events.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
            <thead>
                <tr>
                    <th>Event Type</th>
                    <th>Human</th>
                    <th>Google Email</th>
                    <th>Team</th>
                    <th>Resource</th>
                    <th>Occurred</th>
                    <th>Retries</th>
                    @if (showError)
                    {
                        <th>Last Error</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var evt in Model)
                {
                    var googleEmail = googleEmailLookup.GetValueOrDefault(evt.UserId, "unknown");
                    var teamName = teamLookup.GetValueOrDefault(evt.TeamId, evt.TeamId.ToString());
                    var resources = resourceLookup.GetValueOrDefault(evt.TeamId);
                    <tr>
                        <td><code>@evt.EventType</code></td>
                        <td>
                            <vc:human user-id="@evt.UserId" link="Admin" />
                        </td>
                        <td><small class="text-muted">@googleEmail</small></td>
                        <td>@teamName</td>
                        <td>
                            @if (resources is { Count: > 0 })
                            {
                                @foreach (var resource in resources)
                                {
                                    <div><small>@resource</small></div>
                                }
                            }
                            else
                            {
                                <small class="text-muted">-</small>
                            }
                        </td>
                        <td class="text-nowrap">@evt.OccurredAt.ToDisplayDateTime()</td>
                        <td>
                            @if (evt.RetryCount > 0)
                            {
                                <span class="badge bg-secondary">@evt.RetryCount</span>
                            }
                        </td>
                        @if (showError)
                        {
                            <td>
                                @if (!string.IsNullOrEmpty(evt.LastError))
                                {
                                    <small class="text-danger" title="@evt.LastError">
                                        @(evt.LastError.Length > 120 ? evt.LastError[..120] + "..." : evt.LastError)
                                    </small>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
