@using Humans.Application.Interfaces.Profiles
@model IReadOnlyList<UserEmailFlagViolation>
@{
    ViewData["Title"] = "Email flag violations";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h1>Email flag violations</h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to Google
        </a>
    </div>

    <vc:temp-data-alerts />

    <p class="text-muted">Users whose email rows violate the at-most-one IsGoogle / exactly-one IsPrimary invariants. Open each user's email grid to remediate.</p>

    @if (Model.Count == 0)
    {
        <div class="alert alert-success">
            <i class="fa-solid fa-check-circle me-1"></i>No invariant violations found. All users have at most one Google identity row and exactly one primary verified email.
        </div>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>IsGoogle rows</th>
                            <th>Verified rows</th>
                            <th>Primary verified rows</th>
                            <th>Issue</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var v in Model)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Profile" asp-action="AdminDetail" asp-route-id="@v.UserId">
                                    @(string.IsNullOrWhiteSpace(v.DisplayName) ? v.UserId.ToString() : v.DisplayName)
                                </a>
                            </td>
                            <td>
                                @if (v.HasMultipleGoogle)
                                {
                                    <span class="badge bg-danger">@v.IsGoogleCount</span>
                                }
                                else
                                {
                                    <span class="text-muted">@v.IsGoogleCount</span>
                                }
                            </td>
                            <td><span class="text-muted">@v.VerifiedCount</span></td>
                            <td>
                                @if (v.HasPrimaryProblem)
                                {
                                    <span class="badge bg-warning text-dark">@v.VerifiedPrimaryCount</span>
                                }
                                else
                                {
                                    <span class="text-muted">@v.VerifiedPrimaryCount</span>
                                }
                            </td>
                            <td>
                                @if (v.HasMultipleGoogle)
                                {
                                    <div><i class="fa-brands fa-google me-1 text-danger"></i>Multiple Google rows</div>
                                }
                                @if (v.HasPrimaryProblem)
                                {
                                    <div>
                                        <i class="fa-solid fa-star me-1 text-warning"></i>
                                        @if (v.VerifiedPrimaryCount == 0)
                                        {
                                            <text>No primary among verified rows</text>
                                        }
                                        else
                                        {
                                            <text>Multiple primary verified rows</text>
                                        }
                                    </div>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-controller="Profile" asp-action="AdminEmails" asp-route-id="@v.UserId" class="btn btn-outline-primary btn-sm">
                                    <i class="fa-solid fa-envelope me-1"></i>Open admin emails
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
