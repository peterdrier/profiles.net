@model Humans.Web.Models.CampDetailViewModel
@{
    ViewData["Title"] = Model.Name;
    var isCityPlanningMember = ViewBag.IsCityPlanningTeamMember as bool? ?? false;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">@Localizer["Camp_Plural"]</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
    </ol>
</nav>

<vc:temp-data-alerts />

<div class="row">
    <div class="col-md-8">
        @* Image carousel *@
        @if (Model.ImageUrls.Count > 0)
        {
            if (Model.ImageUrls.Count == 1)
            {
                <img src="@Model.ImageUrls[0]" class="img-fluid rounded mb-4" alt="@Model.Name"
                     style="width: 100%; max-height: 400px; object-fit: cover;" />
            }
            else
            {
                <div id="campCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
                    <div class="carousel-indicators">
                        @for (var i = 0; i < Model.ImageUrls.Count; i++)
                        {
                            <button type="button" data-bs-target="#campCarousel" data-bs-slide-to="@i"
                                    class="@(i == 0 ? "active" : "")" aria-label="Slide @(i + 1)"></button>
                        }
                    </div>
                    <div class="carousel-inner">
                        @for (var i = 0; i < Model.ImageUrls.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@Model.ImageUrls[i]" class="d-block w-100 rounded" alt="@Model.Name"
                                     style="max-height: 400px; object-fit: cover;" />
                            </div>
                        }
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#campCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#campCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            }
        }

        @* Camp name and badges *@
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h1 class="mb-1">@Model.Name</h1>
                @if (Model.CurrentSeason != null)
                {
                    <p class="mb-1">
                        <a asp-action="SeasonDetails" asp-route-slug="@Model.Slug" asp-route-year="@Model.CurrentSeason.Year" class="link-secondary">
                            View @Model.CurrentSeason.Year season page
                        </a>
                    </p>
                }
                @if (Model.HistoricalNames.Count > 0 && !Model.HideHistoricalNames)
                {
                    <p class="text-muted mb-0">
                        <i class="fa-solid fa-clock-rotate-left me-1"></i>
                        Also known as: @string.Join(", ", Model.HistoricalNames)
                    </p>
                }
            </div>
            <div class="d-flex gap-1">
                @if (Model.IsSwissCamp)
                {
                    <span class="badge bg-danger fs-6">
                        <i class="fa-solid fa-flag me-1"></i>Swiss Camp
                    </span>
                }
                @if (Model.CurrentSeason?.Status == CampSeasonStatus.Full)
                {
                    <span class="badge bg-warning text-dark fs-6">Full</span>
                }
            </div>
        </div>

        @* Season details *@
        @if (Model.CurrentSeason != null)
        {
            var season = Model.CurrentSeason;

            @* Blurb *@
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fa-solid fa-pen-fancy me-1"></i> About
                </div>
                <div class="card-body">
                    @Html.SanitizedMarkdown(season.BlurbLong)
                </div>
            </div>

            @* Community info *@
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fa-solid fa-users me-1"></i> Community
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl>
                                <dt>Languages</dt>
                                <dd>@season.Languages</dd>
                                <dt>Accepting Humans</dt>
                                <dd>@season.AcceptingMembers</dd>
                                <dt>Kids Welcome</dt>
                                <dd>@season.KidsWelcome</dd>
                                @if (season.KidsWelcome != YesNoMaybe.No)
                                {
                                    <dt>Kids Visiting</dt>
                                    <dd>@season.KidsVisiting</dd>
                                    @if (!string.IsNullOrEmpty(season.KidsAreaDescription))
                                    {
                                        <dt>Kids Area</dt>
                                        <dd>@Html.SanitizedMarkdown(season.KidsAreaDescription)</dd>
                                    }
                                }
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl>
                                <dt>Adult Playspace</dt>
                                <dd>@season.AdultPlayspace</dd>
                                <dt>Expected Humans</dt>
                                <dd>@season.MemberCount</dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>

            @* Vibes *@
            @if (season.Vibes.Count > 0)
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="fa-solid fa-heart-pulse me-1"></i> Vibes
                    </div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var vibe in season.Vibes)
                            {
                                <span class="badge bg-secondary fs-6">@vibe</span>
                            }
                        </div>
                    </div>
                </div>
            }

            @* Performance & Culture *@
            @if (season.HasPerformanceSpace != PerformanceSpaceStatus.No || !string.IsNullOrEmpty(season.PerformanceTypes))
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="fa-solid fa-masks-theater me-1"></i> Culture & Events
                    </div>
                    <div class="card-body">
                        <dl>
                            <dt>Performance Space</dt>
                            <dd>@season.HasPerformanceSpace</dd>
                            @if (!string.IsNullOrEmpty(season.PerformanceTypes))
                            {
                                <dt>Performance Types</dt>
                                <dd>@season.PerformanceTypes</dd>
                            }
                        </dl>
                    </div>
                </div>
            }

            @* Placement data (visible to leads, CampAdmins, and city planning team) *@
            @if (Model.IsCurrentUserLead || Model.IsCurrentUserCampAdmin || isCityPlanningMember)
            {
                var isPlacementOpen = ViewBag.PlacementIsOpen as bool? ?? false;
                NodaTime.LocalDateTime? placementOpensAt = ViewBag.PlacementOpensAt;
                NodaTime.LocalDateTime? placementClosesAt = ViewBag.PlacementClosesAt;
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fa-solid fa-map-location-dot me-1"></i> Placement</span>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted small">@Localizer["CityPlanning_PlacementPhase"]:</span>
                            @if (isPlacementOpen)
                            {
                                <span class="badge bg-success">@Localizer["CityPlanning_StatusOpen"]</span>
                                <a asp-controller="CityPlanning" asp-action="BarrioMap" class="btn btn-sm btn-outline-primary">
                                    <i class="fa-solid fa-map me-1"></i> @Localizer["CityPlanning_GoToPlacementMap"]
                                </a>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Localizer["CityPlanning_StatusClosed"]</span>
                            }
                            <button type="button" class="btn btn-link btn-sm p-0"
                                    data-bs-toggle="modal" data-bs-target="#placement-help-modal"
                                    title="@Localizer["CityPlanning_PlacementPhaseInfo"]">
                                <i class="fa-solid fa-circle-info text-muted"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <dl>
                                    @if (season.SoundZone.HasValue)
                                    {
                                        <dt>Sound Zone</dt>
                                        <dd><span class="badge bg-info">@season.SoundZone</span></dd>
                                    }
                                    @if (season.SpaceRequirement.HasValue)
                                    {
                                        <dt>Space Requirement</dt>
                                        <dd>@season.SpaceRequirement</dd>
                                    }
                                    @if (Model.IsCurrentUserLead || Model.IsCurrentUserCampAdmin)
                                    {
                                        <dt>Containers</dt>
                                        <dd><a asp-controller="Container" asp-action="Index"
                                               asp-route-slug="@Model.Slug" asp-route-year="@season.Year">Manage containers →</a></dd>
                                    }
                                </dl>
                            </div>
                            <div class="col-md-6">
                                <dl>
                                    @if (season.ElectricalGrid.HasValue)
                                    {
                                        <dt>Electrical Grid</dt>
                                        <dd>@season.ElectricalGrid</dd>
                                    }
                                </dl>
                            </div>
                        </div>
                    </div>
                </div>
                @await Html.PartialAsync("~/Views/CityPlanning/_PlacementHelpModal.cshtml", (placementOpensAt, placementClosesAt))
            }
        }
    </div>

    <div class="col-md-4">
        @* Links & Contact *@
        <div class="card mb-4">
            <div class="card-header">
                <i class="fa-solid fa-link me-1"></i> @Localizer["Camp_Links_Header"]
            </div>
            <div class="card-body">
                @if (Model.Links.Count > 0)
                {
                    <div class="mb-3">
                        @foreach (var link in Model.Links)
                        {
                            var platform = Humans.Domain.Helpers.PlatformDetector.Detect(link.Url);
                            <div class="mb-2">
                                <a href="@link.Url" target="_blank" rel="noopener noreferrer">
                                    <i class="@platform.IconClass me-1"></i> @platform.Name
                                </a>
                            </div>
                        }
                    </div>
                }
                <hr />
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-action="Contact" asp-route-slug="@Model.Slug" class="btn btn-primary w-100">
                        <i class="fa-solid fa-envelope me-1"></i> @Localizer["Camp_ContactButton"]
                    </a>
                }
                else
                {
                    <div class="text-center text-muted">
                        <i class="fa-solid fa-envelope me-1"></i> @Localizer["Camp_ContactLoginHint"]
                    </div>
                }
            </div>
        </div>

        @* Times participating *@
        @if (Model.TimesAtNowhere > 0)
        {
            <div class="card mb-4">
                <div class="card-body text-center">
                    <i class="fa-solid fa-fire fa-2x text-warning mb-2"></i>
                    <h5>@Model.TimesAtNowhere year@(Model.TimesAtNowhere != 1 ? "s" : "") participating</h5>
                </div>
            </div>
        }

        @* Leads (only if authenticated) *@
        @if (User.Identity?.IsAuthenticated == true && Model.Leads.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fa-solid fa-user-shield me-1"></i> Leads
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var lead in Model.Leads)
                    {
                        <li class="list-group-item">
                            <vc:human user-id="@lead.UserId" />
                        </li>
                    }
                </ul>
            </div>
        }

        @* My membership (authenticated only — never shown to anonymous visitors) *@
        @if (User.Identity?.IsAuthenticated == true && Model.Membership.Status != CampMemberStatusSummaryView.NoOpenSeason)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fa-solid fa-campground me-1"></i> My membership
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-2">
                        This does <strong>not</strong> join you to the camp. Join through the camp's own process first, then tell Humans so you get access to any per-camp roles, Early Entry allocations, and notifications.
                    </p>
                    @switch (Model.Membership.Status)
                    {
                        case CampMemberStatusSummaryView.None:
                            @if (Model.IsCurrentUserLead)
                            {
                                @* Leads are part of the camp by definition — don't prompt them to "request to join". *@
                                <div class="alert alert-info py-2 mb-0">
                                    <i class="fa-solid fa-user-shield me-1"></i>
                                    You are a lead for @Model.Membership.OpenSeasonYear.
                                </div>
                            }
                            else
                            {
                                <form asp-controller="Camp" asp-action="RequestMembership" asp-route-slug="@Model.Slug" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-primary w-100">
                                        <i class="fa-solid fa-hand me-1"></i> Request to join for @Model.Membership.OpenSeasonYear
                                    </button>
                                </form>
                            }
                            break;
                        case CampMemberStatusSummaryView.Pending:
                            <div class="d-grid gap-2">
                                <div class="alert alert-warning py-2 mb-0">
                                    <i class="fa-solid fa-hourglass-half me-1"></i> Pending lead approval for @Model.Membership.OpenSeasonYear.
                                </div>
                                <form asp-controller="Camp" asp-action="WithdrawMembershipRequest" asp-route-slug="@Model.Slug" asp-route-campMemberId="@Model.Membership.CampMemberId" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-secondary w-100" data-confirm="Withdraw your pending request?">
                                        <i class="fa-solid fa-xmark me-1"></i> Withdraw request
                                    </button>
                                </form>
                            </div>
                            break;
                        case CampMemberStatusSummaryView.Active:
                            <div class="d-grid gap-2">
                                <div class="alert alert-success py-2 mb-0">
                                    <i class="fa-solid fa-check me-1"></i> You are a member for @Model.Membership.OpenSeasonYear.
                                </div>
                                <form asp-controller="Camp" asp-action="LeaveMembership" asp-route-slug="@Model.Slug" asp-route-campMemberId="@Model.Membership.CampMemberId" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-warning w-100" data-confirm="Leave this camp for this season?">
                                        <i class="fa-solid fa-right-from-bracket me-1"></i> Leave camp
                                    </button>
                                </form>
                            </div>
                            break;
                    }
                </div>
            </div>
        }

        @* Actions *@
        @if (Model.IsCurrentUserLead || Model.IsCurrentUserCampAdmin)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fa-solid fa-gear me-1"></i> Actions
                </div>
                <div class="card-body d-grid gap-2">
                    <a asp-action="Edit" asp-route-slug="@Model.Slug" class="btn btn-outline-primary">
                        <i class="fa-solid fa-pen-to-square me-1"></i>
                        @if (Model.IsCurrentUserLead)
                        {
                            <text>Edit @Localizer["Camp_Singular"] / Assign roles</text>
                        }
                        else
                        {
                            <text>Edit @Localizer["Camp_Singular"]</text>
                        }
                    </a>
                    @if (Model.CurrentSeason != null)
                    {
                        var s = Model.CurrentSeason;
                        @if (Model.IsCurrentUserLead && (s.Status == CampSeasonStatus.Pending || s.Status == CampSeasonStatus.Active))
                        {
                            <form asp-controller="Camp" asp-action="Withdraw" asp-route-slug="@Model.Slug" asp-route-seasonId="@s.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-warning w-100" data-confirm="Are you sure you want to withdraw from this season?">
                                    <i class="fa-solid fa-right-from-bracket me-1"></i> Withdraw Season
                                </button>
                            </form>
                        }
                        @if ((Model.IsCurrentUserLead || Model.IsCurrentUserCampAdmin) && s.Status == CampSeasonStatus.Withdrawn)
                        {
                            <form asp-controller="Camp" asp-action="Rejoin" asp-route-slug="@Model.Slug" asp-route-seasonId="@s.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-success w-100">
                                    <i class="fa-solid fa-rotate-left me-1"></i> Rejoin Season
                                </button>
                            </form>
                        }
                        @if (Model.IsCurrentUserCampAdmin && s.Status == CampSeasonStatus.Full)
                        {
                            <form asp-controller="CampAdmin" asp-action="Reactivate" asp-route-seasonId="@s.Id" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="returnSlug" value="@Model.Slug" />
                                <button type="submit" class="btn btn-outline-success w-100">
                                    <i class="fa-solid fa-rotate-left me-1"></i> Reactivate Season
                                </button>
                            </form>
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>
