@model Humans.Web.Models.CampCardViewModel

<div class="col camp-card" data-camp-name="@Model.Name">
    <div class="card h-100">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Name"
                 style="height: 200px; object-fit: cover;" />
        }
        else
        {
            <div class="d-flex flex-column align-items-center justify-content-center text-muted bg-light"
                 style="height: 200px;">
                <i class="fa-solid fa-camera fa-2x mb-2"></i>
                <small>@Localizer["CampCard_NeedsPhoto"]</small>
            </div>
        }
        <div class="card-body d-flex flex-column">
            <h5 class="card-title">
                <a asp-action="Details" asp-route-slug="@Model.Slug" class="text-decoration-none stretched-link">
                    @Model.Name
                </a>
            </h5>
            @if (!string.IsNullOrEmpty(Model.BlurbShort))
            {
                <p class="card-text text-muted small">
                    @(Model.BlurbShort.Length > 150 ? string.Concat(Model.BlurbShort.AsSpan(0, 150), "...") : Model.BlurbShort)
                </p>
            }
            <div class="d-flex flex-wrap gap-1 mb-2">
                @foreach (var vibe in Model.Vibes)
                {
                    <span class="badge bg-secondary">@vibe</span>
                }
                @if (Model.SoundZone.HasValue)
                {
                    <span class="badge bg-info">
                        <i class="fa-solid fa-volume-high me-1"></i>@Model.SoundZone
                    </span>
                }
            </div>
            <div class="d-flex flex-wrap gap-1 mt-auto">
                @if (Model.AcceptingMembers == YesNoMaybe.Yes)
                {
                    <span class="badge bg-success">Accepting Members</span>
                }
                @if (Model.KidsWelcome == YesNoMaybe.Yes)
                {
                    <span class="badge bg-primary">
                        <i class="fa-solid fa-children me-1"></i>Kids Welcome
                    </span>
                }
                @if (Model.Status == CampSeasonStatus.Full)
                {
                    <span class="badge bg-warning text-dark">Full</span>
                }
                @if (Model.TimesAtNowhere > 0)
                {
                    <span class="badge bg-light text-dark border">
                        <i class="fa-solid fa-fire text-warning me-1"></i>@Model.TimesAtNowhere year@(Model.TimesAtNowhere != 1 ? "s" : "")
                    </span>
                }
            </div>
        </div>
    </div>
</div>
