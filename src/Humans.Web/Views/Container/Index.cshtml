@model Humans.Web.Models.ContainerIndexViewModel
@{
    ViewData["Title"] = $"Containers — {Model.CampName} {Model.Year}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Camp" asp-action="Index">@Localizer["Camp_Plural"]</a></li>
        <li class="breadcrumb-item"><a asp-controller="Camp" asp-action="Details" asp-route-slug="@Model.CampSlug">@Model.CampName</a></li>
        <li class="breadcrumb-item active" aria-current="page">Containers</li>
    </ol>
</nav>

<div class="d-flex align-items-center gap-2 mb-4">
    <h1 class="mb-0">Containers <small class="text-muted">@Model.CampName @Model.Year</small></h1>
    @if (Model.CanManage)
    {
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addContainerModal">
            <i class="fa-solid fa-plus me-1"></i> Add
        </button>
    }
</div>

<vc:temp-data-alerts />

@if (Model.Containers.Count == 0)
{
    <div class="alert alert-secondary">No containers registered for this season yet.</div>
}
else
{
    <div class="row g-3">
        @foreach (var c in Model.Containers.OrderBy(x => x.Name))
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    @if (c.ImageUrl is not null)
                    {
                        <img src="@c.ImageUrl" class="card-img-top" alt="@c.Name" style="max-height:200px;object-fit:cover;" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">@c.Name</h5>
                        @if (!string.IsNullOrEmpty(c.Description))
                        {
                            <p class="card-text text-muted small">@c.Description</p>
                        }
                    </div>
                    @if (Model.CanManage)
                    {
                        <div class="card-footer d-flex gap-2 flex-wrap">
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editModal-@c.Id">
                                <i class="fa-solid fa-pen me-1"></i> Edit
                            </button>
                            @if (c.ImageUrl is null)
                            {
                                <button type="button" class="btn btn-outline-secondary btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#imageModal-@c.Id">
                                    <i class="fa-solid fa-image me-1"></i> Upload Image
                                </button>
                            }
                            else
                            {
                                <form asp-action="DeleteImage" asp-route-slug="@Model.CampSlug" asp-route-year="@Model.Year" asp-route-id="@c.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-warning btn-sm"
                                            data-confirm="Remove image from @c.Name?">
                                        <i class="fa-solid fa-image me-1"></i> Remove Image
                                    </button>
                                </form>
                            }
                            <form asp-action="Delete" asp-route-slug="@Model.CampSlug" asp-route-year="@Model.Year" asp-route-id="@c.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                        data-confirm="Delete container @c.Name?">
                                    <i class="fa-solid fa-trash me-1"></i> Delete
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@if (Model.CanManage)
{
    <div class="modal fade" id="addContainerModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Container</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="Create" asp-route-slug="@Model.CampSlug" asp-route-year="@Model.Year" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input name="Name" class="form-control" maxlength="256" required placeholder="e.g. Shipping Container #1" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="Description" class="form-control" rows="3" maxlength="2000" placeholder="Size, type, special requirements…"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @foreach (var c in Model.Containers)
    {
        <div class="modal fade" id="editModal-@c.Id" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Container</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="Edit" asp-route-slug="@Model.CampSlug" asp-route-year="@Model.Year" asp-route-id="@c.Id" method="post">
                        @Html.AntiForgeryToken()
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Name <span class="text-danger">*</span></label>
                                <input name="Name" class="form-control" value="@c.Name" maxlength="256" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea name="Description" class="form-control" rows="3" maxlength="2000">@c.Description</textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @* Image upload modal *@
        @if (c.ImageUrl is null)
        {
            <div class="modal fade" id="imageModal-@c.Id" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Upload Image — @c.Name</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <form asp-action="UploadImage" asp-route-slug="@Model.CampSlug" asp-route-year="@Model.Year" asp-route-id="@c.Id"
                              method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label">Image file (JPEG, PNG, or WebP — max 10 MB)</label>
                                    <input type="file" name="file" class="form-control" accept="image/jpeg,image/png,image/webp" required />
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Upload</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
}
