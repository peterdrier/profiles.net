@model Humans.Web.Models.ContainerIndexViewModel
@{
    ViewData["Title"] = $"Containers — {Model.CampName} {Model.Year}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Camp" asp-action="Index">@Localizer["Camp_Plural"]</a></li>
        <li class="breadcrumb-item"><a asp-controller="Camp" asp-action="Details" asp-route-slug="@Model.CampSlug">@Model.CampName</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Localizer["Container_Breadcrumb"]</li>
    </ol>
</nav>

<div class="d-flex align-items-center gap-2 mb-4">
    <h1 class="mb-0">@Localizer["Container_Breadcrumb"] <small class="text-muted">@Model.CampName @Model.Year</small></h1>
    @if (Model.CanManage)
    {
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addContainerModal">
            <i class="fa-solid fa-plus me-1"></i> @Localizer["Common_Add"]
        </button>
    }
</div>

<vc:temp-data-alerts />

@if (!Model.CanManage && !Model.IsPlacementOpen)
{
    <div class="alert alert-info mb-3">
        <i class="fa-solid fa-lock me-1"></i>
        @Localizer["Container_PlacementClosed"]
    </div>
}

@if (Model.Containers.Count == 0)
{
    <div class="alert alert-secondary">@Localizer["Container_Empty"]</div>
}
else
{
    <ul class="list-group">
        @foreach (var c in Model.Containers.OrderBy(x => x.Name))
        {
            <li class="list-group-item d-flex align-items-center gap-3 py-2">
                <div style="width:48px;height:48px;flex-shrink:0;" class="d-flex align-items-center justify-content-center">
                    @if (c.ImageUrl is not null)
                    {
                        <img src="@c.ImageUrl" alt="@c.Name"
                             style="width:48px;height:48px;object-fit:cover;border-radius:4px;cursor:pointer;"
                             data-bs-toggle="modal" data-bs-target="#lightboxModal-@c.Id" />
                    }
                    else
                    {
                        <i class="fa-solid fa-box text-muted fa-lg"></i>
                    }
                </div>
                <div class="flex-grow-1 min-width-0">
                    <div class="fw-semibold">@c.Name</div>
                    @if (!string.IsNullOrEmpty(c.Description))
                    {
                        <div class="text-muted small">@c.Description</div>
                    }
                </div>
                @if (Model.CanManage)
                {
                    <div class="d-flex gap-1 flex-shrink-0">
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                data-bs-toggle="modal" data-bs-target="#editModal-@c.Id"
                                title="@Localizer["Common_Edit"]">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        @if (c.ImageUrl is null)
                        {
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    data-bs-toggle="modal" data-bs-target="#imageModal-@c.Id"
                                    title="@Localizer["Container_UploadImageTitle"]">
                                <i class="fa-solid fa-image"></i>
                            </button>
                        }
                        else
                        {
                            <form asp-action="DeleteImage" asp-route-slug="@Model.CampSlug" asp-route-year="@Model.Year" asp-route-id="@c.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-warning btn-sm"
                                        data-confirm="@string.Format(Localizer["Container_RemoveImageConfirm"], c.Name)"
                                        title="@Localizer["Container_RemoveImageTitle"]">
                                    <i class="fa-solid fa-image"></i>
                                </button>
                            </form>
                        }
                        <form asp-action="Delete" asp-route-slug="@Model.CampSlug" asp-route-year="@Model.Year" asp-route-id="@c.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                    data-confirm="@string.Format(Localizer["Container_DeleteConfirm"], c.Name)"
                                    title="@Localizer["Common_Delete"]">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </form>
                    </div>
                }
            </li>
        }
    </ul>
}

@* ── Modals ──────────────────────────────────────────────────────────── *@

@if (Model.CanManage)
{
    <div class="modal fade" id="addContainerModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Localizer["Container_AddModal_Title"]</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="Create" asp-route-slug="@Model.CampSlug" asp-route-year="@Model.Year" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">@Localizer["Container_FieldName"] <span class="text-danger">*</span></label>
                            <input name="Name" class="form-control" maxlength="256" required placeholder="@Localizer["Container_NamePlaceholder"]" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">@Localizer["Container_FieldDescription"]</label>
                            <textarea name="Description" class="form-control" rows="3" maxlength="2000" placeholder="@Localizer["Container_DescPlaceholder"]"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Common_Cancel"]</button>
                        <button type="submit" class="btn btn-primary">@Localizer["Common_Add"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@foreach (var c in Model.Containers)
{
    @if (c.ImageUrl is not null)
    {
        <div class="modal fade" id="lightboxModal-@c.Id" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@c.Name</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-0 text-center">
                        <img src="@c.ImageUrl" alt="@c.Name" class="img-fluid" />
                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.CanManage)
    {
        <div class="modal fade" id="editModal-@c.Id" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@Localizer["Container_EditModal_Title"]</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="Edit" asp-route-slug="@Model.CampSlug" asp-route-year="@Model.Year" asp-route-id="@c.Id" method="post">
                        @Html.AntiForgeryToken()
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">@Localizer["Container_FieldName"] <span class="text-danger">*</span></label>
                                <input name="Name" class="form-control" value="@c.Name" maxlength="256" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">@Localizer["Container_FieldDescription"]</label>
                                <textarea name="Description" class="form-control" rows="3" maxlength="2000">@c.Description</textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Common_Cancel"]</button>
                            <button type="submit" class="btn btn-primary">@Localizer["Common_Save"]</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @if (c.ImageUrl is null)
        {
            <div class="modal fade" id="imageModal-@c.Id" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">@string.Format(Localizer["Container_UploadImageModal_Title"], c.Name)</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <form asp-action="UploadImage" asp-route-slug="@Model.CampSlug" asp-route-year="@Model.Year" asp-route-id="@c.Id"
                              method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label">@Localizer["Container_ImageFileLabel"]</label>
                                    <input type="file" name="file" class="form-control" accept="image/jpeg,image/png,image/webp" required />
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Common_Cancel"]</button>
                                <button type="submit" class="btn btn-primary">@Localizer["CityPlanning_Admin_Upload"]</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
}
