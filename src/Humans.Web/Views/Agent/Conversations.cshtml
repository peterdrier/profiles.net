@using Humans.Web.Extensions
@model Humans.Web.Controllers.AgentConversationsViewModel
@{
    ViewData["Title"] = Model.IsAdminView ? "Agent Conversations" : Localizer["Agent_HistoryTitle"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">@ViewData["Title"]</h2>
    @if (Model.IsAdminView)
    {
        <a asp-controller="AdminAgent" asp-action="Settings" class="btn btn-outline-secondary btn-sm">Settings</a>
    }
</div>

@if (Model.IsAdminView)
{
    <form method="get" class="row g-2 mb-3">
        <div class="col-auto">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="refusalsOnly" value="true" @(Context.Request.Query["refusalsOnly"] == "true" ? "checked" : null) id="refusalsOnly" />
                <label class="form-check-label" for="refusalsOnly">Refusals only</label>
            </div>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-primary btn-sm">Filter</button>
        </div>
    </form>
}

@if (!Model.Rows.Any())
{
    <p class="text-muted">@Localizer["Agent_HistoryEmpty"]</p>
}
else
{
    @* width:auto + Bootstrap's table-sm — grid sizes to content rather than spanning the full column. *@
    <table class="table table-sm table-hover" style="width: auto;">
        <thead>
            <tr>
                @if (Model.IsAdminView)
                {
                    <th>Human</th>
                }
                <th>@Localizer["Agent_HistoryStarted"]</th>
                @if (Model.IsAdminView)
                {
                    <th>Locale</th>
                }
                <th class="text-end">@Localizer["Agent_HistoryMessages"]</th>
                <th>@Localizer["Agent_HistoryLastMessage"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                var conv = row.Conversation;
                <tr>
                    @if (Model.IsAdminView)
                    {
                        <td><human-link user-id="@conv.UserId" display-name="@row.DisplayName" admin="true" /></td>
                    }
                    <td class="text-nowrap">@conv.StartedAt.ToAuditMinuteTimestamp()</td>
                    @if (Model.IsAdminView)
                    {
                        <td>@conv.Locale</td>
                    }
                    <td class="text-end">@conv.MessageCount</td>
                    <td class="text-nowrap">@conv.LastMessageAt.ToAuditMinuteTimestamp()</td>
                    @* Non-admin viewers go to the user-facing transcript (issue #632) which
                       reuses the live-chat bubble style and surfaces the live user-context tail.
                       Admins keep the existing token/tool-call diagnostic view. *@
                    @if (Model.IsAdminView)
                    {
                        <td><a asp-action="ConversationDetail" asp-route-id="@conv.Id">View</a></td>
                    }
                    else
                    {
                        <td><a asp-action="Conversation" asp-route-id="@conv.Id">View</a></td>
                    }
                </tr>
            }
        </tbody>
    </table>
}
