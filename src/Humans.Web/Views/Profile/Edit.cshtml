            const languageOptions = `@Html.Raw(string.Join("", Humans.Web.Helpers.LanguageCatalog.Languages.Select(l => $"<option value=\"{l.Key}\">{l.Value} ({l.Key})</option>")))`;

            function getNextIndex() {
