@using Microsoft.AspNetCore.Authorization
@using Humans.Web.Authorization
@inject IAuthorizationService AuthService
@model Humans.Web.Models.EmailsViewModel
@{
    ViewData["Title"] = Localizer["Emails_Title"].Value;
    // N>1 violation detection: self users normally toggle exclusively, so we
    // hide Clear in the self grid. But when the data is already in violation
    // (multiple Google rows or multiple verified Primary rows), the user is
    // stuck — radios can't unselect — so expose Clear on the offending rows.
    var hasMultipleGoogle = Model.Emails.Count(e => e.IsGoogle) > 1;
    var hasMultiplePrimary = Model.Emails.Count(e => e.IsPrimary && e.IsVerified) > 1;
    // Manual verify is gated by PolicyNames.AdminOnly server-side; surface the
    // gate in the view so HumanAdmin/Board (who reach the page via
    // UserEmailOperations.Edit) don't see a button that 403s on click.
    var canManuallyVerify = Model.IsAdminContext
        && (await AuthService.AuthorizeAsync(User, PolicyNames.AdminOnly)).Succeeded;
}

<div class="row">
    <div class="col-md-8">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                @if (Model.IsAdminContext)
                {
                    <li class="breadcrumb-item"><a asp-action="AdminDetail" asp-route-id="@Model.TargetUserId">@(Model.TargetDisplayName ?? Localizer["Emails_AdminUnknownTarget"].Value)</a></li>
                }
                else
                {
                    <li class="breadcrumb-item"><a asp-action="Index">Profile</a></li>
                }
                <li class="breadcrumb-item active" aria-current="page">@Localizer["Emails_Title"]</li>
            </ol>
        </nav>

        <h1>@Localizer["Emails_Title"]</h1>

        @if (Model.IsAdminContext)
        {
            <div class="alert alert-warning d-flex align-items-center mb-3">
                <i class="fa-solid fa-user-shield me-2 fs-4"></i>
                <div>
                    @if (!string.IsNullOrWhiteSpace(Model.TargetDisplayName))
                    {
                        @string.Format(Localizer["EmailGrid_AdminContextBannerNamed"].Value, Model.TargetDisplayName)
                    }
                    else
                    {
                        @Localizer["EmailGrid_AdminContextBanner"]
                    }
                </div>
            </div>
        }
        else
        {
            <p class="text-muted">
                @Localizer["Emails_Description"]
            </p>
        }

        @if (Model.LegacyIdentityEmailColumn is not null)
        {
            <div class="alert alert-secondary d-flex align-items-start mb-3 small">
                <i class="fa-solid fa-database me-2 mt-1"></i>
                <div>
                    <strong>Legacy <code>User.Email</code> column:</strong>
                    <code>@Model.LegacyIdentityEmailColumn</code>
                    <div class="text-muted">
                        Raw AspNetIdentity column value (Admin-only diagnostic). The
                        runtime <code>User.Email</code> override returns the verified
                        primary <code>UserEmail</code> row when present, falling back
                        to this column when not.
                    </div>
                </div>
            </div>
        }

        <vc:temp-data-alerts />

        @if (!Model.IsAdminContext && Model.Emails.Any(e => e.IsPendingVerification))
        {
            <div class="alert alert-warning d-flex align-items-center mb-3">
                <i class="fa-solid fa-envelope-circle-check me-2 fs-4"></i>
                <div>
                    <strong>@Localizer["EmailGrid_VerificationPendingTitle"]</strong> — @Localizer["EmailGrid_VerificationPendingBody"]
                </div>
            </div>
        }

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">@Localizer["Emails_YourEmails"]</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.WorkspaceLockedEmailId.HasValue)
                {
                    <div class="px-3 pt-3">
                        <small class="text-muted">
                            <i class="fa-solid fa-lock me-1"></i>@Localizer["EmailGrid_WorkspaceLockedHelp"]
                        </small>
                    </div>
                }
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>@Localizer["EmailGrid_Email"]</th>
                                <th>@Localizer["EmailGrid_Status"]</th>
                                <th>@Localizer["EmailGrid_Primary"]</th>
                                <th title="@Localizer["EmailGrid_GoogleColumnTooltip"]">@Localizer["EmailGrid_Google"]</th>
                                <th>@Localizer["EmailGrid_Visibility"]</th>
                                <th class="text-end">@Localizer["EmailGrid_Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.Emails)
                        {
                            <tr>
                                <td>
                                    <code>@row.Email</code>
                                </td>
                                <td>
                                    @if (row.IsMergePending)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fa-solid fa-code-merge me-1"></i>@Localizer["EmailGrid_StatusMergePending"]
                                        </span>
                                    }
                                    else if (row.IsVerified)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fa-solid fa-check me-1"></i>@Localizer["EmailGrid_StatusVerified"]
                                        </span>
                                    }
                                    else if (row.IsPendingVerification)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fa-solid fa-clock me-1"></i>@Localizer["EmailGrid_StatusPending"]
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@Localizer["Emails_Unverified"]</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var workspaceLocked = Model.WorkspaceLockedEmailId.HasValue;
                                        var isLockedRow = workspaceLocked && Model.WorkspaceLockedEmailId == row.Id;
                                        var primaryChecked = isLockedRow ? true : row.IsPrimary;
                                        var primaryDisabled = workspaceLocked || !row.IsVerified;
                                    }
                                    @* Button-based set/clear (issue 650): radios in independent forms *@
                                    @* are not a real radio group, so a checked one cannot be unselected *@
                                    @* — admins could not recover from the duplicate-IsPrimary state.   *@
                                    @{
                                        var showClearPrimary = !isLockedRow && row.IsPrimary
                                            && (Model.IsAdminContext || hasMultiplePrimary);
                                    }
                                    @if (primaryChecked)
                                    {
                                        <span class="d-inline-flex align-items-center">
                                            <i class="fa-solid fa-circle-check text-success me-1" aria-label="@Localizer["EmailGrid_Primary"]"></i>
                                            @if (showClearPrimary)
                                            {
                                                <form asp-action="@(Model.IsAdminContext ? "AdminClearPrimary" : "ClearPrimary")"
                                                      asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                                      method="post" class="d-inline ms-1"
                                                      data-confirm="@Localizer["EmailGrid_ConfirmClearPrimary"].Value">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="emailId" value="@row.Id" />
                                                    <button type="submit" class="btn btn-link btn-sm text-muted p-0"
                                                            title="@Localizer["EmailGrid_Clear"].Value">
                                                        <i class="fa-solid fa-xmark"></i>
                                                    </button>
                                                </form>
                                            }
                                        </span>
                                    }
                                    else if (!primaryDisabled)
                                    {
                                        <form asp-action="@(Model.IsAdminContext ? "AdminSetPrimary" : "SetPrimary")"
                                              asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="emailId" value="@row.Id" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm">
                                                @Localizer["EmailGrid_SetPrimary"]
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@Localizer["Emails_VerifyFirst"]</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var googleChecked = isLockedRow ? true : row.IsGoogle;
                                        var googleDisabled = workspaceLocked || !row.IsVerified;
                                    }
                                    @{
                                        var showClearGoogle = !isLockedRow && row.IsGoogle
                                            && (Model.IsAdminContext || hasMultipleGoogle);
                                    }
                                    @if (googleChecked)
                                    {
                                        <span class="d-inline-flex align-items-center">
                                            <i class="fa-brands fa-google text-success me-1" aria-label="@Localizer["EmailGrid_Google"]"></i>
                                            @if (showClearGoogle)
                                            {
                                                <form asp-action="@(Model.IsAdminContext ? "AdminClearGoogle" : "ClearGoogle")"
                                                      asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                                      method="post" class="d-inline ms-1"
                                                      data-confirm="@Localizer["EmailGrid_ConfirmClearGoogle"].Value">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="emailId" value="@row.Id" />
                                                    <button type="submit" class="btn btn-link btn-sm text-muted p-0"
                                                            title="@Localizer["EmailGrid_Clear"].Value">
                                                        <i class="fa-solid fa-xmark"></i>
                                                    </button>
                                                </form>
                                            }
                                        </span>
                                    }
                                    else if (!googleDisabled)
                                    {
                                        <form asp-action="@(Model.IsAdminContext ? "AdminSetGoogle" : "SetGoogle")"
                                              asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="emailId" value="@row.Id" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm">
                                                @Localizer["EmailGrid_SetGoogle"]
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@Localizer["Emails_VerifyFirst"]</span>
                                    }
                                </td>
                                <td>
                                    @if (row.IsVerified)
                                    {
                                        <form asp-action="@(Model.IsAdminContext ? "AdminSetVisibility" : "SetEmailVisibility")"
                                              asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="emailId" value="@row.Id" />
                                            <select name="visibility" class="form-select form-select-sm js-auto-submit" style="width: auto; display: inline-block;">
                                                <option value="" selected="@(row.Visibility == null ? "selected" : null)">@Localizer["Emails_Visibility_Hidden"]</option>
                                                <option value="AllActiveProfiles" selected="@(row.Visibility == ContactFieldVisibility.AllActiveProfiles ? "selected" : null)">@Localizer["Emails_Visibility_AllHumans"]</option>
                                                <option value="MyTeams" selected="@(row.Visibility == ContactFieldVisibility.MyTeams ? "selected" : null)">@Localizer["Emails_Visibility_MyTeams"]</option>
                                                <option value="CoordinatorsAndBoard" selected="@(row.Visibility == ContactFieldVisibility.CoordinatorsAndBoard ? "selected" : null)">@Localizer["Emails_Visibility_CoordinatorsBoard"]</option>
                                                <option value="BoardOnly" selected="@(row.Visibility == ContactFieldVisibility.BoardOnly ? "selected" : null)">@Localizer["Emails_Visibility_BoardOnly"]</option>
                                            </select>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (canManuallyVerify && !row.IsVerified && string.IsNullOrEmpty(row.Provider))
                                    {
                                        <form asp-action="AdminVerifyEmail"
                                              asp-route-id="@Model.TargetUserId"
                                              method="post" class="d-inline me-1"
                                              data-confirm="@Localizer["EmailGrid_ConfirmAdminVerify"].Value">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="emailId" value="@row.Id" />
                                            <button type="submit" class="btn btn-outline-success btn-sm">
                                                <i class="fa-solid fa-check me-1"></i>@Localizer["EmailGrid_AdminVerify"]
                                            </button>
                                        </form>
                                    }
                                    @* Never offer a destructive action on the only remaining email — *@
                                    @* removing the last row would leave the user with no email at all, *@
                                    @* regardless of whether the row is provider-linked. *@
                                    @if (Model.Emails.Count > 1)
                                    {
                                        @if (!string.IsNullOrEmpty(row.Provider))
                                        {
                                            @if (Model.IsAdminContext)
                                            {
                                                <form asp-action="AdminUnlink"
                                                      asp-route-id="@Model.TargetUserId"
                                                      asp-route-emailId="@row.Id"
                                                      method="post" class="d-inline"
                                                      data-confirm="@Localizer["EmailGrid_ConfirmUnlink"].Value">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-warning btn-sm">
                                                        <i class="fa-solid fa-link-slash me-1"></i>@Localizer["EmailGrid_Unlink"]
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="Unlink"
                                                      asp-route-id="@row.Id"
                                                      method="post" class="d-inline"
                                                      data-confirm="@Localizer["EmailGrid_ConfirmUnlink"].Value">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-warning btn-sm">
                                                        <i class="fa-solid fa-link-slash me-1"></i>@Localizer["EmailGrid_Unlink"]
                                                    </button>
                                                </form>
                                            }
                                        }
                                        else
                                        {
                                            <form asp-action="@(Model.IsAdminContext ? "AdminDeleteEmail" : "DeleteEmail")"
                                                  asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                                  method="post" class="d-inline"
                                                  data-confirm="@Localizer["Emails_ConfirmRemove"].Value">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="emailId" value="@row.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">@Localizer["Emails_AddNew"]</h5>
            </div>
            <div class="card-body">
                @if (!Model.IsAdminContext)
                {
                    <div class="alert alert-info d-flex align-items-start mb-3">
                        <i class="fa-solid fa-circle-info me-2 fs-4"></i>
                        <div>
                            <strong>@Localizer["Emails_MergeWarningTitle"]</strong>
                            <div>@Localizer["Emails_MergeWarningBody"]</div>
                        </div>
                    </div>
                }
                <form asp-action="@(Model.IsAdminContext ? "AdminAddEmail" : "AddEmail")"
                      asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                      method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NewEmail" class="form-label"></label>
                        @if (Model.IsAdminContext)
                        {
                            <input class="form-control" type="email" name="email"
                                   placeholder="you@example.com" required />
                        }
                        else
                        {
                            <input asp-for="NewEmail" class="form-control" type="email"
                                   placeholder="you@example.com" />
                            <span asp-validation-for="NewEmail" class="text-danger"></span>
                        }
                        <div class="form-text">
                            @Localizer["Emails_VerificationWillBeSent"]
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary"
                            @((Model.IsAdminContext || Model.CanAddEmail) ? "" : "disabled")>
                        <i class="fa-solid fa-paper-plane me-1"></i>
                        @Localizer["Emails_SendVerification"]
                    </button>

                    @if (!Model.IsAdminContext && !Model.CanAddEmail)
                    {
                        <small class="text-muted ms-2">
                            @string.Format(Localizer["Emails_ResendCooldown"].Value, Model.MinutesUntilResend)
                        </small>
                    }
                </form>
            </div>
        </div>

        @if (!Model.IsAdminContext)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fa-brands fa-google me-2"></i>@Localizer["EmailGrid_LinkGoogleAccount"]</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        @Localizer["EmailGrid_LinkGoogleHelp"]
                    </p>
                    <form asp-action="Link" asp-route-provider="Google" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-primary">
                            <i class="fa-brands fa-google me-1"></i>@Localizer["EmailGrid_LinkGoogleAccount"]
                        </button>
                    </form>
                </div>
            </div>
        }

        <div class="mt-4">
            @if (Model.IsAdminContext)
            {
                <a asp-action="AdminDetail" asp-route-id="@Model.TargetUserId" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left me-1"></i>
                    @Localizer["EmailGrid_BackToAdminDetail"]
                </a>
            }
            else
            {
                <a asp-action="Edit" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left me-1"></i>
                    @Localizer["Emails_BackToEdit"]
                </a>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @* site.js has a global form[data-confirm] submit handler and a global *@
    @* js-auto-submit change handler that already cover these forms. No    *@
    @* local listeners — duplicating the handler causes double-submit.     *@
}
