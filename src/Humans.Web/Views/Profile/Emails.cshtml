@using Microsoft.AspNetCore.Authorization
@using Humans.Web.Authorization
@inject IAuthorizationService AuthService
@model Humans.Web.Models.EmailsViewModel
@{
    ViewData["Title"] = Localizer["Emails_Title"].Value;
    // N>1 violation detection: self users normally toggle exclusively, so we
    // hide Clear in the self grid. But when the data is already in violation
    // (multiple Google rows or multiple verified Primary rows), the user is
    // stuck — radios can't unselect — so expose Clear on the offending rows.
    var hasMultipleGoogle = Model.Emails.Count(e => e.IsGoogle) > 1;
    var hasMultiplePrimary = Model.Emails.Count(e => e.IsPrimary && e.IsVerified) > 1;
    // Manual verify is gated by PolicyNames.AdminOnly server-side; surface the
    // gate in the view so HumanAdmin/Board (who reach the page via
    // UserEmailOperations.Edit) don't see a button that 403s on click.
    var canManuallyVerify = Model.IsAdminContext
        && (await AuthService.AuthorizeAsync(User, PolicyNames.AdminOnly)).Succeeded;
}

<div class="row">
    <div class="col-md-8">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                @if (Model.IsAdminContext)
                {
                    <li class="breadcrumb-item"><vc:human user-id="@Model.TargetUserId" layout="Text" link="Admin" /></li>
                }
                else
                {
                    <li class="breadcrumb-item"><a asp-action="Index">Profile</a></li>
                }
                <li class="breadcrumb-item active" aria-current="page">@Localizer["Emails_Title"]</li>
            </ol>
        </nav>

        <h1>@Localizer["Emails_Title"]</h1>

        @if (Model.IsAdminContext)
        {
            <div class="alert alert-warning d-flex align-items-center mb-3">
                <i class="fa-solid fa-user-shield me-2 fs-4"></i>
                <div>
                    @if (!string.IsNullOrWhiteSpace(Model.TargetDisplayName))
                    {
                        @string.Format(Localizer["EmailGrid_AdminContextBannerNamed"].Value, Model.TargetDisplayName)
                    }
                    else
                    {
                        @Localizer["EmailGrid_AdminContextBanner"]
                    }
                </div>
            </div>
        }
        else
        {
            <p class="text-muted">
                @Localizer["Emails_Description"]
            </p>
        }

        @if (Model.LegacyIdentityEmailColumn is not null)
        {
            <div class="alert alert-secondary d-flex align-items-start mb-3 small">
                <i class="fa-solid fa-database me-2 mt-1"></i>
                <div>
                    <strong>Legacy <code>User.Email</code> column:</strong>
                    <code>@Model.LegacyIdentityEmailColumn</code>
                    <div class="text-muted">
                        Raw AspNetIdentity column value (Admin-only diagnostic). The
                        runtime <code>User.Email</code> override returns the verified
                        primary <code>UserEmail</code> row when present, falling back
                        to this column when not.
                    </div>
                </div>
            </div>
        }

        <vc:temp-data-alerts />

        @if (!Model.IsAdminContext && Model.Emails.Any(e => e.IsPendingVerification))
        {
            <div class="alert alert-warning d-flex align-items-center mb-3">
                <i class="fa-solid fa-envelope-circle-check me-2 fs-4"></i>
                <div>
                    <strong>@Localizer["EmailGrid_VerificationPendingTitle"]</strong> — @Localizer["EmailGrid_VerificationPendingBody"]
                </div>
            </div>
        }

        @* see nobodies-collective/Humans#677 — Google sync rejection banner *@
        @if (Model.GoogleEmailStatus == GoogleEmailStatus.Rejected)
        {
            <div class="alert alert-danger d-flex align-items-start mb-3">
                <i class="fa-solid fa-triangle-exclamation me-2 fs-4 mt-1"></i>
                <div>
                    <strong>@Localizer["EmailGrid_GoogleSyncRejectedTitle"]</strong>
                    @Localizer["EmailGrid_GoogleSyncRejectedBody"]
                </div>
            </div>
        }

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">@Localizer["Emails_YourEmails"]</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.WorkspaceLockedEmailId.HasValue)
                {
                    <div class="px-3 pt-3">
                        <small class="text-muted">
                            <i class="fa-solid fa-lock me-1"></i>@Localizer["EmailGrid_WorkspaceLockedHelp"]
                        </small>
                    </div>
                }
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>@Localizer["EmailGrid_Email"]</th>
                                <th>@Localizer["EmailGrid_Status"]</th>
                                <th>@Localizer["EmailGrid_Primary"]</th>
                                <th title="@Localizer["EmailGrid_GoogleColumnTooltip"]">@Localizer["EmailGrid_Google"]</th>
                                <th>@Localizer["EmailGrid_Visibility"]</th>
                                <th class="text-end">@Localizer["EmailGrid_Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.Emails)
                        {
                            <tr>
                                <td>
                                    <code>@row.Email</code>
                                    @if (row.HasOrphanProviderTag)
                                    {
                                        <div class="small text-warning">
                                            <i class="fa-solid fa-triangle-exclamation me-1"></i>
                                            Tagged with @row.Provider but no matching AspNetUserLogins row — self-heals on next OAuth sign-in.
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (row.IsMergePending)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fa-solid fa-code-merge me-1"></i>@Localizer["EmailGrid_StatusMergePending"]
                                        </span>
                                    }
                                    else if (row.IsVerified)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fa-solid fa-check me-1"></i>@Localizer["EmailGrid_StatusVerified"]
                                        </span>
                                    }
                                    else if (row.IsPendingVerification)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fa-solid fa-clock me-1"></i>@Localizer["EmailGrid_StatusPending"]
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@Localizer["Emails_Unverified"]</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var workspaceLocked = Model.WorkspaceLockedEmailId.HasValue;
                                        var isLockedRow = workspaceLocked && Model.WorkspaceLockedEmailId == row.Id;
                                        var primaryChecked = isLockedRow ? true : row.IsPrimary;
                                        var primaryDisabled = workspaceLocked || !row.IsVerified;
                                    }
                                    @* Buttons not radios (see #650): independent forms can't form a real radio group; admin needs unselect path *@
                                    @{
                                        var showClearPrimary = !isLockedRow && row.IsPrimary
                                            && hasMultiplePrimary;
                                    }
                                    @if (primaryChecked)
                                    {
                                        <span class="d-inline-flex align-items-center">
                                            <i class="fa-solid fa-circle-check text-success me-1" aria-label="@Localizer["EmailGrid_Primary"]"></i>
                                            @if (showClearPrimary)
                                            {
                                                <form asp-action="@(Model.IsAdminContext ? "AdminClearPrimary" : "ClearPrimary")"
                                                      asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                                      method="post" class="d-inline ms-1"
                                                      data-confirm="@Localizer["EmailGrid_ConfirmClearPrimary"].Value">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="emailId" value="@row.Id" />
                                                    <button type="submit" class="btn btn-link btn-sm text-muted p-0"
                                                            title="@Localizer["EmailGrid_Clear"].Value">
                                                        <i class="fa-solid fa-xmark"></i>
                                                    </button>
                                                </form>
                                            }
                                        </span>
                                    }
                                    else if (!primaryDisabled)
                                    {
                                        <form asp-action="@(Model.IsAdminContext ? "AdminSetPrimary" : "SetPrimary")"
                                              asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="emailId" value="@row.Id" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm">
                                                @Localizer["EmailGrid_SetPrimary"]
                                            </button>
                                        </form>
                                    }
                                    else if (workspaceLocked && row.IsVerified)
                                    {
                                        @* Verified but Workspace lock held elsewhere — don't claim "verify first" *@
                                        <span class="text-muted small" title="Locked by the Workspace email row">—</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@Localizer["Emails_VerifyFirst"]</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var googleChecked = isLockedRow ? true : row.IsGoogle;
                                        var googleDisabled = workspaceLocked || !row.IsVerified;
                                    }
                                    @{
                                        var showClearGoogle = !isLockedRow && row.IsGoogle
                                            && hasMultipleGoogle;
                                    }
                                    @if (googleChecked)
                                    {
                                        <span class="d-inline-flex align-items-center">
                                            <i class="fa-brands fa-google text-success me-1" aria-label="@Localizer["EmailGrid_Google"]"></i>
                                            @if (showClearGoogle)
                                            {
                                                <form asp-action="@(Model.IsAdminContext ? "AdminClearGoogle" : "ClearGoogle")"
                                                      asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                                      method="post" class="d-inline ms-1"
                                                      data-confirm="@Localizer["EmailGrid_ConfirmClearGoogle"].Value">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="emailId" value="@row.Id" />
                                                    <button type="submit" class="btn btn-link btn-sm text-muted p-0"
                                                            title="@Localizer["EmailGrid_Clear"].Value">
                                                        <i class="fa-solid fa-xmark"></i>
                                                    </button>
                                                </form>
                                            }
                                        </span>
                                    }
                                    else if (!googleDisabled)
                                    {
                                        <form asp-action="@(Model.IsAdminContext ? "AdminSetGoogle" : "SetGoogle")"
                                              asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="emailId" value="@row.Id" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm">
                                                @Localizer["EmailGrid_SetGoogle"]
                                            </button>
                                        </form>
                                    }
                                    else if (workspaceLocked && row.IsVerified)
                                    {
                                        <span class="text-muted small" title="Locked by the Workspace email row">—</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@Localizer["Emails_VerifyFirst"]</span>
                                    }
                                </td>
                                <td>
                                    @if (row.IsVerified)
                                    {
                                        <form asp-action="@(Model.IsAdminContext ? "AdminSetVisibility" : "SetEmailVisibility")"
                                              asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="emailId" value="@row.Id" />
                                            <select name="visibility" class="form-select form-select-sm js-auto-submit" style="width: auto; display: inline-block;">
                                                <option value="" selected="@(row.Visibility == null ? "selected" : null)">@Localizer["Emails_Visibility_Hidden"]</option>
                                                <option value="AllActiveProfiles" selected="@(row.Visibility == ContactFieldVisibility.AllActiveProfiles ? "selected" : null)">@Localizer["Emails_Visibility_AllHumans"]</option>
                                                <option value="MyTeams" selected="@(row.Visibility == ContactFieldVisibility.MyTeams ? "selected" : null)">@Localizer["Emails_Visibility_MyTeams"]</option>
                                                <option value="CoordinatorsAndBoard" selected="@(row.Visibility == ContactFieldVisibility.CoordinatorsAndBoard ? "selected" : null)">@Localizer["Emails_Visibility_CoordinatorsBoard"]</option>
                                                <option value="BoardOnly" selected="@(row.Visibility == ContactFieldVisibility.BoardOnly ? "selected" : null)">@Localizer["Emails_Visibility_BoardOnly"]</option>
                                            </select>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (canManuallyVerify && !row.IsVerified && string.IsNullOrEmpty(row.Provider))
                                    {
                                        <form asp-action="AdminVerifyEmail"
                                              asp-route-id="@Model.TargetUserId"
                                              method="post" class="d-inline me-1"
                                              data-confirm="@Localizer["EmailGrid_ConfirmAdminVerify"].Value">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="emailId" value="@row.Id" />
                                            <button type="submit" class="btn btn-outline-success btn-sm">
                                                <i class="fa-solid fa-check me-1"></i>@Localizer["EmailGrid_AdminVerify"]
                                            </button>
                                        </form>
                                    }
                                    @* No destructive action on the last remaining email row *@
                                    @if (Model.Emails.Count > 1)
                                    {
                                        @if (!string.IsNullOrEmpty(row.Provider))
                                        {
                                            @if (Model.IsAdminContext)
                                            {
                                                <form asp-action="AdminUnlink"
                                                      asp-route-id="@Model.TargetUserId"
                                                      asp-route-emailId="@row.Id"
                                                      method="post" class="d-inline"
                                                      data-confirm="@Localizer["EmailGrid_ConfirmUnlink"].Value">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-warning btn-sm">
                                                        <i class="fa-solid fa-link-slash me-1"></i>@Localizer["EmailGrid_Unlink"]
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="Unlink"
                                                      asp-route-id="@row.Id"
                                                      method="post" class="d-inline"
                                                      data-confirm="@Localizer["EmailGrid_ConfirmUnlink"].Value">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-warning btn-sm">
                                                        <i class="fa-solid fa-link-slash me-1"></i>@Localizer["EmailGrid_Unlink"]
                                                    </button>
                                                </form>
                                            }
                                        }
                                        @* see nobodies-collective/Humans#758 — never offer delete for the
                                           primary email (promote another first) or a ticket-linked email
                                           (removing it could disconnect the user's event ticket). Admins
                                           use the AdminDelete path which re-validates server-side. *@
                                        else if (row.IsPrimary)
                                        {
                                            <span class="text-muted small" title="@Localizer["EmailGrid_DeletePrimaryBlocked"].Value">
                                                <i class="fa-solid fa-lock me-1"></i>@Localizer["EmailGrid_DeletePrimaryBlocked"]
                                            </span>
                                        }
                                        else if (row.IsTicketLinked)
                                        {
                                            <span class="text-muted small" title="@Localizer["EmailGrid_DeleteTicketLinkedBlocked"].Value">
                                                <i class="fa-solid fa-ticket me-1"></i>@Localizer["EmailGrid_DeleteTicketLinkedBlocked"]
                                            </span>
                                        }
                                        else
                                        {
                                            <form asp-action="@(Model.IsAdminContext ? "AdminDeleteEmail" : "DeleteEmail")"
                                                  asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                                                  method="post" class="d-inline"
                                                  data-confirm="@Localizer["Emails_ConfirmRemove"].Value">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="emailId" value="@row.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* Admin UserInfo derived-email diagnostic — what callers across the app actually see *@
        @if (Model.IsAdminContext && Model.TargetUserInfo is not null)
        {
            <div class="card mb-4 border-danger" id="userinfo-emails">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fa-solid fa-user-shield me-1"></i><code>UserInfo</code> derived emails <small class="ms-2 opacity-75">(Admin only)</small></h5>
                </div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <tbody>
                            <tr>
                                <th style="width: 16rem;"><code>UserInfo.Email</code></th>
                                <td>
                                    @if (!string.IsNullOrEmpty(Model.TargetUserInfo.Email))
                                    {
                                        <code>@Model.TargetUserInfo.Email</code>
                                    }
                                    else
                                    {
                                        <span class="text-muted">(null)</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th><code>UserInfo.PrimaryEmail</code></th>
                                <td>
                                    @if (!string.IsNullOrEmpty(Model.TargetUserInfo.PrimaryEmail))
                                    {
                                        <code>@Model.TargetUserInfo.PrimaryEmail</code>
                                    }
                                    else
                                    {
                                        <span class="text-muted">(null)</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th><code>UserInfo.GoogleEmail</code></th>
                                <td>
                                    @if (!string.IsNullOrEmpty(Model.TargetUserInfo.GoogleEmail))
                                    {
                                        <code>@Model.TargetUserInfo.GoogleEmail</code>
                                    }
                                    else
                                    {
                                        <span class="text-muted">(null)</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* see nobodies-collective/Humans#697 — admin AspNetUserLogins snapshot + disagreement flags *@
        @if (Model.IsAdminContext)
        {
            <div class="card mb-4 border-danger" id="external-logins">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fa-solid fa-user-shield me-1"></i>AspNetUserLogins <small class="ms-2 opacity-75">(Admin only)</small></h5>
                    <small class="text-white-50">Authoritative store for OAuth identity. The <code>UserEmail</code> provider tag above is a per-row pointer; this is the truth.</small>
                </div>
                <div class="card-body p-0">
                    @if (!Model.ExternalLogins.Any())
                    {
                        <div class="p-3 text-muted">No external login rows for this user.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Provider</th>
                                        <th>Provider Key (SHA-256 prefix)</th>
                                        <th>Display Name</th>
                                        <th>Flags</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var login in Model.ExternalLogins)
                                {
                                    <tr>
                                        <td><code>@login.LoginProvider</code></td>
                                        <td><code>@login.ProviderKeyHash</code></td>
                                        <td>@(login.ProviderDisplayName ?? "—")</td>
                                        <td>
                                            @if (login.HasOrphanLogin)
                                            {
                                                <span class="badge bg-warning text-dark" title="No UserEmail row is tagged with this (Provider, ProviderKey) for this user. Self-heals on next OAuth sign-in via reconcile.">
                                                    <i class="fa-solid fa-triangle-exclamation me-1"></i>No matching UserEmail tag
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @* Admin raw UserEmail dump — diagnostic, no formatting *@
            <div class="card mb-4 border-danger" id="raw-user-emails">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fa-solid fa-user-shield me-1"></i>Raw <code>user_emails</code> rows <small class="ms-2 opacity-75">(Admin only)</small></h5>
                    <small class="text-white-50">Every column verbatim. Admin diagnostic.</small>
                </div>
                <div class="card-body p-0">
                    @if (!Model.RawUserEmails.Any())
                    {
                        <div class="p-3 text-muted">No rows.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0" style="font-family: monospace; font-size: 12px;">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>UserId</th>
                                        <th>Email</th>
                                        <th>IsVerified</th>
                                        <th>IsPrimary</th>
                                        <th>IsGoogle</th>
                                        <th>Provider</th>
                                        <th>ProviderKey</th>
                                        <th>Visibility</th>
                                        <th>VerificationSentAt</th>
                                        <th>CreatedAt</th>
                                        <th>UpdatedAt</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var r in Model.RawUserEmails)
                                {
                                    <tr>
                                        <td>@r.Id</td>
                                        <td>@r.UserId</td>
                                        <td>@r.Email</td>
                                        <td>@r.IsVerified</td>
                                        <td>@r.IsPrimary</td>
                                        <td>@r.IsGoogle</td>
                                        <td>@(r.Provider ?? "")</td>
                                        <td>@(r.ProviderKey ?? "")</td>
                                        <td>@(r.Visibility?.ToString() ?? "")</td>
                                        <td>@(r.VerificationSentAt?.ToString() ?? "")</td>
                                        <td>@r.CreatedAt</td>
                                        <td>@r.UpdatedAt</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @* Admin recovery: insert verified UserEmail without verification email *@
            <div class="card mb-4 border-danger" id="admin-add-verified">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fa-solid fa-user-shield me-1"></i>Add verified email directly <small class="ms-2 opacity-75">(Admin only)</small></h5>
                    <small class="text-white-50">Inserts a verified <code>user_emails</code> row with no verification flow. Use to restore a row deleted in error.</small>
                </div>
                <div class="card-body">
                    <form asp-action="AdminAddVerifiedEmail"
                          asp-route-id="@Model.TargetUserId"
                          method="post"
                          data-confirm="Insert a verified user_emails row for this address? No verification email will be sent.">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label" for="admin-add-verified-email-input">Email address</label>
                            <input id="admin-add-verified-email-input" class="form-control" type="email" name="email"
                                   placeholder="you@example.com" required />
                        </div>
                        <button type="submit" class="btn btn-danger">
                            <i class="fa-solid fa-plus me-1"></i>Insert verified row
                        </button>
                    </form>
                </div>
            </div>
        }

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">@Localizer["Emails_AddNew"]</h5>
            </div>
            <div class="card-body">
                @if (!Model.IsAdminContext)
                {
                    <div class="alert alert-info d-flex align-items-start mb-3">
                        <i class="fa-solid fa-circle-info me-2 fs-4"></i>
                        <div>
                            <strong>@Localizer["Emails_MergeWarningTitle"]</strong>
                            <div>@Localizer["Emails_MergeWarningBody"]</div>
                        </div>
                    </div>
                }
                <form asp-action="@(Model.IsAdminContext ? "AdminAddEmail" : "AddEmail")"
                      asp-route-id="@(Model.IsAdminContext ? Model.TargetUserId : (Guid?)null)"
                      method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NewEmail" class="form-label"></label>
                        @if (Model.IsAdminContext)
                        {
                            <input class="form-control" type="email" name="email"
                                   placeholder="you@example.com" required />
                        }
                        else
                        {
                            <input asp-for="NewEmail" class="form-control" type="email"
                                   placeholder="you@example.com" />
                            <span asp-validation-for="NewEmail" class="text-danger"></span>
                        }
                        <div class="form-text">
                            @Localizer["Emails_VerificationWillBeSent"]
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary"
                            @((Model.IsAdminContext || Model.CanAddEmail) ? "" : "disabled")>
                        <i class="fa-solid fa-paper-plane me-1"></i>
                        @Localizer["Emails_SendVerification"]
                    </button>

                    @if (!Model.IsAdminContext && !Model.CanAddEmail)
                    {
                        <small class="text-muted ms-2">
                            @string.Format(Localizer["Emails_ResendCooldown"].Value, Model.MinutesUntilResend)
                        </small>
                    }
                </form>
            </div>
        </div>

        @if (!Model.IsAdminContext)
        {
            @* see nobodies-collective/Humans#731 — Linked Accounts dashboard (server-validates CanUnlink) *@
            <div class="card mb-4" id="linked-accounts">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fa-solid fa-link me-2"></i>@Localizer["LinkedAccounts_Title"]</h5>
                </div>
                <div class="card-body p-0">
                    <div class="px-3 pt-3">
                        <small class="text-muted">@Localizer["LinkedAccounts_Description"]</small>
                    </div>
                    @if (!Model.LinkedAccounts.Any())
                    {
                        <div class="p-3 text-muted">@Localizer["LinkedAccounts_Empty"]</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>@Localizer["LinkedAccounts_Provider"]</th>
                                        <th>@Localizer["LinkedAccounts_Account"]</th>
                                        <th>@Localizer["LinkedAccounts_LinkedOn"]</th>
                                        <th class="text-end">@Localizer["LinkedAccounts_Actions"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var acct in Model.LinkedAccounts)
                                {
                                    <tr>
                                        <td>
                                            @if (string.Equals(acct.Provider, "Google", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <i class="fa-brands fa-google me-1"></i>
                                            }
                                            else
                                            {
                                                <i class="fa-solid fa-key me-1"></i>
                                            }
                                            @acct.Provider
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(acct.Email))
                                            {
                                                <code>@acct.Email</code>
                                            }
                                            else if (!string.IsNullOrEmpty(acct.ProviderDisplayName))
                                            {
                                                @acct.ProviderDisplayName
                                            }
                                            else
                                            {
                                                <code class="text-muted">@acct.ProviderKeyHash</code>
                                            }
                                        </td>
                                        <td>
                                            @if (acct.LinkedAt.HasValue)
                                            {
                                                @acct.LinkedAt.ToDisplayDate()
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (acct.CanUnlink)
                                            {
                                                <form asp-action="UnlinkLinkedAccount" method="post" class="d-inline"
                                                      data-confirm="@Localizer["LinkedAccounts_ConfirmUnlink"].Value">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="provider" value="@acct.Provider" />
                                                    <input type="hidden" name="providerKey" value="@acct.ProviderKey" />
                                                    <button type="submit" class="btn btn-outline-warning btn-sm">
                                                        <i class="fa-solid fa-link-slash me-1"></i>@Localizer["EmailGrid_Unlink"]
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small" title="@Localizer["LinkedAccounts_LastSignInMethod"].Value">
                                                    <i class="fa-solid fa-lock me-1"></i>@Localizer["LinkedAccounts_LastSignInMethod"]
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fa-brands fa-google me-2"></i>@Localizer["EmailGrid_LinkGoogleAccount"]</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        @Localizer["EmailGrid_LinkGoogleHelp"]
                    </p>
                    <form asp-action="Link" asp-route-provider="Google" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-primary">
                            <i class="fa-brands fa-google me-1"></i>@Localizer["EmailGrid_LinkGoogleAccount"]
                        </button>
                    </form>
                </div>
            </div>
        }

        <div class="mt-4">
            @if (Model.IsAdminContext)
            {
                <a asp-action="AdminDetail" asp-route-id="@Model.TargetUserId" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left me-1"></i>
                    @Localizer["EmailGrid_BackToAdminDetail"]
                </a>
            }
            else
            {
                <a asp-action="Edit" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left me-1"></i>
                    @Localizer["Emails_BackToEdit"]
                </a>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @* No local listeners — site.js global handlers cover these forms (duplicates double-submit) *@
}
