@model Humans.Web.Models.HumanSearchViewModel

@{
    ViewData["Title"] = Localizer["Search_Title"].Value;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Team" asp-action="Index">@Localizer["Teams_Title"]</a></li>
        <li class="breadcrumb-item active">@Localizer["Search_Title"]</li>
    </ol>
</nav>

<h2>@Localizer["Search_Title"]</h2>

<form method="get" class="mb-4">
    <div class="input-group" style="max-width: 500px;">
        <input type="text" name="q" class="form-control" value="@Model.Query"
               placeholder="@Localizer["Search_Placeholder"]" autofocus />
        <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-search"></i>
        </button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Query))
{
    if (Model.Query.Length < 2)
    {
        <div class="alert alert-info">@Localizer["Search_MinChars"]</div>
    }
    else
    {
        @await Html.PartialAsync("_HumanSearchResults", (IReadOnlyList<Humans.Web.Models.HumanSearchResultViewModel>)Model.Results)
    }
}
